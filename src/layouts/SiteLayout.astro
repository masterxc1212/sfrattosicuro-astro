---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import GA4TrackingIsland from '../components/GA4TrackingIsland.astro';
import CookieConsentBanner from '../components/CookieConsentBanner.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  robots?: string;
  image?: string;
  type?: 'website' | 'article';
  hideStickyMobileCta?: boolean;
}

const {
  title = 'Sfratto Sicuro',
  description = 'Sito ufficiale Sfratto Sicuro',
  canonicalPath,
  robots = 'index,follow',
  image,
  type = 'website',
  hideStickyMobileCta = false
} = Astro.props;
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Preconnect Google Fonts so Inter loads with priority (no new fonts added) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:wght@500;600;700&display=swap" rel="stylesheet" />
    <SeoHead
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      robots={robots}
      image={image}
    />
    <slot name="head" />
  </head>
  <body>
    <a class="ss-skip-link" href="#main-content">Vai al contenuto</a>
    <slot />
    {!hideStickyMobileCta && <StickyMobileCTA />}
    <CookieConsentBanner />
    <GA4TrackingIsland measurementId="G-509YE5HCYB" />
    <script is:inline>
      (function () {
        if (!('IntersectionObserver' in window)) {
          document.querySelectorAll('[data-anim="fade-up"]').forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }
        var prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReduce) {
          document.querySelectorAll('[data-anim="fade-up"]').forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          });
        }, { rootMargin: '0px 0px -8% 0px' });
        document.querySelectorAll('[data-anim="fade-up"]').forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>
  </body>
</html>
