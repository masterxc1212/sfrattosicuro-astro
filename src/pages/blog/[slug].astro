---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HeaderIsland from '../../components/HeaderIsland.astro';
import Footer from '../../components/Footer.astro';
import JsonLd from '../../components/JsonLd.astro';
import { blogPosts } from '../../data/blog-posts';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;

const formatDate = (date: string) =>
  new Intl.DateTimeFormat('it-IT', {
    day: '2-digit',
    month: 'long',
    year: 'numeric'
  }).format(new Date(date));

// ---- Editorial enhancements (no copy changes to body) ----
// Slugify per generare anchor stabili sui <h2>
const slugify = (text: string) =>
  text
    .toLowerCase()
    .replace(/[àáâãä]/g, 'a').replace(/[èéêë]/g, 'e').replace(/[ìíîï]/g, 'i')
    .replace(/[òóôõö]/g, 'o').replace(/[ùúûü]/g, 'u').replace(/[ç]/g, 'c')
    .replace(/[^\w\s-]/g, '').trim().replace(/[\s_-]+/g, '-').replace(/^-+|-+$/g, '');

// Estrai gli H2 dal HTML del post per costruire il TOC
const headings = [...post.html.matchAll(/<h2[^>]*>([\s\S]*?)<\/h2>/gi)].map((m) => {
  const text = m[1].replace(/<[^>]+>/g, '').trim();
  return { text, id: slugify(text) };
});

// Inietta gli id sugli H2 del HTML (idempotente: solo dove manca)
let bodyHtml = post.html;
let headingIdx = 0;
bodyHtml = bodyHtml.replace(/<h2(\s[^>]*)?>([\s\S]*?)<\/h2>/gi, (_full, attrs = '', inner) => {
  const id = headings[headingIdx]?.id;
  headingIdx += 1;
  const hasIdAttr = attrs && /\sid\s*=/.test(attrs);
  if (!id || hasIdAttr) return `<h2${attrs || ''}>${inner}</h2>`;
  return `<h2${attrs || ''} id="${id}">${inner}</h2>`;
});

// Related posts: 3 articoli diversi da questo, prima la stessa categoria
const related = (() => {
  const others = blogPosts.filter((p) => p.slug !== post.slug);
  const sameCat = others.filter((p) => p.category === post.category);
  const otherCat = others.filter((p) => p.category !== post.category);
  return [...sameCat, ...otherCat].slice(0, 3);
})();

// Extract FAQ pairs from HTML for FAQPage schema
// Blog posts use <h3>question</h3><p>answer</p> pattern inside FAQ sections
function extractFaqs(html: string): Array<{ q: string; a: string }> {
  const faqs: Array<{ q: string; a: string }> = [];

  // Find FAQ section (h2 with FAQ keyword) and extract h3+p pairs after it
  const faqSectionMatch = html.match(/(?:<h2[^>]*>[^<]*(?:FAQ|Domande|faq)[^<]*<\/h2>)([\s\S]*?)(?=<h2|$)/i);
  const scope = faqSectionMatch ? faqSectionMatch[1] : html;

  // Match <h3>question</h3> followed by <p>answer</p>
  const h3p = [...scope.matchAll(/<h3[^>]*>([\s\S]*?)<\/h3>\s*(?:<p[^>]*>)?([\s\S]*?)(?=<h3|<h2|$)/gi)];
  for (const m of h3p) {
    const q = m[1].replace(/<[^>]+>/g, '').trim();
    // Get first <p> content after the h3
    const pMatch = m[2].match(/<p[^>]*>([\s\S]*?)<\/p>/i);
    const a = (pMatch ? pMatch[1] : m[2]).replace(/<[^>]+>/g, '').trim().substring(0, 400);
    if (q && a && q.length > 10 && a.length > 20) faqs.push({ q, a });
  }

  // Fallback 2: <p><strong>Q</strong><br>A</p> pattern
  if (faqs.length === 0) {
    const faqSection2 = html.match(/(?:<h2[^>]*>[^<]*(?:FAQ|Domande)[^<]*<\/h2>)([\s\S]*?)(?=<h2|$)/i)?.[1] || '';
    const strongBr = [...faqSection2.matchAll(/<p[^>]*>\s*<strong[^>]*>([\s\S]*?)<\/strong>\s*(?:<br\s*\/?>)?([\s\S]*?)<\/p>/gi)];
    for (const m of strongBr) {
      const q = m[1].replace(/<[^>]+>/g, '').trim();
      const a = m[2].replace(/<[^>]+>/g, '').trim().substring(0, 400);
      if (q && a && q.length > 10 && a.length > 20) faqs.push({ q, a });
    }
  }

  // Fallback 3: <dt>/<dd> pattern
  if (faqs.length === 0) {
    const dtdd = [...html.matchAll(/<dt[^>]*>([\s\S]*?)<\/dt>\s*<dd[^>]*>([\s\S]*?)<\/dd>/gi)];
    for (const m of dtdd) {
      const q = m[1].replace(/<[^>]+>/g, '').trim();
      const a = m[2].replace(/<[^>]+>/g, '').trim().substring(0, 400);
      if (q && a) faqs.push({ q, a });
    }
  }

  return faqs.slice(0, 8);
}

const faqItems = extractFaqs(post.html);
const authorSchema = {
  '@type': 'Organization',
  name: 'Redazione Sfratto Sicuro',
  url: 'https://www.sfrattosicuro.it/chi-siamo/'
};

const articleSchema = {
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  inLanguage: 'it-IT',
  mainEntityOfPage: `https://www.sfrattosicuro.it/blog/${post.slug}/`,
  articleSection: post.category,
  author: authorSchema,
  publisher: {
    '@type': 'Organization',
    name: 'Sfratto Sicuro',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.sfrattosicuro.it/assets/img/logo/logo.png'
    }
  }
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  '@id': `https://www.sfrattosicuro.it/blog/${post.slug}/#breadcrumbs`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.sfrattosicuro.it/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://www.sfrattosicuro.it/blog/' },
    { '@type': 'ListItem', position: 3, name: post.title, item: `https://www.sfrattosicuro.it/blog/${post.slug}/` }
  ]
};

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@graph': [
    articleSchema,
    breadcrumbSchema,
    ...(faqItems.length > 0 ? [{
      '@type': 'FAQPage',
      mainEntity: faqItems.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a }
      }))
    }] : [])
  ]
};
---

<SiteLayout
  title={`${post.title} | Sfratto Sicuro`}
  description={post.description}
  canonicalPath={`/blog/${post.slug}/`}
  type="article"
>
  <Fragment slot="head">
    <JsonLd graph={jsonLd} />
  </Fragment>

  <HeaderIsland />

  <div class="reading-progress" aria-hidden="true" data-reading-progress></div>

  <main class="article-main" id="main-content">
    <article class="article">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/blog/">Blog</a>
        <span>/</span>
        <span aria-current="page">{post.title}</span>
      </nav>

      <header class="article-hero">
        <p class="editorial-eyebrow">{post.category}</p>
        <h1>{post.title}</h1>
        <p class="lead">{post.lead}</p>
        <div class="article-meta">
          <span>Pubblicato il {formatDate(post.publishedAt)}</span>
          <span class="dot">·</span>
          <span>{post.readingTime} di lettura</span>
        </div>
      </header>

      <div class="article-grid">
        {headings.length > 1 && (
          <aside class="article-toc" aria-label="Indice articolo">
            <nav class="editorial-toc" data-toc>
              <span class="editorial-toc__label">Indice</span>
              <ol>
                {headings.map((h) => (
                  <li><a href={`#${h.id}`} data-toc-link={h.id}>{h.text}</a></li>
                ))}
              </ol>
            </nav>
          </aside>
        )}

        <div class="article-body" set:html={bodyHtml} />
      </div>

      <aside class="editorial-inline-cta" aria-labelledby="article-cta-headline">
        <p class="label">Studio Avv. Danilo Ansalone</p>
        <p class="headline" id="article-cta-headline">Specialisti in sfratti e diritto delle locazioni</p>
        <p>Operativi su tutto il territorio nazionale.</p>
        <div class="cta-row">
          <a href="/#contatti" class="btn btn-primary">Richiedi consulenza gratuita</a>
          <a href="/#procedura-sfratto" class="btn btn-secondary">Scopri il metodo</a>
        </div>
      </aside>

      {related.length > 0 && (
        <section class="editorial-related" aria-label="Articoli correlati">
          <header class="editorial-related__head">
            <p class="editorial-eyebrow">Articoli correlati</p>
            <a href="/blog/">Tutti gli articoli →</a>
          </header>
          <div class="editorial-related__grid">
            {related.map((p) => (
              <article class="editorial-related__item">
                <p class="cat">{p.category}</p>
                <h3><a href={`/blog/${p.slug}/`}>{p.title}</a></h3>
                <p>{p.description}</p>
                <span class="arrow">Leggi l'articolo →</span>
              </article>
            ))}
          </div>
        </section>
      )}

    </article>
  </main>

  <Footer />

  <script>
    // Reading progress bar
    const bar = document.querySelector('[data-reading-progress]');
    const article = document.querySelector('.article-body');
    if (bar && article) {
      const update = () => {
        const rect = article.getBoundingClientRect();
        const total = rect.height + rect.top;
        const seen = Math.min(Math.max(window.innerHeight - rect.top, 0), total);
        const pct = total > 0 ? Math.min((seen / total) * 100, 100) : 0;
        (bar as HTMLElement).style.width = pct + '%';
      };
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
    }

    // TOC scroll-spy
    const toc = document.querySelector('[data-toc]');
    const links = toc ? Array.from(toc.querySelectorAll<HTMLAnchorElement>('[data-toc-link]')) : [];
    if (toc && links.length > 0) {
      const ids = links.map((a) => a.getAttribute('data-toc-link') || '');
      const targets = ids.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];
      const setActive = (id: string) => {
        links.forEach((a) => a.classList.toggle('is-active', a.getAttribute('data-toc-link') === id));
      };
      const obs = new IntersectionObserver(
        (entries) => {
          const visible = entries.filter((e) => e.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible[0]) setActive(visible[0].target.id);
        },
        { rootMargin: '-30% 0px -55% 0px', threshold: 0.01 }
      );
      targets.forEach((t) => obs.observe(t));
    }

    // Fade-up on scroll (one-shot)
    const animTargets = document.querySelectorAll('[data-anim="fade-up"]');
    if (animTargets.length > 0 && 'IntersectionObserver' in window) {
      const animObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              animObs.unobserve(e.target);
            }
          });
        },
        { rootMargin: '0px 0px -10% 0px' }
      );
      animTargets.forEach((t) => animObs.observe(t));
    }
  </script>
</SiteLayout>

