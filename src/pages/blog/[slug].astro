---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HeaderIsland from '../../components/HeaderIsland.astro';
import Footer from '../../components/Footer.astro';
import JsonLd from '../../components/JsonLd.astro';
import { blogPosts } from '../../data/blog-posts';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;

const formatDate = (date: string) =>
  new Intl.DateTimeFormat('it-IT', {
    day: '2-digit',
    month: 'long',
    year: 'numeric'
  }).format(new Date(date));

// Extract FAQ pairs from HTML for FAQPage schema
function extractFaqs(html: string): Array<{ q: string; a: string }> {
  const faqs: Array<{ q: string; a: string }> = [];
  // Match <dt>question</dt><dd>answer</dd> pattern
  const dtdd = [...html.matchAll(/<dt[^>]*>([\s\S]*?)<\/dt>\s*<dd[^>]*>([\s\S]*?)<\/dd>/gi)];
  for (const m of dtdd) {
    const q = m[1].replace(/<[^>]+>/g, '').trim();
    const a = m[2].replace(/<[^>]+>/g, '').trim();
    if (q && a) faqs.push({ q, a });
  }
  // Fallback: match <strong>Q</strong> ... pattern in FAQ sections
  if (faqs.length === 0) {
    const faqSection = html.match(/FAQ[\s\S]*$/i)?.[0] || '';
    const items = [...faqSection.matchAll(/<strong[^>]*>([\s\S]*?)<\/strong>([\s\S]*?)(?=<strong|$)/gi)];
    for (const m of items.slice(0, 8)) {
      const q = m[1].replace(/<[^>]+>/g, '').trim();
      const a = m[2].replace(/<[^>]+>/g, '').trim().substring(0, 300);
      if (q && a && q.length > 10) faqs.push({ q, a });
    }
  }
  return faqs.slice(0, 8);
}

const faqItems = extractFaqs(post.html);

const articleSchema = {
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  inLanguage: 'it-IT',
  mainEntityOfPage: `https://www.sfrattosicuro.it/blog/${post.slug}/`,
  articleSection: post.category,
  author: {
    '@type': 'Organization',
    name: 'Sfratto Sicuro'
  },
  publisher: {
    '@type': 'Organization',
    name: 'Sfratto Sicuro',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.sfrattosicuro.it/assets/img/logo/logo.png'
    }
  }
};

const jsonLd: Record<string, unknown> = faqItems.length > 0
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        articleSchema,
        {
          '@type': 'FAQPage',
          mainEntity: faqItems.map(({ q, a }) => ({
            '@type': 'Question',
            name: q,
            acceptedAnswer: { '@type': 'Answer', text: a }
          }))
        }
      ]
    }
  : {
      '@context': 'https://schema.org',
      ...articleSchema
    };
---

<SiteLayout
  title={`${post.title} | Blog Sfratto Sicuro`}
  description={post.description}
  canonicalPath={`/blog/${post.slug}/`}
  type="article"
>
  <Fragment slot="head">
    <JsonLd graph={jsonLd} />
  </Fragment>

  <HeaderIsland />

  <main class="page">
    <article class="article">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/blog/">Blog</a>
        <span>/</span>
        <span aria-current="page">{post.title}</span>
      </nav>

      <header class="hero">
        <p class="eyebrow">{post.category}</p>
        <h1>{post.title}</h1>
        <p class="lead">{post.lead}</p>
        <div class="meta">
          <span>Pubblicato il {formatDate(post.publishedAt)}</span>
          <span>{post.readingTime} di lettura</span>
        </div>
      </header>

      <div class="body" set:html={post.html} />

      <aside class="recovery-note">
        <strong>Nota di ripristino:</strong> {post.sourceNote}
      </aside>
    </article>
  </main>

  <Footer />
</SiteLayout>

