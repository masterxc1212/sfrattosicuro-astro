---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HeaderIsland from '../../components/HeaderIsland.astro';
import Footer from '../../components/Footer.astro';
import JsonLd from '../../components/JsonLd.astro';
import { blogPosts } from '../../data/blog-posts';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;

const formatDate = (date: string) =>
  new Intl.DateTimeFormat('it-IT', {
    day: '2-digit',
    month: 'long',
    year: 'numeric'
  }).format(new Date(date));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  inLanguage: 'it-IT',
  mainEntityOfPage: `https://www.sfrattosicuro.it/blog/${post.slug}/`,
  articleSection: post.category,
  author: {
    '@type': 'Organization',
    name: 'Sfratto Sicuro'
  },
  publisher: {
    '@type': 'Organization',
    name: 'Sfratto Sicuro',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.sfrattosicuro.it/assets/img/logo/logo.png'
    }
  }
};
---

<SiteLayout
  title={`${post.title} | Blog Sfratto Sicuro`}
  description={post.description}
  canonicalPath={`/blog/${post.slug}/`}
  type="article"
>
  <Fragment slot="head">
    <JsonLd graph={jsonLd} />
  </Fragment>

  <HeaderIsland />

  <main class="page">
    <article class="article">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/blog/">Blog</a>
        <span>/</span>
        <span aria-current="page">{post.title}</span>
      </nav>

      <header class="hero">
        <p class="eyebrow">{post.category}</p>
        <h1>{post.title}</h1>
        <p class="lead">{post.lead}</p>
        <div class="meta">
          <span>Pubblicato il {formatDate(post.publishedAt)}</span>
          <span>{post.readingTime} di lettura</span>
        </div>
      </header>

      <div class="body" set:html={post.html} />

      <aside class="recovery-note">
        <strong>Nota di ripristino:</strong> {post.sourceNote}
      </aside>
    </article>
  </main>

  <Footer />
</SiteLayout>

