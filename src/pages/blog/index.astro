---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HeaderIsland from '../../components/HeaderIsland.astro';
import Footer from '../../components/Footer.astro';

// Fetch categories from WordPress API
const fetchCategories = async () => {
  try {
    const res = await fetch('https://www.sfrattosicuro.it/blog/wp-json/wp/v2/categories?per_page=100', { cache: 'no-store' });
    const data = await res.json();
    return data.filter(cat => cat.id === 13 || cat.id === 15);
  } catch {
    return [];
  }
};

const categories = await fetchCategories();
---

<SiteLayout
  title="Blog | Sfratto Sicuro"
  description="Archivio articoli e approfondimenti legali su sfratti, morosità, finita locazione e tutela del proprietario."
  canonicalPath="/blog/"
>
  <HeaderIsland />

  <main class="page">
    <section class="hero">
      <p class="eyebrow">Blog</p>
      <h1>Archivio articoli su sfratti e locazioni</h1>
      <p class="lead">
        Approfondimenti pratici su sfratto per morosità, finita locazione, tempi, costi,
        recupero canoni e tutela del proprietario.
      </p>
    </section>

    <section class="blog-content">
      {/* Sidebar category filter */}
      <aside class="sidebar">
        <h2 class="sidebar-title">Categorie</h2>
        <nav class="category-nav" aria-label="Categorie articoli">
          <button type="button" class="cat-btn active" data-category="all">Tutti gli articoli</button>
          {categories.map((cat) => (
            <button type="button" class="cat-btn" data-category={cat.id}>
              {cat.name}
            </button>
          ))}
        </nav>
      </aside>

      {/* Main content area: display filtered posts */}
      <div class="main-area">
        <section class="archive" aria-labelledby="archive-title">
          <div class="section-head archive-head">
            <div>
              <h2 id="archive-title">Elenco articoli</h2>
            </div>
          </div>

          <div id="blog-archive-grid" class="grid" aria-live="polite">
            <article class="card skeleton"></article>
            <article class="card skeleton"></article>
            <article class="card skeleton"></article>
          </div>

          <p id="blog-archive-status" class="status">Caricamento articoli in corso…</p>
        </section>
      </div>
    </section>
  </main>

  <Footer />
</SiteLayout>

<script>
(() => {
  const grid = document.getElementById('blog-archive-grid');
  const statusEl = document.getElementById('blog-archive-status');
  const catBtns = document.querySelectorAll('.cat-btn');
  if (!grid || !statusEl || !catBtns.length) return;

  let allPosts = [];
  let currentFilter = 'all';

  const decode = (value) => {
    const txt = document.createElement('textarea');
    txt.innerHTML = value || '';
    return txt.value;
  };

  const stripHtml = (html) => {
    const div = document.createElement('div');
    div.innerHTML = html || '';
    return (div.textContent || div.innerText || '').trim();
  };

  const formatDate = (iso) => {
    try {
      return new Intl.DateTimeFormat('it-IT', { day: '2-digit', month: 'long', year: 'numeric' }).format(new Date(iso));
    } catch { return ''; }
  };

  const pickCategories = (post) => {
    const groups = post?._embedded?.['wp:term'];
    if (!Array.isArray(groups)) return [];
    const cats = groups.flat().filter((item) => item?.taxonomy === 'category');
    return cats.map((cat) => ({
      id: cat?.id,
      name: cat?.name || '',
      link: cat?.link || '#'
    })).filter((cat) => cat.id && cat.name && cat.name.toLowerCase() !== 'uncategorized');
  };

  const render = (posts) => {
    if (!Array.isArray(posts) || !posts.length) {
      grid.innerHTML = '<p class="empty">Nessun articolo trovato per questa categoria.</p>';
      statusEl.textContent = '0 articoli caricati.';
      return;
    }

    grid.innerHTML = posts.map((post) => {
      const title = decode(post?.title?.rendered || 'Articolo');
      const excerpt = stripHtml(post?.excerpt?.rendered || '');
      const summary = excerpt.length > 220 ? excerpt.slice(0, 220).trim() + '…' : excerpt;
      const link = post?.link || '#';
      const date = formatDate(post?.date);
      const categories = pickCategories(post);
      const categoriesHtml = categories.length
        ? `<div class="cats">${categories.map((cat) => `<span class="cat">${cat.name}</span>`).join('')}</div>`
        : '';

      return `<article class="card">
        ${categoriesHtml}
        <h3><a href="${link}">${title}</a></h3>
        <p class="meta">${date}</p>
        <p class="excerpt">${summary || 'Apri l’articolo per leggere l’approfondimento completo.'}</p>
        <a class="read-more" href="${link}">Leggi l’articolo</a>
      </article>`;
    }).join('');

    statusEl.textContent = `${posts.length} ${posts.length === 1 ? 'articolo trovato' : 'articoli trovati'}.`;
  };

  const applyFilter = (filterId) => {
    currentFilter = filterId;
    catBtns.forEach(btn => {
      btn.classList.toggle('active', btn.dataset.category === String(currentFilter));
    });

    if (filterId === 'all') {
      render(allPosts);
    } else {
      const filteredPosts = allPosts.filter(post => {
        const postCats = pickCategories(post).map(c => c.id);
        return postCats.includes(Number(filterId));
      });
      render(filteredPosts);
    }
  };

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.category));
  });

  fetch(`https://www.sfrattosicuro.it/blog/wp-json/wp/v2/posts?per_page=100&_embed&orderby=date&order=desc&nocache=${Date.now()}`, { cache: 'no-store' })
    .then((r) => (r.ok ? r.json() : Promise.reject(new Error('fetch_failed'))))
    .then(posts => {
      allPosts = posts;
      applyFilter('all');
    })
    .catch(() => {
      grid.innerHTML = '<p class="empty">Impossibile caricare l’archivio in questo momento.</p>';
      statusEl.textContent = 'Riprova tra poco.';
    });
})();
</script>

<style>
  .page { max-width: 1200px; margin: 0 auto; padding: 40px 24px 56px; }
  .hero { padding: 20px 0 18px; }
  .eyebrow, .category-eyebrow { margin: 0 0 8px; color: #c6902a; text-transform: uppercase; letter-spacing: .05em; font-weight: 700; }
  h1 { margin: 0 0 14px; color: var(--blue-navy); font-size: clamp(2rem, 4vw, 3.2rem); line-height: 1.05; }
  .lead, .sub, .status, .category-card p { color: #475569; line-height: 1.7; }
  .category-section, .archive { margin-top: 22px; }
  .section-head { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 16px; align-items: end; margin-bottom: 20px; }
  .archive-head { margin-top: 6px; }
  h2, h3 { color: var(--blue-navy); }
  h2 { margin: 0 0 6px; }

  /* New layout */
  .blog-content { display: flex; gap: 24px; margin-top: 24px; }
  .sidebar { flex: 0 0 260px; }
  .sidebar-title { margin: 0 0 16px; font-size: 1.25rem; color: var(--blue-navy); }
  .category-nav { display: flex; flex-direction: column; gap: 8px; }
  .cat-btn {
    text-align: left;
    padding: 10px 14px;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    background: #fff;
    font-weight: 600;
    color: #334155;
    cursor: pointer;
    transition: all 150ms ease;
  }
  .cat-btn:hover { background: #f8fafc; border-color: #cbd5e1; }
  .cat-btn.active { background: var(--blue-navy); color: #fff; border-color: var(--blue-navy); }
  .main-area { flex: 1; min-width: 0; }

  .category-grid, .grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; }
  .category-card, .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 18px; padding: 24px; box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05); display: flex; flex-direction: column; gap: 12px; }
  .category-card { background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%); }
  .category-card h3, .card h3 { margin: 0; font-size: 1.18rem; line-height: 1.35; }
  .read-more, .category-link, .card h3 a { color: var(--blue-navy); text-decoration: none; font-weight: 700; }
  .read-more:hover, .category-link:hover, .card h3 a:hover { color: var(--green-security); }
  
  .skeleton { min-height: 220px; background: linear-gradient(90deg, #eef2f7 25%, #f8fafc 37%, #eef2f7 63%); background-size: 400% 100%; animation: shimmer 1.4s ease infinite; }
  .cats { display: flex; gap: 8px; flex-wrap: wrap; }
  .cat { display: inline-flex; align-items: center; min-height: 32px; padding: 6px 10px; border-radius: 999px; background: #eef6ff; border: 1px solid #dbeafe; color: #1d4ed8; font-size: .82rem; font-weight: 700; }
  .meta { margin: 0; color: #64748b; font-size: .92rem; }
  .excerpt { margin: 0; color: #334155; line-height: 1.7; flex: 1; }
  .empty { grid-column: 1 / -1; margin: 0; padding: 28px; border-radius: 16px; background: #fff; border: 1px dashed #cbd5e1; color: #475569; }

  @keyframes shimmer { 0% { background-position: 100% 0; } 100% { background-position: -100% 0; } }

  @media (max-width: 1024px) { .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 767px) { .page { padding: 28px 16px 40px; } .blog-content { flex-direction: column; } .sidebar { width: 100%; } .category-grid, .grid { grid-template-columns: 1fr; } .section-head { align-items: start; } }
</style>