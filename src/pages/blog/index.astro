---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HeaderIsland from '../../components/HeaderIsland.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import { blogCategories, blogPosts } from '../../data/blog-posts';

const postsByCategory = blogCategories.map((category) => ({
  category,
  slug: category.toLowerCase(),
  posts: blogPosts.filter((post) => post.category === category)
}));
---

<SiteLayout
  title="Blog | Sfratto Sicuro"
  description="Archivio articoli e approfondimenti legali su sfratti, morosità, finita locazione, locazioni e tutela del proprietario."
  canonicalPath="/blog/"
>
  <HeaderIsland />

  <main class="page">
    <section class="hero">
      <p class="eyebrow">Blog</p>
      <h1>Archivio articoli su sfratti e locazioni</h1>
      <p class="lead">
        Approfondimenti pratici su sfratto per morosità, finita locazione, contratti,
        recupero canoni e tutela del proprietario.
      </p>
    </section>

    <section class="summary-grid" aria-label="Panoramica archivio blog">
      <article class="summary-card">
        <strong>{blogPosts.length}</strong>
        <span>articoli pubblicati</span>
      </article>
      <article class="summary-card">
        <strong>{blogCategories.length}</strong>
        <span>categorie editoriali</span>
      </article>
    </section>

    <section class="category-nav" aria-labelledby="category-nav-title">
      <div class="section-head compact">
        <div>
          <p class="eyebrow small">Categorie</p>
          <h2 id="category-nav-title">Esplora per categoria</h2>
        </div>
      </div>

      <div class="category-pills">
        {postsByCategory.map(({ category, slug, posts }) => (
          <a href={`#categoria-${slug}`} class="category-pill">
            <span>{category}</span>
            <small>{posts.length} articoli</small>
          </a>
        ))}
      </div>
    </section>

    <section class="archive" aria-labelledby="archive-title">
      <div class="section-head">
        <div>
          <p class="eyebrow small">Elenco articoli</p>
          <h2 id="archive-title">Articoli disponibili</h2>
        </div>
      </div>

      <div class="category-sections">
        {postsByCategory.map(({ category, slug, posts }) => (
          <section id={`categoria-${slug}`} class="category-section" aria-labelledby={`titolo-${slug}`}>
            <div class="category-section-head">
              <div>
                <p class="eyebrow small">Categoria</p>
                <h3 id={`titolo-${slug}`}>{category}</h3>
              </div>
              <span class="count-badge">{posts.length} articoli</span>
            </div>

            <div class="grid">
              {posts.map((post) => <BlogCard post={post} />)}
            </div>
          </section>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</SiteLayout>

