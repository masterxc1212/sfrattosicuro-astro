---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HeaderIsland from '../../components/HeaderIsland.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import { blogCategories, blogPosts } from '../../data/blog-posts';
---

<SiteLayout
  title="Blog | Sfratto Sicuro"
  description="Archivio articoli e approfondimenti legali su sfratti, morosità, finita locazione, locazioni e tutela del proprietario."
  canonicalPath="/blog/"
>
  <HeaderIsland />

  <main class="page">
    <section class="hero">
      <p class="eyebrow">Blog</p>
      <h1>Archivio articoli su sfratti e locazioni</h1>
      <p class="lead">
        Approfondimenti pratici su sfratto per morosità, finita locazione, contratti,
        recupero canoni e tutela del proprietario.
      </p>
    </section>

    <section class="summary-grid" aria-label="Panoramica archivio blog">
      <article class="summary-card">
        <strong>{blogPosts.length}</strong>
        <span>articoli statici pubblicati</span>
      </article>
      <article class="summary-card">
        <strong>{blogCategories.length}</strong>
        <span>categorie editoriali presidiate</span>
      </article>
      <article class="summary-card">
        <strong>URL preservate</strong>
        <span>nessun fetch runtime da WordPress</span>
      </article>
    </section>

    <section class="archive" aria-labelledby="archive-title">
      <div class="section-head">
        <div>
          <p class="eyebrow small">Elenco articoli</p>
          <h2 id="archive-title">Articoli disponibili</h2>
        </div>
      </div>

      <div class="grid">
        {blogPosts.map((post) => <BlogCard post={post} />)}
      </div>
    </section>
  </main>

  <Footer />
</SiteLayout>

<style>
  .page { max-width: 1200px; margin: 0 auto; padding: 40px 24px 56px; }
  .hero { padding: 20px 0 18px; }
  .eyebrow { margin: 0 0 8px; color: #c6902a; text-transform: uppercase; letter-spacing: .05em; font-weight: 700; }
  .eyebrow.small { font-size: .82rem; }
  h1 { margin: 0 0 14px; color: var(--blue-navy); font-size: clamp(2rem, 4vw, 3.2rem); line-height: 1.05; }
  h2 { margin: 0; color: var(--blue-navy); }
  .lead { color: #475569; line-height: 1.7; max-width: 74ch; }
  .summary-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; margin-top: 24px; }
  .summary-card {
    border: 1px solid #dbeafe;
    background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
    border-radius: 18px;
    padding: 20px;
    display: grid;
    gap: 8px;
  }
  .summary-card strong { color: var(--blue-navy); font-size: 1.4rem; }
  .summary-card span { color: #475569; line-height: 1.6; }
  .archive { margin-top: 28px; }
  .section-head { display: flex; justify-content: space-between; gap: 16px; align-items: end; margin-bottom: 20px; }
  .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; }
  @media (max-width: 900px) {
    .summary-grid, .grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 767px) {
    .page { padding: 28px 16px 40px; }
  }
</style>
