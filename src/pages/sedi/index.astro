---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HeaderIsland from '../../components/HeaderIsland.astro';
import Footer from '../../components/Footer.astro';
import JsonLd from '../../components/JsonLd.astro';
import PageJumpNavIsland from '../../components/PageJumpNavIsland.astro';
import sedi from '../../data/sedi.json';
import site from '../../data/site.json';

type SedeItem = {
  nome: string;
  slug: string;
  regione: string;
  tribunale?: string;
};

const list = (sedi as SedeItem[])
  .slice()
  .sort((a, b) => a.regione.localeCompare(b.regione, 'it') || a.nome.localeCompare(b.nome, 'it'));

const grouped = list.reduce((acc, item) => {
  if (!acc[item.regione]) acc[item.regione] = [];
  acc[item.regione].push(item);
  return acc;
}, {} as Record<string, SedeItem[]>);

const regionNames = Object.keys(grouped).sort((a, b) => a.localeCompare(b, 'it'));
const totalSedi = list.length;
const totalRegioni = regionNames.length;

const topCities = ['Milano', 'Roma', 'Napoli', 'Torino', 'Bologna', 'Firenze'];

// Risolvi i dati completi (slug, regione, tribunale) per le top cities monolitiche
const topCityCards = topCities
  .map((name) => list.find((c) => c.nome === name))
  .filter((c): c is SedeItem => Boolean(c));

const macroAreaByRegione: Record<string, 'Nord' | 'Centro' | 'Sud' | 'Isole'> = {
  "Valle d'Aosta": 'Nord',
  Piemonte: 'Nord',
  Lombardia: 'Nord',
  Liguria: 'Nord',
  Veneto: 'Nord',
  'Trentino Alto Adige': 'Nord',
  'Friuli Venezia Giulia': 'Nord',
  'Emilia Romagna': 'Nord',
  Toscana: 'Centro',
  Umbria: 'Centro',
  Marche: 'Centro',
  Lazio: 'Centro',
  Abruzzo: 'Sud',
  Molise: 'Sud',
  Campania: 'Sud',
  Puglia: 'Sud',
  Basilicata: 'Sud',
  Calabria: 'Sud',
  Sicilia: 'Isole',
  Sardegna: 'Isole'
};

const macroAreaStats = list.reduce(
  (acc, item) => {
    const area = macroAreaByRegione[item.regione] ?? 'Nord';
    acc[area] += 1;
    return acc;
  },
  { Nord: 0, Centro: 0, Sud: 0, Isole: 0 } as Record<'Nord' | 'Centro' | 'Sud' | 'Isole', number>
);

const regionToId = (region: string) => `regione-${region.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;

const siteUrl = site.siteUrl.replace(/\/$/, '');

const sediItemList = list.map((item, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  name: `Avvocato per sfratto a ${item.nome}`,
  url: `${siteUrl}/sedi/${item.slug}/`
}));

const sediGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: `${siteUrl}/`,
      name: site.organization.name,
      inLanguage: 'it-IT',
      publisher: { '@id': `${siteUrl}/#organization` }
    },
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: site.organization.name,
      legalName: site.organization.legalName,
      url: `${siteUrl}/`,
      logo: {
        '@type': 'ImageObject',
        url: site.organization.logoUrl
      }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${siteUrl}/sedi/#breadcrumbs`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Sedi', item: `${siteUrl}/sedi/` }
      ]
    },
    {
      '@type': 'CollectionPage',
      '@id': `${siteUrl}/sedi/#collectionpage`,
      url: `${siteUrl}/sedi/`,
      name: 'Sedi territoriali | Sfratto Sicuro',
      description: 'Elenco delle sedi territoriali e presidi operativi in Italia per assistenza legale nelle procedure di sfratto.',
      inLanguage: 'it-IT',
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}/#organization` },
      breadcrumb: { '@id': `${siteUrl}/sedi/#breadcrumbs` },
      mainEntity: { '@id': `${siteUrl}/sedi/#itemlist` }
    },
    {
      '@type': 'ItemList',
      '@id': `${siteUrl}/sedi/#itemlist`,
      name: 'Elenco sedi territoriali',
      numberOfItems: totalSedi,
      itemListOrder: 'https://schema.org/ItemListOrderAscending',
      itemListElement: sediItemList
    }
  ]
};
---

<SiteLayout
  title="Sedi territoriali | Sfratto Sicuro"
  description="Elenco delle sedi territoriali e presidi operativi in Italia per assistenza legale nelle procedure di sfratto."
  canonicalPath="/sedi/"
>
  <Fragment slot="head">
    <JsonLd graph={sediGraph} />
  </Fragment>

  <HeaderIsland />
  <PageJumpNavIsland
    title="Percorso rapido"
    items={[
      { href: '#citySearch', label: 'Cerca città' },
      { href: '#regionIndex', label: 'Indice regioni' },
      { href: '#regionList', label: 'Elenco sedi' },
      { href: '/servizi/#contatti', label: 'Richiedi consulenza' }
    ]}
  />

  <main id="main-content">
    <section class="sedi-hero">
      <div class="container">
        <div class="hero-copy">
          <p class="editorial-eyebrow">Rete territoriale</p>
          <h1>Sedi territoriali</h1>
          <p class="hero-sub">Trova rapidamente la sede di riferimento per città o regione e accedi alla pagina locale dedicata.</p>
        </div>

        <div class="stats" aria-label="Statistiche sedi">
          <span><strong class="stat-num">{totalSedi}</strong><span class="stat-label">sedi operative</span></span>
          <span><strong class="stat-num">{totalRegioni}</strong><span class="stat-label">regioni coperte</span></span>
        </div>
      </div>
    </section>

    <section class="top-cities" aria-label="Sedi delle città principali">
      <div class="container">
        <div class="top-cities__grid">
          {topCityCards.map((city) => (
            <a class="top-city" href={`/sedi/${city.slug}/`} data-anim="fade-up">
              <p class="region-tag">{city.regione}</p>
              <p class="city-name">{city.nome}</p>
              <p class="court">{city.tribunale ?? `Tribunale di ${city.nome}`}</p>
              <span class="arrow">Avvocato per sfratto a {city.nome} →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="coverage-visual" aria-label="Copertura nazionale">
      <div class="container coverage-grid">
        <div class="coverage-copy">
          <p class="editorial-eyebrow">Copertura</p>
          <h2>Copertura nazionale a colpo d'occhio</h2>
          <p>
            La rete è distribuita su tutto il territorio italiano, con presidi operativi nelle principali aree
            geografiche. Seleziona una regione dalla mappa per saltare direttamente alla sezione dedicata.
          </p>
        </div>

        <div class="macro-stats" aria-label="Sedi per macro area">
          <span><strong>{macroAreaStats.Nord}</strong> Nord</span>
          <span><strong>{macroAreaStats.Centro}</strong> Centro</span>
          <span><strong>{macroAreaStats.Sud}</strong> Sud</span>
          <span><strong>{macroAreaStats.Isole}</strong> Isole</span>
        </div>
      </div>
    </section>

    <section class="sticky-tools" aria-label="Ricerca e filtri">
      <div class="container tools-grid">
        <label class="field">
          <span>Cerca città</span>
          <input id="citySearch" type="search" placeholder="Es. Milano, Roma, Napoli" aria-label="Cerca una città" />
        </label>

        <label class="field">
          <span>Filtra per regione</span>
          <select id="regionFilter" aria-label="Filtra per regione">
            <option value="">Tutte le regioni</option>
            {regionNames.map((region) => (
              <option value={region}>{region}</option>
            ))}
          </select>
        </label>

        <button id="resetFilters" type="button" class="btn-reset">Reset</button>
      </div>

      <div class="container quick-links">
        <p class="quick-title">Città più cercate</p>
        <div class="chips">
          {topCities.map((city) => (
            <button type="button" class="city-chip" data-city-chip={city}>{city}</button>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--compact">
      <nav class="container region-index" id="regionIndex" aria-label="Indice regioni">
        {regionNames.map((region) => (
          <a href={`#${regionToId(region)}`}>{region}</a>
        ))}
      </nav>
    </section>

    <section class="section section--compact">
      <div class="container">
        <p id="resultsCounter" class="results-counter" aria-live="polite"></p>
        <p id="noResults" class="no-results" hidden>Nessuna sede trovata con i filtri selezionati.</p>

        <div class="region-list" id="regionList">
          {regionNames.map((region, index) => {
            const indexLabel = String(index + 1).padStart(2, '0') + ' / ' + String(regionNames.length).padStart(2, '0');
            return (
              <section class="region" data-region={region} id={regionToId(region)}>
                <header class="region-head">
                  <span class="region-num">{indexLabel}</span>
                  <h2>
                    {region}
                    <span class="count">{grouped[region].length} sedi</span>
                  </h2>
                </header>
                <ul class="city-grid">
                  {grouped[region].map((item) => (
                    <li data-city={item.nome.toLowerCase()}>
                      <a href={`/sedi/${item.slug}/`}>Avvocato per sfratto a {item.nome}</a>
                    </li>
                  ))}
                </ul>
              </section>
            );
          })}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</SiteLayout>

<script>
  const searchInput = document.getElementById('citySearch');
  const regionFilter = document.getElementById('regionFilter');
  const resetBtn = document.getElementById('resetFilters');
  const regionList = Array.from(document.querySelectorAll('.region'));
  const resultsCounter = document.getElementById('resultsCounter');
  const noResults = document.getElementById('noResults');
  const cityChips = Array.from(document.querySelectorAll('[data-city-chip]'));

  const updateCounter = (count) => {
    if (!resultsCounter) return;
    resultsCounter.textContent = count === 1 ? '1 sede trovata' : `${count} sedi trovate`;
  };

  const applyFilters = () => {
    const query = (searchInput?.value || '').trim().toLowerCase();
    const selectedRegion = regionFilter?.value || '';
    let totalVisibleCities = 0;

    regionList.forEach((regionEl) => {
      const regionName = regionEl.getAttribute('data-region') || '';
      const matchesRegion = !selectedRegion || regionName === selectedRegion;

      let visibleCities = 0;
      regionEl.querySelectorAll('li[data-city]').forEach((li) => {
        const city = li.getAttribute('data-city') || '';
        const show = city.includes(query);
        li.style.display = show ? '' : 'none';
        if (show) visibleCities++;
      });

      const showRegion = matchesRegion && visibleCities > 0;
      regionEl.style.display = showRegion ? '' : 'none';
      totalVisibleCities += showRegion ? visibleCities : 0;
    });

    updateCounter(totalVisibleCities);
    if (noResults) noResults.hidden = totalVisibleCities !== 0;
  };

  searchInput?.addEventListener('input', applyFilters);
  regionFilter?.addEventListener('change', applyFilters);

  resetBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    if (regionFilter) regionFilter.value = '';
    applyFilters();
  });

  cityChips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const city = chip.getAttribute('data-city-chip') || '';
      if (searchInput) searchInput.value = city;
      applyFilters();
    });
  });

  applyFilters();
</script>

