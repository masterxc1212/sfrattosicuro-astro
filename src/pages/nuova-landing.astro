---
/**
 * /nuova-landing/ — Preview landing con header/footer del sito.
 * Usa LandingModel.astro che assembla i componenti modulari.
 * Per la versione con header minimal, vedi /landing-v2/.
 */
import SiteLayout from '../layouts/SiteLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import LandingModel from '../components/LandingModel.astro';
import { getLandingConfig, landingOrg } from '../data/landing-model';
import site from '../data/site.json';

const config = getLandingConfig('nazionale');
const siteUrl = site.siteUrl.replace(/\/$/, '');

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${siteUrl}${config.canonicalPath}#webpage`,
      url: `${siteUrl}${config.canonicalPath}`,
      name: config.title,
      description: config.description
    },
    {
      '@type': 'LegalService',
      '@id': `${siteUrl}${config.canonicalPath}#service`,
      name: 'Sfratto Sicuro',
      url: `${siteUrl}${config.canonicalPath}`,
      telephone: landingOrg.telephone,
      email: landingOrg.email,
      areaServed: { '@type': 'Country', name: 'IT' },
      serviceType: ['Sfratto per morosità', 'Sfratto per finita locazione']
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteUrl}${config.canonicalPath}#faq`,
      mainEntity: config.faq.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a }
      }))
    }
  ]
};
---

<SiteLayout
  title={config.title}
  description={config.description}
  canonicalPath={config.canonicalPath}
  robots={config.noindex ? 'noindex,nofollow' : 'index,follow'}
>
  <Fragment slot="head">
    <JsonLd graph={graph} />
  </Fragment>

  <LandingModel config={config} />
</SiteLayout>
