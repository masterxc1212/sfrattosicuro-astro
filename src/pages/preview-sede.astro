---
import SiteLayout from '../layouts/SiteLayout.astro';
import sedi from '../data/sedi.json';
import HeaderIsland from '../components/HeaderIsland.astro';
import HeroInstitutionalIsland from '../components/HeroInstitutionalIsland.astro';
import ReviewsIsland from '../components/ReviewsIsland.astro';
import VideoReviewsIsland from '../components/VideoReviewsIsland.astro';
import ContactFormIsland from '../components/ContactFormIsland.astro';
import SmoothScrollIsland from '../components/SmoothScrollIsland.astro';
import Footer from '../components/Footer.astro';
import SedeIdentityIsland from '../components/SedeIdentityIsland.astro';
import ProvvedimentiIsland from '../components/ProvvedimentiIsland.astro';
import StudioSection from '../components/StudioSection.astro';
import WhenPossibleSection from '../components/WhenPossibleSection.astro';
import ProcedureSection from '../components/ProcedureSection.astro';
import TypesSection from '../components/TypesSection.astro';
import TimelineSection from '../components/TimelineSection.astro';
import WhyLawyerSection from '../components/WhyLawyerSection.astro';
import TerritoryCoverageSection from '../components/TerritoryCoverageSection.astro';
import FaqSection from '../components/FaqSection.astro';

const sedeSlug = Astro.url.searchParams.get('sede')?.trim().toLowerCase() || 'milano';
const exists = (sedi as { slug: string }[]).some((item) => item.slug === sedeSlug);
const canonicalPath = exists ? `/sedi/${sedeSlug}/` : '/';
---

<SiteLayout
  title={`Preview sede ${sedeSlug} | Sfratto Sicuro`}
  description="Preview interna pagina sede."
  canonicalPath={canonicalPath}
  robots="noindex,nofollow"
>
  <HeaderIsland />
  <main id="main-content">
    <HeroInstitutionalIsland sedeSlug={sedeSlug} />
    <SedeIdentityIsland sedeSlug={sedeSlug} />

    <WhenPossibleSection sedeSlug={sedeSlug} />
    <ProcedureSection sedeSlug={sedeSlug} />
    <TypesSection sedeSlug={sedeSlug} />
    <TimelineSection sedeSlug={sedeSlug} />
    <WhyLawyerSection sedeSlug={sedeSlug} />
    <TerritoryCoverageSection sedeSlug={sedeSlug} />

    <StudioSection sedeSlug={sedeSlug} />
    <ProvvedimentiIsland />
    <ReviewsIsland />
    <VideoReviewsIsland />
    <FaqSection sedeSlug={sedeSlug} />
    <ContactFormIsland />
  </main>

  <Footer sedeSlug={sedeSlug} />
  <SmoothScrollIsland />
</SiteLayout>
