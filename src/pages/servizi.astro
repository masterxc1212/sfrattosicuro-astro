---
import SiteLayout from '../layouts/SiteLayout.astro';
import HeaderIsland from '../components/HeaderIsland.astro';
import Footer from '../components/Footer.astro';
import HeroInstitutionalIsland from '../components/HeroInstitutionalIsland.astro';
import CoverageSectionIsland from '../components/CoverageSectionIsland.astro';
import ContactFormIsland from '../components/ContactFormIsland.astro';
import SmoothScrollIsland from '../components/SmoothScrollIsland.astro';
import JsonLd from '../components/JsonLd.astro';
import ServicesIntroIsland from '../components/ServicesIntroIsland.astro';
import ServicesGridIsland from '../components/ServicesGridIsland.astro';
import ServicesDetailsIsland from '../components/ServicesDetailsIsland.astro';
import ServicesMethodIsland from '../components/ServicesMethodIsland.astro';
import PageJumpNavIsland from '../components/PageJumpNavIsland.astro';
import site from '../data/site.json';

const title = 'Servizi legali per sfratti e locazioni | Sfratto Sicuro';
const description = 'Scopri i servizi legali di Sfratto Sicuro per la gestione delle locazioni, le procedure di sfratto e il recupero dei canoni non pagati.';

const siteUrl = site.siteUrl.replace(/\/$/, '');
const org = site.organization;

const heroCarousel = [
  {
    image: '/assets/img/provvedimenti/01.webp',
    alt: 'Provvedimento di convalida sfratto per morosità',
    title: 'Convalida di sfratto per morosità',
    description: 'Provvedimento ottenuto presso il Tribunale di Napoli, con dati sensibili oscurati.'
  },
  {
    image: '/assets/img/provvedimenti/02.webp',
    alt: 'Provvedimento di convalida sfratto per morosità',
    title: 'Convalida di sfratto per finita locazione',
    description: 'Provvedimento ottenuto presso il Tribunale di Roma, documentazione anonimizzata.'
  },
  {
    image: '/assets/img/provvedimenti/03.webp',
    alt: 'Provvedimento di convalida sfratto per morosità',
    title: 'Ordinanza di rilascio immobile',
    description: 'Provvedimento ottenuto presso il Tribunale di Milano, con dati personali oscurati.'
  },
  {
    image: '/assets/img/provvedimenti/04.webp',
    alt: 'Provvedimento di convalida sfratto per morosità',
    title: 'Procedura di sfratto conclusa',
    description: 'Provvedimento emesso in materia di locazione, riportato in forma anonimizzata.'
  }
];

const servicesGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${siteUrl}/servizi/#webpage`,
      url: `${siteUrl}/servizi/`,
      name: title,
      description,
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}/#legalservice` }
    },
    {
      '@type': 'LegalService',
      '@id': `${siteUrl}/servizi/#service`,
      name: 'Servizi legali per sfratti e locazioni',
      provider: { '@id': `${siteUrl}/#organization` },
      areaServed: { '@type': 'Country', name: 'IT' },
      serviceType: [
        'Sfratto per morosità',
        'Sfratto per finita locazione',
        'Recupero canoni locazione',
        'Controversie locazione',
        'Predisposizione contratti di locazione'
      ],
      url: `${siteUrl}/servizi/`
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${siteUrl}/servizi/#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: `${siteUrl}/`
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Servizi',
          item: `${siteUrl}/servizi/`
        }
      ]
    }
  ]
};
---

<SiteLayout title={title} description={description} canonicalPath="/servizi/" image="/assets/img/provvedimenti/01.webp">
  <Fragment slot="head">
    <JsonLd graph={servicesGraph} />
  </Fragment>

  <HeaderIsland />
  <PageJumpNavIsland
    title="Percorso rapido"
    items={[
      { href: '#servizi-legali', label: 'Servizi' },
      { href: '#metodo-servizi', label: 'Metodo' },
      { href: '#contatti', label: 'Contatti' },
      { href: '/sedi/', label: 'Sedi territoriali' }
    ]}
  />

  <main id="main-content">
    <HeroInstitutionalIsland
      kicker="Servizi legali in diritto delle locazioni"
      h1="Servizi legali per sfratti e locazioni"
      subtitle="Offriamo assistenza legale ai proprietari di immobili nella gestione delle locazioni e nelle procedure di sfratto. Il servizio è strutturato per accompagnare il proprietario nella gestione del rapporto con l’inquilino, dalla predisposizione del contratto fino alle eventuali procedure di sfratto e al recupero dei canoni non pagati."
      bullets={[
        'Sfratto per morosità con assistenza completa fino al rilascio',
        'Sfratto per finita locazione e tutela del proprietario',
        'Recupero canoni locazione e gestione delle controversie locative'
      ]}
      trustRow={[
        'Approccio operativo su procedure di sfratto',
        'Metodo strutturato in diritto delle locazioni',
        'Assistenza su tutto il territorio nazionale'
      ]}
      primaryCtaLabel="Richiedi una consulenza"
      primaryCtaHref="#contatti"
      secondaryCtaLabel="Scopri i servizi"
      secondaryCtaHref="#servizi-legali"
      useCarousel={true}
      carouselItems={heroCarousel}
      bulletsLabel="Servizi legali principali"
    />

    <ServicesIntroIsland />
    <ServicesGridIsland />
    <ServicesDetailsIsland />
    <ServicesMethodIsland />
    <CoverageSectionIsland />

    <section class="section section--compact legal-note" aria-label="Dati societari e trasparenza">
      <div class="container legal-note-box">
        <h2>Trasparenza e dati societari</h2>
        <p>
          Il servizio è erogato da <strong>{org.legalName}</strong> ({org.name}), P. IVA {org.vatID.replace(/^IT/i, '')},
          con sede in {org.nationalAddress.streetAddress}, {org.nationalAddress.postalCode} {org.nationalAddress.addressLocality}.
          Per informazioni precontrattuali puoi scrivere a <a href={`mailto:${org.email}`}>{org.email}</a>
          o chiamare il <a href={`tel:${org.telephone.replace(/\s+/g, '')}`}>{org.telephone}</a>.
        </p>
      </div>
    </section>

    <ContactFormIsland
      title="Richiedi una consulenza"
      description="Se hai un immobile locato e stai affrontando problemi con il tuo inquilino, puoi richiedere una consulenza per valutare la procedura più adatta alla tua situazione."
    />
  </main>

  <Footer sedeSlug="nazionale" />
  <SmoothScrollIsland />
</SiteLayout>

<style>
  .legal-note-box {
    max-width: 1100px;
    margin: 0 auto;
    padding: 18px;
    border: 1px solid #d9e5f4;
    border-radius: 12px;
    background: linear-gradient(180deg, #f8fbff 0%, #eef4fd 100%);
  }

  .legal-note-box h2 {
    margin: 0 0 8px;
    color: var(--blue-navy);
    font-size: 1.1rem;
  }

  .legal-note-box p {
    margin: 0;
    color: #334155;
    line-height: 1.65;
  }

  .legal-note-box a { color: #1e3a8a; }
</style>
