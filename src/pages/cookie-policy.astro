---
import SiteLayout from '../layouts/SiteLayout.astro';
import HeaderIsland from '../components/HeaderIsland.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import PageJumpNavIsland from '../components/PageJumpNavIsland.astro';
import site from '../data/site.json';

const title = 'Cookie Policy | Sfratto Sicuro';
const description = 'Informazioni sull’uso dei cookie e strumenti di tracciamento sul sito Sfratto Sicuro.';

const cookieGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${site.siteUrl}/cookie-policy/#webpage`,
      url: `${site.siteUrl}/cookie-policy/`,
      name: title,
      description,
      inLanguage: 'it-IT',
      isPartOf: { '@id': `${site.siteUrl}/#website` }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${site.siteUrl}/cookie-policy/#breadcrumbs`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Cookie Policy', item: `${site.siteUrl}/cookie-policy/` }
      ]
    }
  ]
};
---

<SiteLayout title={title} description={description} canonicalPath="/cookie-policy/">
  <Fragment slot="head">
    <JsonLd graph={cookieGraph} />
  </Fragment>

  <HeaderIsland />
  <PageJumpNavIsland
    title="Sezioni cookie"
    items={[
      { href: '#definizione-cookie', label: 'Cosa sono' },
      { href: '#tipologie-cookie', label: 'Tipologie' },
      { href: '#consenso-cookie', label: 'Consenso' },
      { href: '#contatti-cookie', label: 'Contatti' }
    ]}
  />

  <main id="main-content" class="legal-main">
    <section class="legal-hero">
      <div class="container">
        <p class="kicker">Documentazione legale</p>
        <h1>Cookie Policy</h1>
        <p>Informazioni su cookie tecnici, analitici e strumenti di tracciamento.</p>
      </div>
    </section>

    <section class="container legal-body">
      <article class="card" id="definizione-cookie">
        <h2>1. Cosa sono i cookie</h2>
        <p>
          I cookie sono piccoli file di testo inviati al browser durante la navigazione e usati per
          migliorare l’esperienza utente, misurare le performance del sito e gestire preferenze.
        </p>
      </article>

      <article class="card" id="tipologie-cookie">
        <h2>2. Tipologie utilizzate</h2>
        <ul>
          <li><strong>Cookie tecnici:</strong> necessari al funzionamento del sito.</li>
          <li><strong>Cookie analitici:</strong> utili per statistiche aggregate sul traffico.</li>
          <li><strong>Cookie di profilazione/marketing:</strong> attivati solo con consenso, ove previsti.</li>
        </ul>
      </article>

      <article class="card" id="consenso-cookie">
        <h2>3. Gestione del consenso</h2>
        <p>
          Puoi modificare in qualsiasi momento le preferenze cookie tramite il browser e gli eventuali
          strumenti di gestione del consenso presenti sul sito.
        </p>
      </article>

      <article class="card" id="contatti-cookie">
        <h2>4. Contatti</h2>
        <p>
          Per chiarimenti sul trattamento dei dati e sull’uso dei cookie puoi contattarci a
          <a href={`mailto:${site.organization.email}`}>{site.organization.email}</a>.
        </p>
        <p class="last-update">Ultimo aggiornamento: marzo 2026</p>
      </article>
    </section>
  </main>

  <Footer sedeSlug="nazionale" />
</SiteLayout>

