---
import SiteLayout from '../layouts/SiteLayout.astro';
import HomeModel from '../components/HomeModel.astro';
import JsonLd from '../components/JsonLd.astro';
import site from '../data/site.json';
import { getNationalHomeSeo } from '../lib/home-model';

const seo = getNationalHomeSeo();
const { title, description } = seo;
const siteUrl = site.siteUrl.replace(/\/$/, '');

const faqItems = [
  {
    q: 'Quanto tempo serve per ottenere la convalida di sfratto?',
    a: 'Grazie a un protocollo interno di gestione della pratica e di ottimizzazione dei tempi di notifica, in molti casi puntiamo ad arrivare all’udienza per la convalida di sfratto in circa 60 giorni.'
  },
  {
    q: 'Quando si può avviare lo sfratto per morosità?',
    a: 'La procedura può essere avviata quando il conduttore non paga i canoni o gli oneri dovuti nei termini previsti dal contratto, con assistenza legale nella predisposizione dell’intimazione e nella successiva fase di convalida.'
  },
  {
    q: 'Cosa succede se l’inquilino si oppone allo sfratto?',
    a: 'Se l’inquilino propone opposizione, la procedura può richiedere attività ulteriori e tempi più lunghi. In questi casi è necessario valutare subito la strategia processuale più adatta per tutelare il proprietario.'
  },
  {
    q: 'Che cos’è il termine di grazia nello sfratto per morosità?',
    a: 'Nel procedimento per sfratto per morosità il giudice può, in presenza dei presupposti di legge, concedere un termine per sanare la morosità. Si tratta di una variabile che può incidere sui tempi della procedura e che va valutata caso per caso.'
  }
];

const faqEntities = faqItems.map((item) => ({
  '@type': 'Question',
  name: item.q,
  acceptedAnswer: {
    '@type': 'Answer',
    text: item.a
  }
}));

const org = site.organization;
const mapUrl = org.sameAs?.[0] || '';

const homeGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: `${siteUrl}/`,
      name: org.name,
      publisher: { '@id': `${siteUrl}/#organization` }
    },
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: org.name,
      legalName: org.legalName,
      url: `${siteUrl}/`,
      logo: {
        '@type': 'ImageObject',
        url: org.logoUrl
      },
      email: org.email,
      telephone: org.telephone,
      vatID: org.vatID,
      address: {
        '@type': 'PostalAddress',
        ...org.nationalAddress
      },
      contactPoint: [
        {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          telephone: org.telephone,
          email: org.email,
          availableLanguage: ['it']
        },
        {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          url: org.whatsappUrl,
          availableLanguage: ['it']
        }
      ],
      sameAs: org.sameAs || []
    },
    {
      '@type': 'LegalService',
      '@id': `${siteUrl}/#legalservice`,
      name: org.name,
      url: `${siteUrl}/`,
      telephone: org.telephone,
      email: org.email,
      address: {
        '@type': 'PostalAddress',
        ...org.nationalAddress
      },
      areaServed: [
        { '@type': 'Country', name: 'IT' },
        { '@type': 'AdministrativeArea', name: org.nationalAddress.addressRegion },
        { '@type': 'City', name: org.nationalAddress.addressLocality }
      ],
      serviceType: ['Sfratto per morosità', 'Sfratto per finita locazione'],
      openingHoursSpecification: org.openingHoursSpecification,
      provider: { '@id': `${siteUrl}/#organization` },
      ...(mapUrl ? { hasMap: mapUrl } : {})
    },
    {
      '@type': 'WebPage',
      '@id': `${siteUrl}/#webpage`,
      url: `${siteUrl}/`,
      name: title,
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}/#legalservice` }
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteUrl}/#faq`,
      mainEntity: faqEntities
    }
  ]
};
---

<SiteLayout title={title} description={description} canonicalPath={seo.canonicalPath} image="/og-home.jpg">
  <!-- cache-bust: 2026-03-21-1318 -->
  <Fragment slot="head">
    <JsonLd graph={homeGraph} />
  </Fragment>

  <HomeModel
    sedeSlug="nazionale"
    jumpTitle="Percorso rapido"
    jumpItems={[
      { href: '#procedura-sfratto', label: 'Procedura' },
      { href: '#faq-sfratto', label: 'FAQ' },
      { href: '#contatti', label: 'Contatti' },
      { href: '/sedi/', label: 'Sedi territoriali' }
    ]}
    showDoveOperiamo={true}
    showBlogLatest={true}
    showVideoReviews={false}
    faqItems={faqItems}
  />
</SiteLayout>
