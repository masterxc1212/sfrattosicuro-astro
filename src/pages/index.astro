---
import SiteLayout from '../layouts/SiteLayout.astro';
import HomeModel from '../components/HomeModel.astro';
import JsonLd from '../components/JsonLd.astro';
import site from '../data/site.json';
import { getNationalHomeSeo } from '../lib/home-model';

const seo = getNationalHomeSeo();
const { title, description } = seo;
const siteUrl = site.siteUrl.replace(/\/$/, '');

const faqEntities = [
  {
    '@type': 'Question',
    name: 'Quanto tempo serve per sfrattare un inquilino?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'La durata dipende dal tribunale competente e dall’eventuale opposizione dell’inquilino.'
    }
  },
  {
    '@type': 'Question',
    name: 'Quanti mesi di affitto non pagato servono per lo sfratto?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'In genere è possibile avviare la procedura quando l’inquilino non paga il canone nei termini previsti dal contratto.'
    }
  },
  {
    '@type': 'Question',
    name: 'È possibile sfrattare un inquilino con figli minori?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'La presenza di minori non impedisce la procedura di sfratto ma può incidere sui tempi dell’esecuzione.'
    }
  }
];

const org = site.organization;
const mapUrl = org.sameAs?.[0] || '';

const homeGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: `${siteUrl}/`,
      name: org.name,
      publisher: { '@id': `${siteUrl}/#organization` }
    },
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: org.name,
      legalName: org.legalName,
      url: `${siteUrl}/`,
      logo: {
        '@type': 'ImageObject',
        url: org.logoUrl
      },
      email: org.email,
      telephone: org.telephone,
      vatID: org.vatID,
      address: {
        '@type': 'PostalAddress',
        ...org.nationalAddress
      },
      contactPoint: [
        {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          telephone: org.telephone,
          email: org.email,
          availableLanguage: ['it']
        },
        {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          url: org.whatsappUrl,
          availableLanguage: ['it']
        }
      ],
      sameAs: org.sameAs || []
    },
    {
      '@type': 'LegalService',
      '@id': `${siteUrl}/#legalservice`,
      name: org.name,
      url: `${siteUrl}/`,
      areaServed: [
        { '@type': 'Country', name: 'IT' },
        { '@type': 'AdministrativeArea', name: org.nationalAddress.addressRegion },
        { '@type': 'City', name: org.nationalAddress.addressLocality }
      ],
      serviceType: ['Sfratto per morosità', 'Sfratto per finita locazione'],
      provider: { '@id': `${siteUrl}/#organization` },
      ...(mapUrl ? { hasMap: mapUrl } : {})
    },
    {
      '@type': 'WebPage',
      '@id': `${siteUrl}/#webpage`,
      url: `${siteUrl}/`,
      name: title,
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}/#legalservice` }
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteUrl}/#faq`,
      mainEntity: faqEntities
    }
  ]
};
---

<SiteLayout title={title} description={description} canonicalPath={seo.canonicalPath} image="/og-home.jpg">
  <Fragment slot="head">
    <JsonLd graph={homeGraph} />
  </Fragment>

  <HomeModel
    sedeSlug="nazionale"
    jumpTitle="Percorso rapido"
    jumpItems={[
      { href: '#procedura-sfratto', label: 'Procedura' },
      { href: '#faq-sfratto', label: 'FAQ' },
      { href: '#contatti', label: 'Contatti' },
      { href: '/sedi/', label: 'Sedi territoriali' }
    ]}
    showDoveOperiamo={true}
    showBlogLatest={true}
    showVideoReviews={false}
  />
</SiteLayout>
