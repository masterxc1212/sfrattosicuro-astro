---
/**
 * /landing-v2/ ГѓВўГўвЂљВ¬Гўв‚¬Вќ 1:1 faithful clone of public/landing/index.html
 * Built from modular Astro components.
 * Every section, every copy block, every CTA matches the original exactly.
 *
 * This version uses a dedicated CSS file (landing.css) for styling
 * and is self-contained without relying on SiteLayout.astro.
 */
import '../../styles/landing.css';
import { buildLandingPageConfig } from '../../data/landing-v2';
import { versionedSrc } from '../../lib/asset-version';
import CookieConsentBanner from '../../components/CookieConsentBanner.astro';
import GA4TrackingIsland from '../../components/GA4TrackingIsland.astro';

// Section components ГѓВўГўвЂљВ¬Гўв‚¬Вќ 1:1 clones of original landing sections
import LandingOriginalHeaderSection from '../../components/landing/LandingOriginalHeaderSection.astro';
import LandingOriginalTrustBarSection from '../../components/landing/LandingOriginalTrustBarSection.astro';
import LandingOriginalHeroSection from '../../components/landing/LandingOriginalHeroSection.astro';
import LandingOriginalProblemsSection from '../../components/landing/LandingOriginalProblemsSection.astro';
import LandingOriginalCalculatorSection from '../../components/landing/LandingOriginalCalculatorSection.astro';
import LandingOriginalReviewsSection from '../../components/landing/LandingOriginalReviewsSection.astro';
import LandingOriginalVideoReviewsSection from '../../components/landing/LandingOriginalVideoReviewsSection.astro';
import LandingOriginalProvvedimentiSection from '../../components/landing/LandingOriginalProvvedimentiSection.astro';
import LandingOriginalUrgencySection from '../../components/landing/LandingOriginalUrgencySection.astro';
import LandingOriginalLegalCostSection from '../../components/landing/LandingOriginalLegalCostSection.astro';
import LandingOriginalProcedureSection from '../../components/landing/LandingOriginalProcedureSection.astro';
import LandingOriginalPricingSection from '../../components/landing/LandingOriginalPricingSection.astro';
import LandingOriginalCostTransparencySection from '../../components/landing/LandingOriginalCostTransparencySection.astro';
import LandingOriginalWhoWeAreSection from '../../components/landing/LandingOriginalWhoWeAreSection.astro';
import LandingOriginalWhyChooseSection from '../../components/landing/LandingOriginalWhyChooseSection.astro';
import LandingOriginalFaqSection from '../../components/landing/LandingOriginalFaqSection.astro';
import LandingOriginalMiniWidgetSection from '../../components/landing/LandingOriginalMiniWidgetSection.astro';
import LandingOriginalContactFormSection from '../../components/landing/LandingOriginalContactFormSection.astro';
import LandingOriginalFooterSection from '../../components/landing/LandingOriginalFooterSection.astro';

const config = buildLandingPageConfig({
  version: 'v2',
  territory: 'nazionale',
  keyword: 'sfratto-per-morosita',
});
---
<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Favicons & Manifest -->
    <link rel="icon" type="image/png" href="/assets/icons/favicon-96x96.png" sizes="96x96">
    <link rel="shortcut icon" href="/assets/icons/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/icons/apple-touch-icon.png">
    <meta name="apple-mobile-web-app-title" content="Sfratto">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#1B2951">

    <!-- Title & Meta -->
    <title>{config.seo.title}</title>
    <meta name="description" content={config.seo.description}>
    <meta name="keywords" content={config.seo.keywords}>
    <meta name="robots" content={config.seo.robots}>
    <meta name="author" content="SfrattoSicuro.it">
    <link rel="canonical" href={config.seo.canonicalUrl}>

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:title" content={config.seo.ogTitle}>
    <meta property="og:description" content={config.seo.ogDescription}>
    <meta property="og:url" content={config.seo.ogUrl}>
    <meta property="og:site_name" content="SfrattoSicuro.it">
    <meta property="og:locale" content="it_IT">
    <meta property="og:image" content="https://www.sfrattosicuro.it/assets/img/hero.webp">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={config.seo.twitterTitle}>
    <meta name="twitter:description" content={config.seo.twitterDescription}>
    <meta name="twitter:image" content="https://www.sfrattosicuro.it/assets/img/hero.webp">

    <!-- Preconnect & DNS-prefetch -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="//www.google-analytics.com">
    <link rel="dns-prefetch" href="//i.ytimg.com">
    <link rel="dns-prefetch" href="//www.youtube-nocookie.com">

    <!-- Google Fonts Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(config.jsonLd.legalService)} />
    <script type="application/ld+json" set:html={JSON.stringify(config.jsonLd.organization)} />
    <script type="application/ld+json" set:html={JSON.stringify(config.jsonLd.website)} />
    <script type="application/ld+json" set:html={JSON.stringify(config.jsonLd.faq)} />

    <!-- GTM noscript -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KFR8V7BD" height="0" width="0" style="display:none;visibility:hidden" loading="lazy"></iframe></noscript>

    <!-- Tracking script aligned with cookie consent used by home/sedi -->
    <script>
      (function(){
        const CONSENT_KEY = 'ss_cookie_consent_v1';
        const AW_ID = 'AW-10983419342';

        function getParam(name){
          const params = new URLSearchParams(window.location.search);
          return params.get(name) || '';
        }

        function captureTrackingParams(){
          const gclid = getParam('gclid');
          const utmSource = getParam('utm_source');
          const utmMedium = getParam('utm_medium');
          const utmCampaign = getParam('utm_campaign');
          const utmTerm = getParam('utm_term');
          const utmContent = getParam('utm_content');
          const keyword = getParam('keyword');
          document.querySelectorAll('form[action="/php/invia-email.php"]').forEach(function(f){
            var set = function(n, v){
              var i = f.querySelector('[name="'+n+'"]');
              if(i) i.value = v;
            };
            set('gclid', gclid);
            set('utm_source', utmSource);
            set('utm_medium', utmMedium);
            set('utm_campaign', utmCampaign);
            set('utm_term', utmTerm);
            set('utm_content', utmContent);
            set('keyword', keyword);
          });
        }

        function readConsent(){
          try {
            const raw = localStorage.getItem(CONSENT_KEY);
            return raw ? JSON.parse(raw) : null;
          } catch {
            return null;
          }
        }

        function initAdsIfNeeded(consent){
          if (!consent?.marketing) return;
          if (window.__landingAdsLoaded) {
            if (typeof window.gtag === 'function') {
              window.gtag('consent', 'update', {
                ad_storage: 'granted',
                ad_user_data: 'granted',
                ad_personalization: 'granted'
              });
            }
            return;
          }

          window.__landingAdsLoaded = true;
          window.dataLayer = window.dataLayer || [];
          function gtag(){ window.dataLayer.push(arguments); }
          window.gtag = window.gtag || gtag;
          window.gtag('consent', 'default', {
            ad_storage: 'granted',
            ad_user_data: 'granted',
            ad_personalization: 'granted'
          });
          window.gtag('js', new Date());
          window.gtag('config', AW_ID, { send_page_view: false, transport_type: 'beacon' });

          if (!document.querySelector('script[data-landing-aw="' + AW_ID + '"]')) {
            var s = document.createElement('script');
            s.async = true;
            s.src = 'https://www.googletagmanager.com/gtag/js?id=' + AW_ID;
            s.setAttribute('data-landing-aw', AW_ID);
            document.head.appendChild(s);
          }
        }

        // Applica al DOM quando ГЁ pronto (la call diretta ГЁ in <head>, form non ancora nel DOM)
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', captureTrackingParams, { once: true });
        } else {
          captureTrackingParams();
        }
        // Belt-and-suspenders: ri-applica al submit (copre form dinamici)
        document.addEventListener('submit', function(ev) {
          if (ev.target && ev.target.matches && ev.target.matches('form[action="/php/invia-email.php"]')) {
            captureTrackingParams();
          }
        }, true);
        const consent = readConsent();
        if (consent?.marketing) initAdsIfNeeded(consent);
        window.addEventListener('ss:cookie-consent-updated', function(event){
          const detail = event?.detail || {};
          if (detail.marketing) initAdsIfNeeded(detail);
        });
      })();
    </script>

    <!-- Lazy load images -->
    <script>
      (function(){
        var setLazy = function(){
          document.querySelectorAll('img:not([fetchpriority="high"]):not([loading])').forEach(function(i){ i.loading = 'lazy'; });
        };
        if(document.readyState === 'loading'){
          document.addEventListener('DOMContentLoaded', setLazy, { once: true });
        } else {
          setLazy();
        }
      })();
    </script>
    <script src="/js/gclid-capture.js" defer></script>
  </head>
  <body>
    <LandingOriginalHeaderSection />

    <main id="main-content" style="min-height:100vh; margin-top: var(--header-h, 90px);">

      <!-- 3. Hero with form -->
      <LandingOriginalHeroSection hero={config.hero} />

      <!-- 2. Trust bar -->
      <LandingOriginalTrustBarSection trustBar={config.trustBar} />

      <!-- 4. Problem situations -->
      <LandingOriginalProblemsSection problemsSection={config.problems} />

      <!-- 5. Cost calculator -->
      <LandingOriginalCalculatorSection calculator={config.calculator} />

      <!-- 6. Google Reviews -->
      <LandingOriginalReviewsSection />

      <!-- 7. Video Reviews -->
      <LandingOriginalVideoReviewsSection />

      <!-- 8. Provvedimenti -->
      <LandingOriginalProvvedimentiSection />

      <!-- 9. Posti Limitati -->
      <LandingOriginalUrgencySection />

      <!-- 10. Rimborso Spese -->
      <LandingOriginalLegalCostSection legalCost={config.legalCost} />

      <!-- 11. Procedure -->
      <LandingOriginalProcedureSection procedure={config.procedure} />

      <!-- 12. Services / Pricing -->
      <LandingOriginalPricingSection services={config.services} />

      <!-- 13. Cost Transparency -->
      <LandingOriginalCostTransparencySection costTransparency={config.costTransparency} />

      <!-- 14. Chi Siamo -->
      <LandingOriginalWhoWeAreSection whoWeAre={config.whoWeAre} />

      <!-- 15. PerchГѓЖ’Г‚В© Sceglierci -->
      <LandingOriginalWhyChooseSection whyChooseUs={config.whyChooseUs} />

      <!-- 16. FAQ -->
      <LandingOriginalFaqSection faqSection={config.faq} />

      <!-- 17. Mini Widget Rating -->
      <LandingOriginalMiniWidgetSection />

      <!-- 18. Contact Form -->
      <LandingOriginalContactFormSection contactForm={config.contactForm} />

    </main>

    <!-- 19. Footer -->
    <LandingOriginalFooterSection />
    <CookieConsentBanner />
    <GA4TrackingIsland measurementId="G-509YE5HCYB" />

    <!-- External script deps (same as original + form handling/tracking) -->
    <script src={versionedSrc('/assets/js/calculator.js')} defer></script>
    <script src={versionedSrc('/assets/js/reviews.js')} defer></script>
    <script src={versionedSrc('/assets/js/videos.js')} defer></script>
    <script src={versionedSrc('/assets/js/form-validation.js')} defer></script>
    <script src={versionedSrc('/assets/js/main.js')} defer></script>
  </body>
</html>