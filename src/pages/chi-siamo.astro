---
import SiteLayout from '../layouts/SiteLayout.astro';
import HeaderIsland from '../components/HeaderIsland.astro';
import Footer from '../components/Footer.astro';
import ContactFormIsland from '../components/ContactFormIsland.astro';
import SmoothScrollIsland from '../components/SmoothScrollIsland.astro';
import JsonLd from '../components/JsonLd.astro';
import ChiSiamoHeroIsland from '../components/ChiSiamoHeroIsland.astro';
import ChiSiamoIntroIsland from '../components/ChiSiamoIntroIsland.astro';
import FounderSectionIsland from '../components/FounderSectionIsland.astro';
import MethodSectionIsland from '../components/MethodSectionIsland.astro';
import NetworkSectionIsland from '../components/NetworkSectionIsland.astro';
import CoverageSectionIsland from '../components/CoverageSectionIsland.astro';
import PageJumpNavIsland from '../components/PageJumpNavIsland.astro';
import site from '../data/site.json';

const title = 'Studio legale sfratti e locazioni | Sfratto Sicuro';
const description = 'Sfratto Sicuro è uno studio legale specializzato in sfratti e locazioni. Assistenza ai proprietari nelle procedure di sfratto per morosità e finita locazione.';
const siteUrl = site.siteUrl.replace(/\/$/, '');
const org = site.organization;

const chiSiamoGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: `${siteUrl}/`,
      name: org.name,
      publisher: { '@id': `${siteUrl}/#organization` }
    },
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: org.name,
      legalName: org.legalName,
      url: `${siteUrl}/`,
      logo: {
        '@type': 'ImageObject',
        url: org.logoUrl
      }
    },
    {
      '@type': 'WebPage',
      '@id': `${siteUrl}/chi-siamo/#webpage`,
      url: `${siteUrl}/chi-siamo/`,
      name: title,
      description,
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}/#organization` }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${siteUrl}/chi-siamo/#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: `${siteUrl}/`
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Chi siamo',
          item: `${siteUrl}/chi-siamo/`
        }
      ]
    },
    {
      '@type': 'Person',
      '@id': 'https://www.daniloansalone.it/#person',
      name: 'Danilo Ansalone',
      jobTitle: 'Avvocato',
      url: 'https://www.daniloansalone.it',
      worksFor: {
        '@type': 'Organization',
        name: org.name,
        url: `${siteUrl}/`
      }
    }
  ]
};
---

<SiteLayout
  title={title}
  description={description}
  canonicalPath="/chi-siamo/"
  image="/assets/img/ufficio/hero_chi_siamo.webp"
>
  <Fragment slot="head">
    <JsonLd graph={chiSiamoGraph} />
  </Fragment>

  <HeaderIsland />
  <PageJumpNavIsland
    title="Percorso rapido"
    items={[
      { href: '/servizi/', label: 'Servizi' },
      { href: '/sedi/', label: 'Sedi territoriali' },
      { href: '#contatti', label: 'Contatti' }
    ]}
  />

  <main id="main-content">
    <ChiSiamoHeroIsland />
    <ChiSiamoIntroIsland />
    <FounderSectionIsland />
    <MethodSectionIsland />
    <NetworkSectionIsland />
    <CoverageSectionIsland />

    <ContactFormIsland
      title="Richiedi una consulenza"
      description="Se hai un immobile locato e stai affrontando problemi con il tuo inquilino, puoi richiedere una consulenza per valutare la procedura più adatta alla tua situazione."
    />
  </main>

  <Footer sedeSlug="nazionale" />
  <SmoothScrollIsland />
</SiteLayout>
