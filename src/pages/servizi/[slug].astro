---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HeaderIsland from '../../components/HeaderIsland.astro';
import Footer from '../../components/Footer.astro';
import ContactFormIsland from '../../components/ContactFormIsland.astro';
import SmoothScrollIsland from '../../components/SmoothScrollIsland.astro';
import PageJumpNavIsland from '../../components/PageJumpNavIsland.astro';
import JsonLd from '../../components/JsonLd.astro';
import site from '../../data/site.json';
import { servicePages, type ServicePage } from '../../data/service-pages';

export function getStaticPaths() {
  return servicePages.map((service) => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props as { service: ServicePage };
const siteUrl = site.siteUrl.replace(/\/$/, '');
const canonicalPath = `/servizi/${service.slug}/`;

const related = servicePages.filter((item) => item.slug !== service.slug).slice(0, 4);

const faqEntities = service.faqs.map((item) => ({
  '@type': 'Question',
  name: item.q,
  acceptedAnswer: {
    '@type': 'Answer',
    text: item.a
  }
}));

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${siteUrl}${canonicalPath}#webpage`,
      url: `${siteUrl}${canonicalPath}`,
      name: service.title,
      description: service.metaDescription,
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}${canonicalPath}#service` },
      inLanguage: 'it-IT'
    },
    {
      '@type': 'Service',
      '@id': `${siteUrl}${canonicalPath}#service`,
      serviceType: service.shortTitle,
      name: service.shortTitle,
      provider: { '@id': `${siteUrl}/#organization` },
      areaServed: { '@type': 'Country', name: 'IT' },
      url: `${siteUrl}${canonicalPath}`
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteUrl}${canonicalPath}#faq`,
      mainEntity: faqEntities
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${siteUrl}${canonicalPath}#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: `${siteUrl}/`
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Servizi',
          item: `${siteUrl}/servizi/`
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: service.shortTitle,
          item: `${siteUrl}${canonicalPath}`
        }
      ]
    }
  ]
};
---

<SiteLayout
  title={service.title}
  description={service.metaDescription}
  canonicalPath={canonicalPath}
  image="/assets/img/provvedimenti/02.webp"
>
  <Fragment slot="head">
    <JsonLd graph={graph} />
  </Fragment>

  <HeaderIsland />
  <PageJumpNavIsland
    title="Percorso rapido"
    items={[
      { href: '#quando-serve', label: 'Quando serve' },
      { href: '#cosa-include', label: 'Cosa include' },
      { href: '#faq-servizio', label: 'FAQ' },
      { href: '#contatti', label: 'Contatti' }
    ]}
  />

  <main id="main-content">
    <section class="service-hero section" aria-labelledby="service-title">
      <div class="container hero-grid">
        <div>
          <p class="kicker">Servizi legali in diritto delle locazioni</p>
          <h1 id="service-title">{service.h1}</h1>
          <p class="lead">{service.intro}</p>

          <div class="keyword-meta" aria-label="focus keyword">
            <span>Keyword principale:</span>
            <strong>{service.primaryKeyword}</strong>
          </div>

          <div class="cta-row">
            <a class="btn btn-primary" href="#contatti">Richiedi una consulenza</a>
            <a class="btn btn-secondary" href="/servizi/">Torna a tutti i servizi</a>
          </div>
        </div>

        <aside class="hero-box" aria-label="keyword correlate">
          <h2>Ricerche correlate utili</h2>
          <ul>
            {service.secondaryKeywords.map((kw) => (
              <li>{kw}</li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section id="quando-serve" class="section section-light" aria-labelledby="when-title">
      <div class="container narrow">
        <h2 id="when-title">Quando è utile questo servizio</h2>
        <ul class="check-list">
          {service.whenToUse.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section id="cosa-include" class="section" aria-labelledby="include-title">
      <div class="container narrow">
        <h2 id="include-title">Cosa include l’assistenza</h2>
        <ul class="check-list">
          {service.includes.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section id="faq-servizio" class="section section-light" aria-labelledby="faq-title">
      <div class="container narrow">
        <h2 id="faq-title">FAQ sul servizio</h2>
        <div class="faq-list">
          {service.faqs.map((faq) => (
            <details>
              <summary>{faq.q}</summary>
              <p>{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="related-title">
      <div class="container narrow">
        <h2 id="related-title">Servizi correlati</h2>
        <div class="related-grid">
          {related.map((item) => (
            <a href={`/servizi/${item.slug}/`} class="related-card">
              <h3>{item.shortTitle}</h3>
              <p>{item.metaDescription}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <ContactFormIsland
      title={`Richiedi una consulenza su ${service.shortTitle.toLowerCase()}`}
      description="Analizziamo il caso e definiamo il percorso legale più adatto alla tua situazione locativa."
    />
  </main>

  <Footer sedeSlug="nazionale" />
  <SmoothScrollIsland />
</SiteLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .narrow { max-width: 980px; }

  .service-hero {
    background: linear-gradient(180deg, #f8fbff 0%, #eef4fd 100%);
    border-bottom: 1px solid #e2e8f0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr .8fr;
    gap: 20px;
    align-items: start;
  }

  .kicker {
    margin: 0 0 10px;
    color: #c6902a;
    text-transform: uppercase;
    letter-spacing: .05em;
    font-size: .78rem;
    font-weight: 700;
  }

  h1 {
    margin: 0 0 12px;
    color: var(--blue-navy);
    font-size: clamp(1.7rem, 2.8vw, 2.45rem);
    line-height: 1.2;
  }

  h2 {
    margin: 0 0 14px;
    color: var(--blue-navy);
  }

  .lead {
    margin: 0;
    color: #334155;
    line-height: 1.72;
    font-size: 1.05rem;
  }

  .keyword-meta {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid #d7e3f3;
    background: #fff;
    color: #334155;
    font-size: .92rem;
  }

  .cta-row {
    margin-top: 18px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 10px 16px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
  }

  .btn-primary {
    background: var(--green-security);
    color: #fff;
  }

  .btn-secondary {
    background: #fff;
    border: 1px solid #d1d5db;
    color: var(--blue-navy);
  }

  .hero-box {
    border: 1px solid #d9e5f4;
    border-radius: 12px;
    background: #fff;
    padding: 16px;
  }

  .hero-box h2 {
    font-size: 1.02rem;
    margin-bottom: 10px;
  }

  .hero-box ul {
    margin: 0;
    padding-left: 18px;
    color: #334155;
    line-height: 1.7;
  }

  .section-light {
    background: #f8fafc;
    border-top: 1px solid #edf2f7;
    border-bottom: 1px solid #edf2f7;
  }

  .check-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 10px;
  }

  .check-list li {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 12px 14px;
    color: #334155;
    line-height: 1.6;
  }

  .faq-list {
    display: grid;
    gap: 10px;
  }

  .faq-list details {
    border: 1px solid #d9e5f4;
    border-radius: 10px;
    background: #fff;
    padding: 12px 14px;
  }

  .faq-list summary {
    cursor: pointer;
    font-weight: 700;
    color: var(--blue-navy);
  }

  .faq-list p {
    margin: 10px 0 0;
    color: #334155;
    line-height: 1.7;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .related-card {
    display: block;
    text-decoration: none;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #fff;
    padding: 14px;
  }

  .related-card h3 {
    margin: 0 0 6px;
    color: var(--blue-navy);
    font-size: 1.02rem;
  }

  .related-card p {
    margin: 0;
    color: #475569;
    line-height: 1.55;
    font-size: .94rem;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .container { padding: 0 16px; }
    .cta-row { display: grid; grid-template-columns: 1fr; }
    .btn { width: 100%; }
  }
</style>
