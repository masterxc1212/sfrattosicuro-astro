---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HeaderIsland from '../../components/HeaderIsland.astro';
import Footer from '../../components/Footer.astro';
import ContactFormIsland from '../../components/ContactFormIsland.astro';
import SmoothScrollIsland from '../../components/SmoothScrollIsland.astro';
import PageJumpNavIsland from '../../components/PageJumpNavIsland.astro';
import JsonLd from '../../components/JsonLd.astro';
import site from '../../data/site.json';
import { servicePages, type ServicePage } from '../../data/service-pages';

export function getStaticPaths() {
  return servicePages.map((service) => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props as { service: ServicePage };
const siteUrl = site.siteUrl.replace(/\/$/, '');
const canonicalPath = `/servizi/${service.slug}/`;

const related = servicePages.filter((item) => item.slug !== service.slug).slice(0, 4);

const faqEntities = service.faqs.map((item) => ({
  '@type': 'Question',
  name: item.q,
  acceptedAnswer: {
    '@type': 'Answer',
    text: item.a
  }
}));

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${siteUrl}${canonicalPath}#webpage`,
      url: `${siteUrl}${canonicalPath}`,
      name: service.title,
      description: service.metaDescription,
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}${canonicalPath}#service` },
      inLanguage: 'it-IT'
    },
    {
      '@type': 'Service',
      '@id': `${siteUrl}${canonicalPath}#service`,
      serviceType: service.shortTitle,
      name: service.shortTitle,
      provider: { '@id': `${siteUrl}/#organization` },
      areaServed: { '@type': 'Country', name: 'IT' },
      url: `${siteUrl}${canonicalPath}`
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteUrl}${canonicalPath}#faq`,
      mainEntity: faqEntities
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${siteUrl}${canonicalPath}#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: `${siteUrl}/`
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Servizi',
          item: `${siteUrl}/servizi/`
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: service.shortTitle,
          item: `${siteUrl}${canonicalPath}`
        }
      ]
    }
  ]
};
---

<SiteLayout
  title={service.title}
  description={service.metaDescription}
  canonicalPath={canonicalPath}
  image="/assets/img/provvedimenti/02.webp"
>
  <Fragment slot="head">
    <JsonLd graph={graph} />
  </Fragment>

  <HeaderIsland />
  <PageJumpNavIsland
    title="Percorso rapido"
    items={[
      { href: '#quando-serve', label: 'Quando serve' },
      { href: '#procedura', label: 'Procedura' },
      { href: '#caso-pratico', label: 'Caso pratico' },
      { href: '#costi-tempi', label: 'Costi e tempi' },
      { href: '#faq-servizio', label: 'FAQ' },
      { href: '#contatti', label: 'Contatti' }
    ]}
  />

  <main id="main-content">
    <section class="service-hero section" aria-labelledby="service-title">
      <div class="container narrow">
        <p class="kicker">Servizi legali in diritto delle locazioni</p>
        <h1 id="service-title">{service.h1}</h1>
        <p class="lead">{service.intro}</p>

        <div class="cta-row">
          <a class="btn btn-primary" href="#contatti">Richiedi una consulenza</a>
          <a class="btn btn-secondary" href="/servizi/">Torna a tutti i servizi</a>
        </div>
      </div>
    </section>

    <section class="section section-light" aria-labelledby="link-servizi-title">
      <div class="container narrow">
        <div class="service-links-box">
          <h2 id="link-servizi-title">Servizi principali collegati</h2>
          <div class="service-links-grid">
            <a href="/servizi/sfratto-per-morosita/">Sfratto per morosità</a>
            <a href="/servizi/sfratto-per-finita-locazione/">Sfratto per finita locazione</a>
            <a href="/servizi/recupero-canoni-non-pagati/">Recupero canoni non pagati</a>
            <a href="/servizi/tutela-proprietario/">Tutela continuativa del proprietario</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="overview-title">
      <div class="container narrow prose">
        <h2 id="overview-title">Come funziona questo servizio</h2>
        {service.overview.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </section>

    <section id="quando-serve" class="section section-light" aria-labelledby="when-title">
      <div class="container narrow">
        <h2 id="when-title">Quando è utile questo servizio</h2>
        <ul class="check-list">
          {service.whenToUse.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section id="procedura" class="section" aria-labelledby="procedura-title">
      <div class="container narrow">
        <h2 id="procedura-title">Come si sviluppa la procedura</h2>
        <div class="step-list">
          {service.procedureSteps.map((step) => (
            <article class="step-card">
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-light" aria-labelledby="documenti-title">
      <div class="container narrow">
        <h2 id="documenti-title">Documenti utili per partire</h2>
        <ul class="check-list">
          {service.documents.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section id="cosa-include" class="section" aria-labelledby="include-title">
      <div class="container narrow">
        <h2 id="include-title">Cosa include l’assistenza</h2>
        <ul class="check-list">
          {service.includes.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section id="caso-pratico" class="section section-light" aria-labelledby="case-title">
      <div class="container narrow">
        <h2 id="case-title">Esempio di caso trattato</h2>
        <article class="case-card">
          <h3>{service.caseExample.title}</h3>
          <p><strong>Scenario:</strong> {service.caseExample.scenario}</p>
          <p><strong>Attività svolta:</strong> {service.caseExample.activity}</p>
          <p><strong>Esito:</strong> {service.caseExample.outcome}</p>
        </article>
      </div>
    </section>

    <section id="costi-tempi" class="section" aria-labelledby="costi-tempi-title">
      <div class="container narrow">
        <h2 id="costi-tempi-title">Investimento e tempi operativi</h2>
        <p class="pricing-intro">
          L’obiettivo è ridurre la perdita economica del proprietario con una gestione legale strutturata:
          in molte situazioni, il costo dell’attesa può essere superiore al costo dell’intervento.
        </p>
        <div class="pricing-box">
          <ul class="check-list">
            <li><strong>{service.pricing.fee}</strong></li>
            <li><strong>{service.pricing.payment}</strong></li>
            <li><strong>{service.pricing.timing}</strong></li>
          </ul>
          <p class="pricing-note">{service.pricing.note}</p>
        </div>
      </div>
    </section>

    <section id="faq-servizio" class="section section-light" aria-labelledby="faq-title">
      <div class="container narrow">
        <h2 id="faq-title">FAQ sul servizio</h2>
        <div class="faq-list">
          {service.faqs.map((faq) => (
            <details>
              <summary>{faq.q}</summary>
              <p>{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="related-title">
      <div class="container narrow">
        <h2 id="related-title">Servizi correlati</h2>
        <div class="related-grid">
          {related.map((item) => (
            <a href={`/servizi/${item.slug}/`} class="related-card">
              <h3>{item.shortTitle}</h3>
              <p>{item.metaDescription}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <ContactFormIsland
      title={`Richiedi una consulenza su ${service.shortTitle.toLowerCase()}`}
      description="Analizziamo il caso e definiamo il percorso legale più adatto alla tua situazione locativa."
    />
  </main>

  <Footer sedeSlug="nazionale" />
  <SmoothScrollIsland />
</SiteLayout>

<style>
  .narrow { max-width: 980px; }

  .service-hero {
    background: linear-gradient(180deg, #f8fbff 0%, #eef4fd 100%);
    border-bottom: 1px solid #e2e8f0;
  }

  .kicker {
    margin: 0 0 10px;
    color: var(--kicker-gold);
    text-transform: uppercase;
    letter-spacing: .05em;
    font-size: .78rem;
    font-weight: 700;
  }

  h1 {
    margin: 0 0 12px;
    color: var(--blue-navy);
    font-size: clamp(1.7rem, 2.8vw, 2.45rem);
    line-height: 1.2;
  }

  h2 {
    margin: 0 0 14px;
    color: var(--blue-navy);
  }

  .lead {
    margin: 0;
    color: var(--text-body);
    line-height: 1.72;
    font-size: 1.05rem;
  }

  .prose p {
    margin: 0 0 10px;
    color: var(--text-body);
    line-height: 1.75;
  }

  .service-links-box {
    border: 1px solid #d9e5f4;
    border-radius: 12px;
    background: #fff;
    padding: 16px;
  }

  .service-links-box h2 {
    font-size: 1.02rem;
    margin-bottom: 10px;
  }

  .service-links-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .service-links-grid a {
    text-decoration: none;
    font-weight: 700;
    color: var(--link-blue);
    border: 1px solid #dbe4f1;
    background: #f8fbff;
    border-radius: 10px;
    padding: 10px 12px;
  }

  .service-links-grid a:hover { text-decoration: underline; background: #eef4fd; }

  .cta-row {
    margin-top: 18px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 10px 16px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
  }

  .btn-primary {
    background: var(--green-security);
    color: #fff;
  }

  .btn-secondary {
    background: #fff;
    border: 1px solid #d1d5db;
    color: var(--blue-navy);
  }

  .section-light {
    background: #f8fafc;
    border-top: 1px solid #edf2f7;
    border-bottom: 1px solid #edf2f7;
  }

  .check-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 10px;
  }

  .check-list li {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 12px 14px;
    color: var(--text-body);
    line-height: 1.6;
  }

  .step-list {
    display: grid;
    gap: 12px;
  }

  .step-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 14px;
  }

  .step-card h3 {
    margin: 0 0 6px;
    color: var(--blue-navy);
    font-size: 1rem;
  }

  .step-card p {
    margin: 0;
    color: var(--text-body);
    line-height: 1.7;
  }

  .case-card {
    background: #fff;
    border: 1px solid #d9e5f4;
    border-radius: 12px;
    padding: 16px;
  }

  .case-card h3 {
    margin: 0 0 10px;
    color: var(--blue-navy);
  }

  .case-card p {
    margin: 0 0 8px;
    color: var(--text-body);
    line-height: 1.7;
  }

  .pricing-intro {
    margin: 0 0 12px;
    color: var(--text-body);
    line-height: 1.7;
  }

  .pricing-box {
    border: 1px solid #d9e5f4;
    background: #fff;
    border-radius: 12px;
    padding: 14px;
  }

  .pricing-note {
    margin: 12px 0 0;
    color: #475569;
    line-height: 1.65;
    font-size: .95rem;
  }

  .faq-list {
    display: grid;
    gap: 10px;
  }

  .faq-list details {
    border: 1px solid #d9e5f4;
    border-radius: 10px;
    background: #fff;
    padding: 12px 14px;
  }

  .faq-list summary {
    cursor: pointer;
    font-weight: 700;
    color: var(--blue-navy);
  }

  .faq-list p {
    margin: 10px 0 0;
    color: var(--text-body);
    line-height: 1.7;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .related-card {
    display: block;
    text-decoration: none;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #fff;
    padding: 14px;
  }

  .related-card h3 {
    margin: 0 0 6px;
    color: var(--blue-navy);
    font-size: 1.02rem;
  }

  .related-card p {
    margin: 0;
    color: #475569;
    line-height: 1.55;
    font-size: .94rem;
  }

  @media (max-width: 900px) {
    .service-links-grid,
    .related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .cta-row { display: grid; grid-template-columns: 1fr; }
    .btn { width: 100%; }
  }
</style>
