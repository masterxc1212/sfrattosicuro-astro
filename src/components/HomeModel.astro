---
import HeaderIsland from './HeaderIsland.astro';
import HeroInstitutionalIsland from './HeroInstitutionalIsland.astro';
import SedeIdentityIsland from './SedeIdentityIsland.astro';
import TerritorialCtaIsland from './TerritorialCtaIsland.astro';
import WhenPossibleSection from './WhenPossibleSection.astro';
import ProcedureSection from './ProcedureSection.astro';
import TypesSection from './TypesSection.astro';
import TimelineSection from './TimelineSection.astro';
import WhyLawyerSection from './WhyLawyerSection.astro';
import TerritoryCoverageSection from './TerritoryCoverageSection.astro';
import DoveOperiamoSection from './DoveOperiamoSection.astro';
import StudioSection from './StudioSection.astro';
import ProvvedimentiIsland from './ProvvedimentiIsland.astro';
import ReviewsIsland from './ReviewsIsland.astro';
import LatestBlogPostsIsland from './LatestBlogPostsIsland.astro';
import SedeBlogLinksIsland from './SedeBlogLinksIsland.astro';
import VideoReviewsIsland from './VideoReviewsIsland.astro';
import TribunaleInfoSection from './TribunaleInfoSection.astro';
import FaqSection from './FaqSection.astro';
import ContactFormIsland from './ContactFormIsland.astro';
import Footer from './Footer.astro';
import SmoothScrollIsland from './SmoothScrollIsland.astro';
import PageJumpNavIsland from './PageJumpNavIsland.astro';
// === Piano 80% — 7 sezioni territoriali ===
import StoriaTribunaleSection from './sede/StoriaTribunaleSection.astro';
import CancelleriaOperativaSection from './sede/CancelleriaOperativaSection.astro';
import MercatoLocaleSection from './sede/MercatoLocaleSection.astro';
import GiurisprudenzaLocaleSection from './sede/GiurisprudenzaLocaleSection.astro';
import TempiRealiSection from './sede/TempiRealiSection.astro';
import PartnerLocaliSection from './sede/PartnerLocaliSection.astro';
import ZoneServiteSection from './sede/ZoneServiteSection.astro';
import sediJson from '../data/sedi.json';
import type { SedeItem } from '../lib/home-model';

interface JumpItem {
  href: string;
  label: string;
}

interface Breadcrumb {
  city: string;
}

interface Props {
  sedeSlug?: string;
  jumpTitle?: string;
  jumpItems?: JumpItem[];
  breadcrumb?: Breadcrumb;
  introText?: string;
  showDoveOperiamo?: boolean;
  showVideoReviews?: boolean;
  showBlogLatest?: boolean;
  faqItems?: { q: string; a: string }[];
}

const {
  sedeSlug = 'nazionale',
  jumpTitle = 'Percorso rapido',
  jumpItems = [
    { href: '#procedura-sfratto', label: 'Procedura' },
    { href: '#faq-sfratto', label: 'FAQ' },
    { href: '#contatti', label: 'Contatti' }
  ],
  breadcrumb,
  introText,
  showDoveOperiamo = false,
  showVideoReviews = false,
  showBlogLatest = true,
  faqItems
} = Astro.props;

const isNational = sedeSlug === 'nazionale';
const sedeData: SedeItem | undefined = isNational
  ? undefined
  : (sediJson as SedeItem[]).find((s) => s.slug === sedeSlug);

// Piano 80% — la sede ha almeno un blocco territoriale popolato.
// Quando true, la pagina sede demolisce le sezioni boilerplate generiche
// (WhenPossible, Types, WhyLawyer, TerritoryCoverage, TribunaleInfo) e
// le sostituisce con i 7 blocchi territoriali unici.
const hasTerritorialContent = !!(sedeData && (
  sedeData.mercatoLocale
  || sedeData.cancelleriaEstesa
  || sedeData.giurisprudenzaLocale
  || sedeData.partnerLocali
  || sedeData.tempiReali
  || sedeData.zoneServite
  || sedeData.storiaTribunale
));

// Sezioni boilerplate: render solo se NON c'e' contenuto territoriale specifico.
// Per le pagine nazionale e per le sedi non ancora popolate (124/137),
// continuiamo a usare il boilerplate.
const showBoilerplate = !hasTerritorialContent;
---

<HeaderIsland />
<PageJumpNavIsland title={jumpTitle} items={jumpItems} />

<main id="main-content">
  {breadcrumb && (
    <nav class="breadcrumb container" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/sedi/">Sedi</a>
      <span>/</span>
      <span aria-current="page">{breadcrumb.city}</span>
    </nav>
  )}

  <HeroInstitutionalIsland sedeSlug={sedeSlug} />
  <SedeIdentityIsland sedeSlug={sedeSlug} />
  <TerritorialCtaIsland sedeSlug={sedeSlug} />

  {introText && (
    <section class="section section--compact intro container">
      <p>{introText}</p>
      {!isNational && <a class="back-link" href="/sedi/">&larr; Torna all'elenco sedi</a>}
    </section>
  )}

  <hr class="asterism" aria-hidden="true" />

  {showBoilerplate && <WhenPossibleSection sedeSlug={sedeSlug} />}
  <ProcedureSection sedeSlug={sedeSlug} />
  {showBoilerplate && <TypesSection sedeSlug={sedeSlug} />}
  <TimelineSection sedeSlug={sedeSlug} />
  {showBoilerplate && <TribunaleInfoSection sedeSlug={sedeSlug} />}
  {showBoilerplate && <WhyLawyerSection sedeSlug={sedeSlug} />}
  {showBoilerplate && <TerritoryCoverageSection sedeSlug={sedeSlug} />}

  {showDoveOperiamo && <DoveOperiamoSection />}

  {sedeData && (
    <>
      <hr class="asterism" aria-hidden="true" />
      <StoriaTribunaleSection sede={sedeData} />
      <CancelleriaOperativaSection sede={sedeData} />
      <MercatoLocaleSection sede={sedeData} />
      <GiurisprudenzaLocaleSection sede={sedeData} />
      <TempiRealiSection sede={sedeData} />
      <PartnerLocaliSection sede={sedeData} />
      <ZoneServiteSection sede={sedeData} />
    </>
  )}

  <hr class="asterism" aria-hidden="true" />

  <StudioSection sedeSlug={sedeSlug} />
  <ProvvedimentiIsland />
  <ReviewsIsland />

  {/* Una sola sezione blog per pagina: nazionale = LatestBlogPosts (generico),
      sede = SedeBlogLinks (specifico per la citta). Mai entrambe. */}
  {isNational && showBlogLatest && <LatestBlogPostsIsland />}
  {!isNational && <SedeBlogLinksIsland sedeSlug={sedeSlug} />}
  {showVideoReviews && <VideoReviewsIsland />}

  <FaqSection sedeSlug={sedeSlug} faqItems={faqItems} />
  <ContactFormIsland />
</main>

<Footer sedeSlug={sedeSlug} />
<SmoothScrollIsland />
