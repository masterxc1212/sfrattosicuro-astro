---
import sedi from '../data/sedi.json';

interface HeroVars {
  kicker?: string;
  h1Suffix?: string;
  subtitleLocal?: string;
  trustLocal1?: string;
  trustLocal2?: string;
  trustLocal3?: string;
  imageAlt?: string;
}

interface SedeItem {
  nome: string;
  slug: string;
  regione?: string;
  intro?: string;
  heroVars?: HeroVars;
}

interface HeroCarouselItem {
  image: string;
  alt: string;
  title: string;
  description: string;
}

interface Props {
  sedeSlug?: string;
  kicker?: string;
  h1?: string;
  subtitle?: string;
  bullets?: string[];
  trustRow?: string[];
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  heroImage?: string;
  heroImageAlt?: string;
  bulletsLabel?: string;
  useCarousel?: boolean;
  carouselItems?: HeroCarouselItem[];
}

const {
  sedeSlug = 'nazionale',
  kicker: kickerOverride,
  h1: h1Override,
  subtitle: subtitleOverride,
  bullets: bulletsOverride,
  trustRow: trustRowOverride,
  primaryCtaLabel = 'Richiedi consulenza gratuita',
  primaryCtaHref = '#contatti',
  secondaryCtaLabel = 'Scopri il metodo',
  secondaryCtaHref = '#procedura-sfratto',
  heroImage,
  heroImageAlt,
  bulletsLabel = 'Servizi principali',
  useCarousel = false,
  carouselItems = []
} = Astro.props;

const normalized = sedeSlug.trim().toLowerCase();
const isNazionale = normalized === 'nazionale';
const effectiveSlug = isNazionale ? 'salerno' : normalized;

const sediList = sedi as SedeItem[];
const sede = sediList.find((item) => item.slug === effectiveSlug);
const vars = sede?.heroVars ?? {};

const defaultKicker = isNazionale
  ? 'Avvocato per sfratto per morosità'
  : (vars.kicker ?? 'Specialisti in sfratti e diritto delle locazioni');

const defaultH1 = isNazionale
  ? 'Avvocato per Sfratto'
  : `Avvocato per Sfratto ${vars.h1Suffix ?? sede?.nome ?? ''}`.trim();

const normalizeLocalCopy = (text?: string) =>
  (text || '')
    .replace(/operiamo presso il tribunale di/gi, 'assistenza presso il tribunale di')
    .replace(/operatività presso il tribunale di/gi, 'presenza presso il tribunale di')
    .trim();

const defaultSubtitle = isNazionale
  ? 'Assistiamo proprietari e locatori nelle procedure di sfratto per morosità e finita locazione, con un protocollo operativo orientato ad arrivare, in molti casi, all’udienza per la convalida di sfratto in circa 60 giorni.'
  : normalizeLocalCopy(vars.subtitleLocal)
    || `Ti assistiamo per la procedura di sfratto presso il Tribunale di ${sede?.nome ?? 'competenza territoriale'}, fino al rilascio dell'immobile.`;

const defaultBullets = [
  'Sfratto per morosità e recupero dei canoni non pagati',
  'Sfratto per finita locazione e rilascio dell\'immobile',
  'Consulenza specialistica e gestione completa della pratica'
];

const defaultTrustRow = isNazionale
  ? [
      'Specialisti in sfratti e diritto delle locazioni',
      'Protocollo operativo orientato alla convalida in circa 60 giorni',
      'Operativi su tutto il territorio nazionale'
    ]
  : [
      normalizeLocalCopy(vars.trustLocal1) || `Tribunale competente: ${sede?.nome ?? ''}`,
      vars.trustLocal2 ?? (sede?.regione ? `Copertura territoriale in ${sede.regione}` : 'Copertura territoriale dedicata'),
      vars.trustLocal3 ?? 'Assistenza completa fino alla convalida'
    ];

const kicker = kickerOverride ?? defaultKicker;
const h1 = h1Override ?? defaultH1;
const subtitle = subtitleOverride ?? defaultSubtitle;
const bullets = bulletsOverride ?? defaultBullets;
const trustRow = trustRowOverride ?? defaultTrustRow;

const mediaImage = heroImage ?? '/assets/img/ufficio/hero_home.webp';
const mediaAlt = heroImageAlt ?? vars.imageAlt ?? 'Studio legale Sfratto Sicuro';
const enableCarousel = useCarousel && carouselItems.length > 0;
---

<section class="hero-institutional" aria-labelledby="hero-title">
  <div class="hero-grid">
    <div class="hero-copy">
      <p class="kicker">{kicker}</p>
      <h1 id="hero-title">{h1}</h1>
      <p class="subtitle">{subtitle}</p>

      <ul class="bullets" aria-label={bulletsLabel}>
        {bullets.map((item) => (
          <li>{item}</li>
        ))}
      </ul>

      <div class="cta-row">
        <a href={primaryCtaHref} class="btn btn-primary">{primaryCtaLabel}</a>
        <a href={secondaryCtaHref} class="btn btn-secondary">{secondaryCtaLabel}</a>
      </div>

      <div class="trust-row" aria-label="Elementi di affidabilità">
        {trustRow.map((item) => (
          <span>{item}</span>
        ))}
      </div>
    </div>

    {enableCarousel ? (
      <div class="hero-media hero-carousel" data-hero-carousel>
        <div class="carousel-track">
          {carouselItems.map((item, idx) => (
            <article class={`slide ${idx === 0 ? 'is-active' : ''}`} data-slide style={idx === 0 ? 'display:block' : 'display:none'}>
              <img src={item.image} alt={item.alt} loading={idx === 0 ? 'eager' : 'lazy'} fetchpriority={idx === 0 ? 'high' : 'auto'} decoding="async" />
              <div class="slide-overlay"></div>
              <div class="slide-text">
                <p class="slide-title">{item.title}</p>
                <p class="slide-description">{item.description}</p>
              </div>
            </article>
          ))}
        </div>

        <button class="carousel-btn prev" type="button" aria-label="Slide precedente" data-prev>‹</button>
        <button class="carousel-btn next" type="button" aria-label="Slide successiva" data-next>›</button>

        <div class="carousel-dots" aria-label="Indicatori slide">
          {carouselItems.map((_, idx) => (
            <button type="button" class={`dot ${idx === 0 ? 'is-active' : ''}`} data-dot data-index={idx} aria-label={`Vai alla slide ${idx + 1}`}></button>
          ))}
        </div>
      </div>
    ) : (
      <picture class="hero-media">
        <source srcset={mediaImage} type="image/webp" />
        <img src={mediaImage} alt={mediaAlt} loading="eager" fetchpriority="high" decoding="async" />
      </picture>
    )}
  </div>
</section>

{enableCarousel && (
  <script is:inline>
    (() => {
      const carousels = document.querySelectorAll('[data-hero-carousel]');
      carousels.forEach((root) => {
        const slides = Array.from(root.querySelectorAll('[data-slide]'));
        const dots = Array.from(root.querySelectorAll('[data-dot]'));
        const prev = root.querySelector('[data-prev]');
        const next = root.querySelector('[data-next]');
        if (!slides.length) return;

        let current = 0;
        let timer = null;

        const setActive = (index) => {
          current = (index + slides.length) % slides.length;
          slides.forEach((slide, i) => {
            const isActive = i === current;
            slide.classList.toggle('is-active', isActive);
            slide.style.display = isActive ? 'block' : 'none';
          });
          dots.forEach((dot, i) => dot.classList.toggle('is-active', i === current));
        };

        const play = () => {
          stop();
          timer = setInterval(() => setActive(current + 1), 4500);
        };

        const stop = () => {
          if (timer) {
            clearInterval(timer);
            timer = null;
          }
        };

        prev?.addEventListener('click', () => {
          setActive(current - 1);
          play();
        });

        next?.addEventListener('click', () => {
          setActive(current + 1);
          play();
        });

        dots.forEach((dot, idx) => {
          dot.addEventListener('click', () => {
            setActive(idx);
            play();
          });
        });

        root.addEventListener('mouseenter', stop);
        root.addEventListener('mouseleave', play);
        play();
      });
    })();
  </script>
)}

<style>
  .hero-institutional {
    margin: 0 0 24px;
    padding: clamp(20px, 2.8vw, 34px);
    border-radius: 0;
    background: #f7f9fc;
    border: 1px solid #e2e8f0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(16px, 2.5vw, 30px);
    align-items: center;
  }

  .hero-copy { max-width: 74ch; }

  .kicker {
    margin: 0 0 8px;
    color: #c6902a;
    text-transform: uppercase;
    letter-spacing: .05em;
    font-weight: 700;
  }

  h1 {
    margin: 0 0 12px;
    color: var(--blue-navy);
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1.05;
  }

  .subtitle {
    margin: 0 0 16px;
    color: #334155;
    font-size: clamp(1rem, 1.6vw, 1.18rem);
    line-height: 1.65;
  }

  .bullets {
    margin: 0 0 18px;
    padding-left: 18px;
    color: #334155;
    display: grid;
    gap: 8px;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0 0 18px;
  }

  .btn {
    text-decoration: none;
    border-radius: 10px;
    padding: 12px 14px;
    font-weight: 700;
    border: 1px solid transparent;
  }

  .btn-primary { background: #2b8f42; color: #fff; }
  .btn-secondary { background: #fff; color: #1e3a8a; border-color: #cbd5e1; }

  .trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .trust-row span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 10px;
    background: #fff;
    border: 1px solid #e2e8f0;
    color: #334155;
    font-size: .92rem;
    border-radius: 999px;
  }

  .hero-media {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid #dbe3ef;
    box-shadow: 0 12px 32px rgba(15, 23, 42, .08);
    min-height: 320px;
    background: #e8eef7;
  }

  .hero-media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .hero-carousel { position: relative; }
  .carousel-track, .slide { height: 100%; min-height: 320px; }
  .slide { position: relative; }
  .slide-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(15,23,42,.1) 0%, rgba(15,23,42,.52) 100%); }
  .slide-text { position: absolute; left: 18px; right: 18px; bottom: 18px; color: #fff; }
  .slide-title { margin: 0 0 6px; font-weight: 700; font-size: 1.15rem; }
  .slide-description { margin: 0; line-height: 1.55; }
  .carousel-btn {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 2;
    width: 40px; height: 40px; border-radius: 50%; border: 0; cursor: pointer;
    background: rgba(255,255,255,.85); color: #0f172a; font-size: 1.4rem; font-weight: 700;
  }
  .carousel-btn.prev { left: 12px; }
  .carousel-btn.next { right: 12px; }
  .carousel-dots {
    position: absolute; left: 0; right: 0; bottom: 10px; z-index: 2;
    display: flex; justify-content: center; gap: 8px;
  }
  .dot {
    width: 10px; height: 10px; border-radius: 50%; border: 0; cursor: pointer;
    background: rgba(255,255,255,.6);
  }
  .dot.is-active { background: #fff; }

  @media (min-width: 1024px) {
    .hero-grid { grid-template-columns: minmax(0, 1.1fr) minmax(380px, .9fr); }
  }

  @media (max-width: 767px) {
    .hero-institutional { padding: 16px; margin-bottom: 12px; }
    .hero-media { display: none; }
    .kicker { font-size: 0.72rem; margin-bottom: 10px; }
    h1 { margin-bottom: 14px; }
    .subtitle { font-size: 0.95rem; margin-bottom: 18px; }
    .bullets { list-style: none; padding-left: 0; font-size: 0.9rem; gap: 6px; margin-bottom: 20px; }
    .bullets li { padding-left: 1.4em; position: relative; }
    .bullets li::before { content: '✓'; position: absolute; left: 0; color: #2b8f42; font-weight: 700; }
    .cta-row { flex-direction: column; margin-bottom: 20px; }
    .btn { text-align: center; }
    .trust-row { gap: 6px; }
    .trust-row span { font-size: 0.82rem; padding: 6px 8px; }
    .trust-row span:nth-child(n+3) { display: none; }
  }
</style>
