---
interface Props { sedeSlug: string; }
const { sedeSlug = 'nazionale' } = Astro.props;
---

<section class="section" id="lo-studio" aria-labelledby="studio-title">
  <div class="container studio-grid">
    <div class="studio-copy">
      <h2 id="studio-title">Uno studio legale focalizzato sulle procedure di sfratto</h2>
      <p>Assistiamo proprietari di immobili nella gestione delle procedure di sfratto per morosità e finita locazione fino al rilascio dell’immobile.</p>
    </div>

    <picture class="studio-media">
      <source srcset="/assets/img/ufficio/elemento_home.webp" type="image/webp" />
      <img src="/assets/img/ufficio/elemento_home.webp" alt="Studio legale Sfratto Sicuro - ufficio" loading="lazy" />
    </picture>
  </div>
</section>

