---
import sedi from '../data/sedi.json';

interface SedeItem { nome: string; slug: string; tribunale?: string; }
interface Props { sedeSlug?: string; }

const { sedeSlug = 'nazionale' } = Astro.props;
const normalized = sedeSlug.trim().toLowerCase();
const isNazionale = normalized === 'nazionale';
const sede = (sedi as SedeItem[]).find((item) => item.slug === normalized);

const nome = sede?.nome ?? 'la tua città';
const tribunale = sede?.tribunale ?? `Tribunale di ${nome}`;
---

<section class="section" id="quando-sfrattare" aria-labelledby="when-title">
  <div class="container">
    <h2 id="when-title">Quando è possibile sfrattare un inquilino</h2>
    <p>
      La legge consente al proprietario di richiedere il rilascio dell’immobile attraverso la procedura di sfratto in specifiche situazioni previste dal codice di procedura civile.
      Le ipotesi più frequenti riguardano la morosità dell’inquilino o la scadenza del contratto di locazione.
    </p>
    {!isNazionale && <p>Per gli immobili situati a {nome}, la procedura viene trattata presso il {tribunale}.</p>}

    <div class="grid2">
      <article class="card">
        <span class="icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3v18M7 7h8M7 17h8M5 10c0-1.1.9-2 2-2h10M5 14c0 1.1.9 2 2 2h10"/></svg></span>
        <h3>Sfratto per morosità</h3>
        <p>Si verifica quando l’inquilino non paga il canone di locazione o le spese accessorie previste dal contratto. In questo caso il proprietario può avviare la procedura di sfratto per morosità davanti al tribunale competente.</p>
      </article>
      <article class="card">
        <span class="icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M8 3v3M16 3v3M4 9h16M5 6h14a1 1 0 0 1 1 1v12H4V7a1 1 0 0 1 1-1Zm7 6h4m-4 4h6"/></svg></span>
        <h3>Sfratto per finita locazione</h3>
        <p>Quando il contratto di locazione è scaduto e l’inquilino non restituisce l’immobile, il proprietario può richiedere lo sfratto per finita locazione per ottenere il rilascio dell’immobile.</p>
      </article>
    </div>
  </div>
</section>

<style>
  .section { padding: 56px 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  h2 { margin: 0 0 22px; color: var(--blue-navy); }
  p { margin: 0 0 14px; line-height: 1.6; color: #334155; }
  .grid2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 8px; }
  .card { background: #fff; border-radius: 10px; padding: 24px; box-shadow: 0 4px 12px rgba(0,0,0,.05); border: 1px solid #e5e7eb; }
  .icon { width: 32px; height: 32px; display: inline-grid; place-items: center; margin-bottom: 12px; }
  .icon svg { width: 100%; height: 100%; stroke: var(--blue-navy); stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
  h3 { margin: 0 0 10px; color: var(--blue-navy); }
  .card p { margin: 0; }
  @media (max-width: 1024px) { .section { padding: 44px 0; } }
  @media (max-width: 767px) {
    .section { padding: 36px 0; }
    .grid2 { grid-template-columns: 1fr; gap: 12px; }
    .card { box-shadow: none; }
    h2 { font-size: clamp(1.3rem, 5vw, 1.8rem); margin-bottom: 16px; }
  }
</style>
