---
const topSedi = [
  { name: 'Milano', slug: 'milano' },
  { name: 'Roma', slug: 'roma' },
  { name: 'Napoli', slug: 'napoli' },
  { name: 'Torino', slug: 'torino' },
  { name: 'Bologna', slug: 'bologna' },
  { name: 'Firenze', slug: 'firenze' },
  { name: 'Palermo', slug: 'palermo' },
  { name: 'Bari', slug: 'bari' }
];
---

<section class="section" id="dove-operiamo" aria-labelledby="dove-operiamo-title">
  <div class="container">
    <div class="layout">
      <div>
        <h2 id="dove-operiamo-title">Dove operiamo</h2>
        <p class="subtitle">Presidi territoriali e gestione pratiche presso i tribunali competenti in tutta Italia.</p>
        <p>Trova la sede territoriale più vicina e consulta le informazioni operative per avviare la procedura con un avvocato per sfratto.</p>
        <a class="btn" href="/sedi/">Vedi tutte le sedi</a>
      </div>

      <div class="list-box" aria-label="Sedi principali">
        <ul>
          {topSedi.map((sede) => (
            <li><a href={`/sedi/${sede.slug}/`}>Avvocato per sfratto a {sede.name}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

