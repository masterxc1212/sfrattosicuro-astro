---
/**
 * StickyMobileCTA — Bottom action bar mobile only.
 * Visibile sotto i 900px. Tre azioni rapide: chiama, WhatsApp, scrivi.
 * Copy invariato (riusa lo stesso copy delle CTA esistenti del sito).
 */
import site from '../data/site.json';

const org = site.organization;
const tel = (org?.telephone || '+39 02 80898395').replace(/\s+/g, '');
const wa = org?.whatsappUrl || 'https://wa.me/393291175957';
---

<aside class="sticky-mobile-cta" aria-label="Azioni rapide" data-sticky-mobile-cta>
  <div class="sticky-mobile-cta__inner">
    <a class="sticky-mobile-cta__btn sticky-mobile-cta__btn--call" href={`tel:${tel}`} aria-label="Chiama il numero">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z"/>
      </svg>
      <span>Chiama</span>
    </a>
    <a class="sticky-mobile-cta__btn sticky-mobile-cta__btn--wa" href={wa} target="_blank" rel="noopener noreferrer" aria-label="Scrivi su WhatsApp">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
      </svg>
      <span>WhatsApp</span>
    </a>
    <a class="sticky-mobile-cta__btn sticky-mobile-cta__btn--primary" href="#contatti" aria-label="Vai al modulo contatti">
      <span>Scrivi</span>
    </a>
  </div>
</aside>

<script>
  // Mostra la sticky CTA solo dopo che l'utente ha scrollato oltre l'hero (UX più sobria)
  (function () {
    const el = document.querySelector('[data-sticky-mobile-cta]');
    if (!el) return;
    const trigger = 360;
    const onScroll = () => {
      if (window.scrollY > trigger) {
        el.classList.add('is-visible');
      } else {
        el.classList.remove('is-visible');
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>
