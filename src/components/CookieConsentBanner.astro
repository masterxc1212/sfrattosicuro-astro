<div id="cookie-consent" class="cc" hidden>
  <div class="cc__inner" role="region" aria-label="Preferenze cookie">
    <p>
      Usiamo cookie necessari e, con il tuo consenso, cookie analitici/marketing.
      Se non scegli entro pochi secondi, restano attivi solo i necessari.
      <a href="/cookie-policy/">Cookie Policy</a>
    </p>
    <div class="cc__actions">
      <button type="button" data-cc-action="reject">Rifiuta</button>
      <button type="button" data-cc-action="accept" class="primary">Accetta</button>
    </div>
  </div>
</div>

<button id="cookie-manage" class="cc-manage" type="button" hidden>Cookie</button>

<script is:inline>
  (() => {
    const STORAGE_KEY = 'ss_cookie_consent_v1';
    const AUTO_CLOSE_MS = 9000;

    const root = document.getElementById('cookie-consent');
    const manageBtn = document.getElementById('cookie-manage');
    if (!root || !manageBtn) return;

    let autoCloseTimer = null;

    const read = () => {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        return {
          necessary: true,
          analytics: Boolean(parsed.analytics),
          marketing: Boolean(parsed.marketing),
          updatedAt: parsed.updatedAt || new Date().toISOString()
        };
      } catch {
        return null;
      }
    };

    const emit = (consent) => {
      window.__ssCookieConsent = consent;
      window.dispatchEvent(new CustomEvent('ss:cookie-consent-updated', { detail: consent }));
    };

    const clearTimer = () => {
      if (!autoCloseTimer) return;
      clearTimeout(autoCloseTimer);
      autoCloseTimer = null;
    };

    const save = ({ analytics, marketing }) => {
      clearTimer();
      const consent = {
        necessary: true,
        analytics: Boolean(analytics),
        marketing: Boolean(marketing),
        updatedAt: new Date().toISOString()
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(consent));
      emit(consent);
      root.hidden = true;
      manageBtn.hidden = false;
    };

    const current = read();
    if (current) {
      emit(current);
      root.hidden = true;
      manageBtn.hidden = false;
    } else {
      root.hidden = false;
      manageBtn.hidden = true;
      autoCloseTimer = setTimeout(() => {
        save({ analytics: false, marketing: false });
      }, AUTO_CLOSE_MS);
    }

    root.addEventListener('click', (event) => {
      const btn = event.target.closest('[data-cc-action]');
      if (!btn) return;
      const action = btn.getAttribute('data-cc-action');
      if (action === 'accept') save({ analytics: true, marketing: true });
      if (action === 'reject') save({ analytics: false, marketing: false });
    });

    manageBtn.addEventListener('click', () => {
      clearTimer();
      root.hidden = false;
      manageBtn.hidden = true;
      autoCloseTimer = setTimeout(() => {
        save({ analytics: false, marketing: false });
      }, AUTO_CLOSE_MS);
    });
  })();
</script>

