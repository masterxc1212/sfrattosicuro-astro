---
import sedi from '../data/sedi.json';

interface SedeItem {
  nome: string;
  slug: string;
  intro?: string;
  tribunale?: string;
  localAngles?: {
    openingAngle?: string;
    protocolAngle?: string;
    courtAngle?: string;
    closingAngle?: string;
  };
}

interface Props { sedeSlug?: string; }

const { sedeSlug = 'nazionale' } = Astro.props;
const normalized = sedeSlug.trim().toLowerCase();
const isNazionale = normalized === 'nazionale';
const sede = (sedi as SedeItem[]).find((item) => item.slug === normalized);

const nome = sede?.nome ?? 'la tua città';
const tribunale = sede?.tribunale ?? `Tribunale di ${nome}`;
const title = isNazionale ? 'Avvocato per Sfratto in tutta Italia' : `Avvocato per Sfratto a ${nome}`;
const subtitle = isNazionale
  ? 'Siamo operativi su tutto il territorio nazionale per assistere i proprietari nella procedura di sfratto e nella gestione delle locazioni.'
  : (sede?.localAngles?.openingAngle?.trim() || sede?.intro?.trim() || `Presidio territoriale dedicato per le procedure di sfratto a ${nome}.`);

const pillars = isNazionale
  ? [
      { icon: 'scale', title: 'Strategia legale strutturata', text: 'Analizziamo il contratto di locazione e impostiamo la procedura di sfratto più efficace per ottenere il rilascio dell’immobile.' },
      { icon: 'court', title: 'Operatività nei tribunali italiani', text: 'Gestione delle procedure di sfratto presso i tribunali competenti su tutto il territorio nazionale.' },
      { icon: 'doc', title: 'Gestione completa della pratica', text: 'Assistenza legale dalla fase iniziale fino alla liberazione dell’immobile.' }
    ]
  : [
      { icon: 'scale', title: `Strategia locale su ${nome}`, text: sede?.localAngles?.protocolAngle?.trim() || `Impostiamo la strategia processuale in base alla prassi del ${tribunale}.` },
      { icon: 'court', title: 'Presidio territoriale diretto', text: sede?.localAngles?.courtAngle?.trim() || `Seguiamo le procedure presso il ${tribunale}, con coordinamento continuo.` },
      { icon: 'doc', title: 'Pratica seguita end-to-end', text: sede?.localAngles?.closingAngle?.trim() || 'Dalla prima intimazione fino alla fase esecutiva con ufficiale giudiziario.' }
    ];
---

<section class="section" aria-label={`Presentazione sede ${isNazionale ? 'nazionale' : nome}`}>
  <div class="container">
    <h2>{title}</h2>
    <p class="subtitle">{subtitle}</p>

    <div class="grid3">
      {pillars.map((item) => (
        <article class="card">
          <span class="icon" aria-hidden="true">
            {item.icon === 'scale' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M5 21h14M4 7h16M7 7l-3 7a3 3 0 006 0l-3-7M17 7l-3 7a3 3 0 006 0l-3-7"/></svg>}
            {item.icon === 'court' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10h18M5 10V7l7-4 7 4v3M6 10v8m4-8v8m4-8v8m4-8v8M3 21h18"/></svg>}
            {item.icon === 'doc' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h7l5 5v13H7zM14 3v5h5M9 13h6M9 17h6"/></svg>}
          </span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

