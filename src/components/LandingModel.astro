---
/**
 * LandingModel — Wrapper che assembla i componenti landing modulari.
 * Usato da nuova-landing.astro e come riferimento per altre pagine.
 * Per la versione full, usa src/pages/landing-v2/index.astro.
 */
import HeaderIsland from './HeaderIsland.astro';
import Footer from './Footer.astro';
import ReviewsIsland from './ReviewsIsland.astro';
import ProvvedimentiIsland from './ProvvedimentiIsland.astro';
import SmoothScrollIsland from './SmoothScrollIsland.astro';

import LandingHeroIsland from './landing/LandingHeroIsland.astro';
import LandingTrustBarSection from './landing/LandingTrustBarSection.astro';
import LandingProblemsSection from './landing/LandingProblemsSection.astro';
import LandingHowItWorksSection from './landing/LandingHowItWorksSection.astro';
import LandingPricingSection from './landing/LandingPricingSection.astro';
import LandingUrgencySection from './landing/LandingUrgencySection.astro';
import LandingFaqSection from './landing/LandingFaqSection.astro';
import LandingContactFormIsland from './landing/LandingContactFormIsland.astro';

import type { LandingConfig } from '../data/landing-model';

interface Props {
  config: LandingConfig;
}

const { config } = Astro.props;
---

<HeaderIsland />

<main id="main-content">

  <!-- 1. Hero con form inline di qualificazione -->
  <LandingHeroIsland config={config} />

  <!-- 2. Trust bar: 4 metriche chiave -->
  <LandingTrustBarSection signals={config.trustSignals} />

  <!-- 3. Problemi del proprietario -->
  <LandingProblemsSection problems={config.problems} />

  <!-- 4. Come funziona -->
  <LandingHowItWorksSection steps={config.steps} />

  <!-- 5. Pricing trasparente -->
  <LandingPricingSection offer={config.offer} />

  <!-- 6. Urgency CTA -->
  <LandingUrgencySection urgency={config.urgency} />

  <!-- 7. Prove sociali -->
  <ReviewsIsland />

  <!-- 8. Provvedimenti documentati -->
  <ProvvedimentiIsland />

  <!-- 9. FAQ -->
  <LandingFaqSection
    faq={config.faq}
    territory={config.territory}
  />

  <!-- 10. Form di contatto qualificato -->
  <LandingContactFormIsland
    formCta={config.formCta}
    qualifierQuestion={config.qualifierQuestion}
    qualifierOptions={config.qualifierOptions}
    territory={config.territory}
  />

</main>

<Footer />
<SmoothScrollIsland />
