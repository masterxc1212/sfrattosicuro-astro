---
// LandingOriginalHeroSection.astro — 1:1 clone of original hero
// Source: public/landing/index.html
import { landingOriginal } from '../../data/landing-original';

interface Props {
  hero?: typeof landingOriginal.hero;
}

const { hero = landingOriginal.hero } = Astro.props;
---
<section
  class="hero-section text-white relative overflow-hidden"
  style="background: linear-gradient(135deg, #1B2951 0%, #2a4073 50%, #1B2951 100%);"
  aria-label="Sezione principale"
>
  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-6xl mx-auto">
      <div class="hero-grid">

        <div class="hero-content">

          <div class="hero-seal-mobile lg:hidden">
            <picture>
              <source media="(min-width: 1024px)" srcset="/assets/img/sigillo/sigillo-315.webp" width="315" height="315">
              <source media="(min-width: 640px)" srcset="/assets/img/sigillo/sigillo-240.webp" width="240" height="240">
              <img
                src="/assets/img/sigillo/sigillo-180.webp"
                alt="Avvocati Iscritti all'Albo Professionisti"
                class="seal-prominent-img"
                width="180"
                height="180"
                fetchpriority="high"
                decoding="async"
                loading="eager"
              >
            </picture>
          </div>

          <h1 class="hero-title" set:html={hero.title.replace(/\n/g, '<br>')}></h1>

          <h2 class="hero-subtitle" set:html={hero.subtitle}></h2>

          <ul class="hero-benefits" style="min-height:200px">
            {hero.bullets.map((bullet) => (
              <li class="hero-benefit-item">
                <span class="checkmark" aria-hidden="true">✓</span>
                <span set:html={bullet}></span>
              </li>
            ))}
          </ul>

        </div>

        <div class="hero-form-container">
          <div class="hero-form-card">
            <div class="text-center">
              <h3 class="form-title">{hero.formTitle}</h3>
              <p class="form-subtitle" set:html={hero.formSubtitle}></p>
            </div>

            <form
              action="/php/invia-email.php"
              method="POST"
              id="hero-form"
            >
              <div class="form-group">
                <label for="nome-hero" class="form-label">Nominativo *</label>
                <input
                  type="text"
                  name="nome"
                  id="nome-hero"
                  class="form-input"
                  placeholder={hero.formNamePlaceholder}
                  required
                  minlength="2"
                  aria-required="true"
                  autocomplete="name"
                >
              </div>

              <div class="form-group">
                <label for="telefono-hero" class="form-label">Telefono *</label>
                <input
                  type="tel"
                  name="telefono"
                  id="telefono-hero"
                  class="form-input"
                  placeholder={hero.formPhonePlaceholder}
                  pattern="[0-9\s+]{8,}"
                  required
                  aria-required="true"
                  autocomplete="tel"
                >
              </div>

              <input type="hidden" name="form_source" value={hero.formSource}>
              <input type="hidden" name="gclid" value="">
              <input type="hidden" name="utm_source" value="">
              <input type="hidden" name="utm_medium" value="">
              <input type="hidden" name="utm_campaign" value="">
              <input type="hidden" name="utm_term" value="">
              <input type="hidden" name="keyword" value="">
              <input type="hidden" name="utm_content" value="">
              <input type="hidden" name="redirect_url" value="https://www.sfrattosicuro.it/grazie.html">

              <button type="submit" class="form-submit" aria-label="Richiedi una consulenza gratuita">
                <i class="fas fa-phone" aria-hidden="true"></i>
                <span>{hero.formSubmitLabel}</span>
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
