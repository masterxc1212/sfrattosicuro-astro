---
// LandingOriginalVideoReviewsSection.astro — 1:1 clone of original video reviews section
// Source: public/landing/index.html
---
<section id="video-recensioni" class="bg-white py-16">
  <div class="container">
    <h2 class="text-3xl font-bold text-blue-navy text-center mb-6">
      <span aria-hidden="true">🎥</span> Video Recensioni dei Nostri Clienti
    </h2>
    <p class="text-center text-gray-700 mb-8 max-w-3xl mx-auto">
      Guarda cosa dicono i proprietari che hanno scelto il "Protocollo Riprendi Casa" per riottenere il proprio immobile in tempi rapidi e con serenità.
    </p>
    <div id="videoGrid" class="video-grid gap-6" style="min-height:300px">
      <div class="video-skeleton animate-pulse" style="background:#e5e7eb;border-radius:0.75rem;aspect-ratio:16/9"></div>
      <div class="video-skeleton animate-pulse hidden md:block" style="background:#e5e7eb;border-radius:0.75rem;aspect-ratio:16/9"></div>
      <div class="video-skeleton animate-pulse hidden lg:block" style="background:#e5e7eb;border-radius:0.75rem;aspect-ratio:16/9"></div>
    </div>
    <div id="videoStatus" class="text-center text-gray-700 mt-6" role="status" aria-live="polite"></div>
  </div>
</section>
