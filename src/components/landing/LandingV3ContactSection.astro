---
import { landingOriginal } from '../../data/landing-original';

interface Props {
  contactForm?: typeof landingOriginal.contactForm;
}

const { contactForm = landingOriginal.contactForm } = Astro.props;
---
<section id={contactForm.sectionId} class="py-16 bg-gray-pearl landing-v3-contact" aria-labelledby="contatti-heading-v3">
  <div class="container mx-auto px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 id="contatti-heading-v3" class="text-3xl md:text-4xl font-bold text-blue-navy mb-4">{contactForm.title}</h2>
        <p class="text-lg md:text-xl text-dark-gray max-w-3xl mx-auto">{contactForm.subtitle}</p>
      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:2rem; align-items:start;" class="landing-v3-contact-grid-2col">

        <!-- COLONNA SINISTRA: info + contatti -->
        <div style="display:flex; flex-direction:column; gap:1.5rem;">

          <div class="bg-white rounded-2xl card-shadow landing-v3-contact-card" style="padding:1.5rem;">
            <h3 class="text-xl font-bold text-blue-navy" style="margin-bottom:1rem;">{contactForm.formTitle}</h3>
            <div class="bg-blue-50 rounded-xl text-sm text-dark-gray" style="padding:1rem; border:1px solid rgba(27,41,81,.1);">
              <strong class="text-blue-navy">Checklist minima:</strong>
              <ul style="margin-top:.75rem; padding-left:1.25rem; list-style:disc; line-height:1.6;">
                <li>sei il proprietario o il locatore dell'immobile;</li>
                <li>l'inquilino ha già accumulato morosità;</li>
                <li>puoi indicarci città immobile e mesi non pagati.</li>
              </ul>
            </div>
          </div>

          <div class="bg-blue-navy text-white rounded-2xl landing-v3-side-card" style="padding:1.5rem;">
            <h3 class="font-bold" style="font-size:1.1rem; margin-bottom:1rem;">Contatti diretti</h3>
            <div style="display:flex; flex-direction:column; gap:1rem; font-size:.9rem;">
              <div>
                <div class="text-gold-refined" style="font-weight:600; margin-bottom:.25rem;">Telefono</div>
                <a href="tel:+390280898395" class="text-white" style="font-weight:700;">{contactForm.contacts.phoneValue}</a>
                <p class="text-gray-300" style="margin-top:.25rem; font-size:.8rem;">{contactForm.contacts.phoneHours}</p>
              </div>
              <div>
                <div class="text-gold-refined" style="font-weight:600; margin-bottom:.25rem;">WhatsApp</div>
                <a href="https://wa.me/393291175957" target="_blank" rel="noopener noreferrer" class="text-white" style="font-weight:700;">{contactForm.contacts.whatsappValue}</a>
                <p class="text-gray-300" style="margin-top:.25rem; font-size:.8rem;">{contactForm.contacts.whatsappNote}</p>
              </div>
            </div>
          </div>

          <div class="bg-yellow-50 rounded-xl" style="padding:1.25rem; border:1px solid var(--gold-refined);">
            <h4 class="font-bold text-blue-navy" style="margin-bottom:.5rem;">{contactForm.urgencyBox.title}</h4>
            <p class="text-dark-gray" style="font-size:.9rem; line-height:1.6;"><span set:html={contactForm.urgencyBox.body}></span></p>
          </div>

        </div>

        <!-- COLONNA DESTRA: form -->
        <div class="bg-white rounded-2xl card-shadow" style="padding:1.5rem; position:sticky; top:calc(var(--header-h) + 1rem);">
          <form action="/php/invia-email.php" method="POST" class="landing-v3-contact-form" aria-label="Form richiesta rapida proprietario" style="display:flex; flex-direction:column; gap:1rem;">

            <div>
              <label for="nome-v3" class="block text-dark-gray" style="font-weight:600; margin-bottom:.4rem;">Nome e cognome *</label>
              <input type="text" name="nome" id="nome-v3" class="form-input" placeholder="Nome e cognome del proprietario" required aria-required="true">
            </div>

            <div>
              <label for="telefono-v3" class="block text-dark-gray" style="font-weight:600; margin-bottom:.4rem;">Telefono *</label>
              <input type="tel" name="telefono" id="telefono-v3" class="form-input" placeholder="Numero di telefono diretto" required aria-required="true">
            </div>

            <div>
              <label for="citta-v3" class="block text-dark-gray" style="font-weight:600; margin-bottom:.4rem;">Città immobile *</label>
              <input type="text" name="città" id="citta-v3" class="form-input" placeholder="In che città si trova l'immobile?" required aria-required="true">
            </div>

            <input type="hidden" name="form_source" value="bottom_form_v3">
            <input type="hidden" name="gclid" value="">
            <input type="hidden" name="utm_source" value="">
            <input type="hidden" name="utm_medium" value="">
            <input type="hidden" name="utm_campaign" value="">
            <input type="hidden" name="utm_term" value="">
            <input type="hidden" name="keyword" value="">
            <input type="hidden" name="utm_content" value="">
            <input type="hidden" name="matchtype" value="">
            <input type="hidden" name="redirect_url" value="https://www.sfrattosicuro.it/grazie.html">

            <p class="text-xs text-dark-gray text-center">{contactForm.privacyNote}</p>

            <button type="submit" class="w-full btn-primary py-4 rounded-lg font-bold text-white text-lg btn-mobile-fix" aria-label="Richiedi richiamo rapido proprietario">
              Ti richiamiamo entro 2 ore
            </button>

            <p class="text-xs text-dark-gray text-center">✓ Solo proprietari / locatori • ✓ Richiamo rapido • ✓ Nessun impegno</p>
          </form>
        </div>

      </div>
    </div>
  </div>
</section>
