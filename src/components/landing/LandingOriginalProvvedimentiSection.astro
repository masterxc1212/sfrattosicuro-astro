---
// LandingOriginalProvvedimentiSection.astro — converted to carousel for better UX
const images = [
  { src: '/assets/img/provvedimenti/01.webp', alt: 'Provvedimento di Convalida di Sfratto - Tribunale Italiano' },
  { src: '/assets/img/provvedimenti/02.webp', alt: 'Provvedimento di Convalida di Sfratto - Tribunale Italiano' },
  { src: '/assets/img/provvedimenti/03.webp', alt: 'Provvedimento di Convalida di Sfratto - Tribunale Italiano' },
  { src: '/assets/img/provvedimenti/04.webp', alt: 'Provvedimento di Convalida di Sfratto - Tribunale Italiano' },
];
const carouselId = 'provvedimenti-carousel';
---
<section class="py-12 md:py-16" style="background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <div class="inline-block mb-4">
        <span
          class="bg-green-50 px-4 py-2 rounded-full text-sm font-bold border-2"
          style="background: rgba(59, 174, 93, 0.1); border-color: var(--green-security); color: var(--green-security);"
        >
          <i class="fas fa-gavel"></i> DOCUMENTAZIONE UFFICIALE
        </span>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: var(--blue-navy);">
        Provvedimenti ottenuti
      </h2>
      <p class="text-base md:text-lg max-w-3xl mx-auto" style="color: var(--anthracite); line-height: 1.6;">
        Alcuni esempi reali di provvedimenti di convalida ottenuti per i nostri clienti, mostrati in forma anonimizzata.
      </p>
    </div>

    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between gap-3 mb-4">
        <div class="text-sm text-dark-gray font-semibold">Scorri i provvedimenti</div>
        <div class="flex gap-2">
          <button type="button" class="btn-secondary" aria-label="Provvedimento precedente" onclick={`document.getElementById('${carouselId}').scrollBy({left:-280,behavior:'smooth'})`}>
            <i class="fas fa-chevron-left"></i>
          </button>
          <button type="button" class="btn-secondary" aria-label="Provvedimento successivo" onclick={`document.getElementById('${carouselId}').scrollBy({left:280,behavior:'smooth'})`}>
            <i class="fas fa-chevron-right"></i>
          </button>
        </div>
      </div>

      <div
        id={carouselId}
        class="flex gap-4 overflow-x-auto pb-4"
        style="scroll-snap-type:x mandatory; -webkit-overflow-scrolling: touch;"
      >
        {images.map((img, i) => (
          <div class="provvedimento-card group flex-shrink-0" style="scroll-snap-align:start; width:52%; flex-shrink:0;">
            <div
              class="relative overflow-hidden rounded-xl shadow-lg transition-all duration-300 hover:shadow-2xl"
              style="border: 3px solid var(--green-security); background: white;"
            >
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-contain transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
                width="300"
                height="400"
              >
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-100 sm:opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
                <div class="p-4 text-white">
                  <p class="font-bold text-sm">Convalida ottenuta</p>
                  <p class="text-xs mt-1 opacity-90">Provvedimento anonimizzato a tutela della privacy</p>
                </div>
              </div>
              <div
                class="absolute top-3 right-3 px-3 py-1 rounded-full text-xs font-bold shadow-md"
                style="background: var(--green-security); color: white;"
              >
                <i class="fas fa-check"></i> Reale
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
