---
// LandingOriginalReviewsSection.astro — 1:1 clone of original Google reviews section
// Source: public/landing/index.html
---
<section id="recensioni-google" class="py-16 bg-gradient-to-b from-gray-pearl to-white" aria-labelledby="recensioni-title">

  <div class="container mx-auto px-4">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-12">
        <div class="inline-flex items-center justify-center space-x-3 mb-6 bg-white px-4 sm:px-6 py-3 rounded-full shadow-lg border-2 border-gray-200">
          <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true" style="flex-shrink:0">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span class="font-bold text-gray-800 text-sm sm:text-base">Recensioni Google</span>
        </div>

        <h2 id="recensioni-title" class="text-2xl sm:text-3xl md:text-4xl font-bold text-blue-navy mb-4 px-4">
          Cosa Dicono i Proprietari che Abbiamo Aiutato
        </h2>
        <p class="text-base sm:text-lg md:text-xl text-dark-gray px-4">
          Recensioni autentiche e verificate dai nostri clienti
        </p>
      </div>

      <div id="google-rating-hero" class="bg-white border-3 border-green-security rounded-2xl p-6 sm:p-8 md:p-12 mb-8 sm:mb-12 text-center shadow-xl">
        <div class="text-6xl sm:text-7xl md:text-8xl font-bold text-green-security mb-3 sm:mb-4">
          <span id="rating-number">5.0</span>
        </div>
        <div class="text-3xl sm:text-4xl md:text-5xl mb-3 sm:mb-4 text-yellow-400" id="rating-stars" aria-label="5 stelle su 5">
          ★★★★★
        </div>
        <div class="text-lg sm:text-xl md:text-2xl font-semibold text-blue-navy mb-2">
          Eccellente
        </div>
        <div class="text-base sm:text-lg text-dark-gray mb-4 sm:mb-6">
          Basato su <strong id="total-reviews">8</strong> recensioni Google
        </div>
        <a
          href="https://www.google.com/search?kgmid=/g/11xzr2cjfr&hl=it-IT&q=Sfratto+Sicuro"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-semibold text-sm sm:text-base underline transition"
          style="touch-action:manipulation"
        >
          Vedi tutte le recensioni su Google
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/>
          </svg>
        </a>
      </div>

      <div id="google-reviews-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6" style="min-height:280px">
        <div class="review-skeleton animate-pulse" style="background:#f3f4f6;border-radius:1rem;height:250px"></div>
        <div class="review-skeleton animate-pulse hidden md:block" style="background:#f3f4f6;border-radius:1rem;height:250px"></div>
        <div class="review-skeleton animate-pulse hidden lg:block" style="background:#f3f4f6;border-radius:1rem;height:250px"></div>
      </div>

    </div>
  </div>

</section>
