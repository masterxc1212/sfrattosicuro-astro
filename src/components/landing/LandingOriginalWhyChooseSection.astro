---
// LandingOriginalWhyChooseSection.astro — 1:1 clone of original perche sceglierci section
// Source: public/landing/index.html
import { landingOriginal } from '../../data/landing-original';

const defaultPillars = [
  {
    icon: 'fa-network-wired',
    title: 'Rete Nazionale',
    body: 'Avvocati domiciliatari in ogni Tribunale d\'Italia per velocizzare ogni fase.',
  },
  {
    icon: 'fa-laptop',
    title: 'Sistema Digitale',
    body: 'Gestione completamente online con aggiornamenti automatici.',
  },
  {
    icon: 'fa-chart-line',
    title: 'Metodo Collaudato',
    body: 'Oltre 1.500 sfratti per morosità completati con successo. Ogni fase è stata ottimizzata.',
  },
  {
    icon: 'fa-headset',
    title: 'Supporto Dedicato',
    body: 'Un avvocato ti segue passo passo nella procedura, dalla convalida fino al rilascio se necessario.',
  }
];

interface Props {
  whyChooseUs?: typeof landingOriginal.whyChooseUs;
}

const { whyChooseUs = landingOriginal.whyChooseUs } = Astro.props;
const pillars = whyChooseUs.pillars?.length ? whyChooseUs.pillars : defaultPillars;
---
<section id={whyChooseUs.sectionId} class="py-14 md:py-16 bg-gray-pearl landing-v3-whychoose" aria-labelledby="perche-sceglierci-title">
  <div class="container mx-auto px-4">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-12 landing-v3-section-head">
        <h2 id="perche-sceglierci-title" class="text-3xl md:text-4xl font-bold text-blue-navy mb-6">
          {whyChooseUs.title}
        </h2>
        <p class="text-lg md:text-xl text-dark-gray">
          {whyChooseUs.subtitle}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
        {pillars.map(p => (
          <article class="text-center bg-white p-6 rounded-2xl card-shadow landing-v3-why-card">
            <div class="text-green-security text-4xl mb-4" aria-hidden="true">
              <i class={`fas ${p.icon}`}></i>
            </div>
            <h3 class="text-lg md:text-xl font-bold text-blue-navy mb-3">{p.title}</h3>
            <p class="text-dark-gray text-base">{p.body}</p>
          </article>
        ))}
      </div>

      <div class="text-center">
        <div class="bg-blue-navy text-white p-6 md:p-8 rounded-2xl inline-block max-w-4xl landing-v3-cta-panel">
          <h3 class="text-2xl md:text-3xl font-bold mb-4">
            <span class="text-gold-refined mr-3" aria-hidden="true">✅</span>
            {whyChooseUs.bottomTitle}
          </h3>
          <p class="text-lg md:text-XL mb-8">
            {whyChooseUs.bottomBody}
          </p>
          <a
            href="#contatti"
            class="btn-primary px-6 md:px-8 py-4 rounded-lg font-bold text-base md:text-lg btn-mobile-fix"
            aria-label="Richiedi una consulenza gratuita per beneficiare della nostra specializzazione"
          >
            <span class="mr-2" aria-hidden="true">✉️</span>
            {whyChooseUs.ctaLabel}
          </a>
          <p class="text-xs text-gray-300 mt-4">✓ {whyChooseUs.ctaCaption}</p>
        </div>
      </div>

    </div>
  </div>
</section>
