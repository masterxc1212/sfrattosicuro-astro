---
// LandingOriginalCostTransparencySection.astro — 1:1 clone of original cost transparency section
// Source: public/landing/index.html
import { landingOriginal } from '../../data/landing-original';

const defaultIncludedLeft = [
  'Consulenza e analisi del caso',
  'Predisposizione atti legali',
  'Contributo unificato per l\'iscrizione a ruolo',
  'Marche da bollo',
];
const defaultIncludedRight = [
  'Spese notifica',
  'Rappresentanza processuale in udienza',
  'Gestione completa fino alla convalida',
  'Assistenza e aggiornamenti costanti',
];

interface Props {
  costTransparency?: typeof landingOriginal.costTransparency;
}

const { costTransparency = landingOriginal.costTransparency } = Astro.props;
const includedLeft = costTransparency.includedItemsLeft?.length ? costTransparency.includedItemsLeft : defaultIncludedLeft;
const includedRight = costTransparency.includedItemsRight?.length ? costTransparency.includedItemsRight : defaultIncludedRight;
---
<section id={costTransparency.sectionId} class="py-16 bg-gray-pearl" aria-labelledby="costi-trasparenza-title">
  <a id={costTransparency.anchorId} class="sr-only" aria-hidden="true"></a>
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <div class="transparency-box p-8 rounded-lg card-shadow">

        <div class="text-center mb-8">
          <h2 id="costi-trasparenza-title" class="text-2xl md:text-3xl font-bold text-blue-navy mb-4">
            <i class="fas fa-hand-holding-heart text-green-security mr-3" aria-hidden="true"></i>
            {costTransparency.title}
          </h2>
          <p class="text-lg text-dark-gray">
            {costTransparency.subtitle}
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg mb-6">
          <h3 class="text-xl font-bold text-blue-navy mb-4">
            <i class="fas fa-euro-sign text-green-security mr-2" aria-hidden="true"></i>
            {costTransparency.priceTitle}
          </h3>
          <p class="text-dark-gray mb-4">
            <span set:html={costTransparency.priceBody}></span>
          </p>

          <div class="bg-green-50 p-4 rounded-lg mb-4">
            <h4 class="font-bold text-green-security mb-3">✅ {costTransparency.includedTitle}</h4>
            <p class="text-dark-gray text-base mb-3">
              <strong>{costTransparency.includedSubtitle}</strong>
            </p>
            <div class="grid md:grid-cols-2 gap-4 text-base">
              <ul class="space-y-1 text-dark-gray">
                {includedLeft.map(item => <li>{item}</li>)}
              </ul>
              <ul class="space-y-1 text-dark-gray">
                {includedRight.map(item => <li>{item}</li>)}
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
