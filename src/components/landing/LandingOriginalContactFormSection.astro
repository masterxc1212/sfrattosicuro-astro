---
// LandingOriginalContactFormSection.astro — 1:1 clone of original contact form section
// Source: public/landing/index.html
import { landingOriginal } from '../../data/landing-original';

interface Props {
  contactForm?: typeof landingOriginal.contactForm;
}

const { contactForm = landingOriginal.contactForm } = Astro.props;
---
<section id={contactForm.sectionId} class="py-16 bg-gray-pearl" aria-labelledby="contatti-heading">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">

      <div class="text-center mb-16">
        <h2 id="contatti-heading" class="text-3xl md:text-4xl font-bold text-blue-navy mb-6">
          {contactForm.title}
        </h2>
        <p class="text-lg md:text-xl text-dark-gray">
          {contactForm.subtitle}
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 md:gap-12">

        <!-- Form -->
        <div class="bg-white p-6 md:p-8 rounded-lg card-shadow">
          <h3 class="text-xl md:text-2xl font-bold text-blue-navy mb-6">
            {contactForm.formTitle}
          </h3>

          <form action="/php/invia-email.php" method="POST" class="space-y-6" aria-label="Form di richiesta consulenza">

            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="nome" class="block text-dark-gray font-semibold mb-2">{contactForm.fields.nome.label}</label>
                <input
                  type="text"
                  name="nome"
                  id="nome"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-green-security text-gray-800"
                  placeholder={contactForm.fields.nome.placeholder}
                  required
                  aria-required="true"
                >
              </div>
              <div>
                <label for="cognome" class="block text-dark-gray font-semibold mb-2">{contactForm.fields.cognome.label}</label>
                <input
                  type="text"
                  name="cognome"
                  id="cognome"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-green-security text-gray-800"
                  placeholder={contactForm.fields.cognome.placeholder}
                  required
                  aria-required="true"
                >
              </div>
            </div>

            <div>
              <label for="telefono" class="block text-dark-gray font-semibold mb-2">{contactForm.fields.telefono.label}</label>
              <input
                type="tel"
                name="telefono"
                id="telefono"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-green-security text-gray-800"
                placeholder={contactForm.fields.telefono.placeholder}
                required
                aria-required="true"
              >
            </div>

            <div>
              <label for="email" class="block text-dark-gray font-semibold mb-2">{contactForm.fields.email.label}</label>
              <input
                type="email"
                name="email"
                id="email"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-green-security text-gray-800"
                placeholder={contactForm.fields.email.placeholder}
                required
                aria-required="true"
              >
            </div>

            <div>
              <label for="citta" class="block text-dark-gray font-semibold mb-2">{contactForm.fields.citta.label}</label>
              <input
                type="text"
                name="città"
                id="citta"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-green-security text-gray-800"
                placeholder={contactForm.fields.citta.placeholder}
                required
                aria-required="true"
              >
            </div>

            <div>
              <label for="morosita" class="block text-dark-gray font-semibold mb-2">{contactForm.fields.morosita.label}</label>
              <select
                name="morosità"
                id="morosita"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-green-security text-gray-800"
                required
                aria-required="true"
              >
                {contactForm.fields.morosita.options.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </div>

            <div>
              <label for="note" class="block text-dark-gray font-semibold mb-2">{contactForm.fields.note.label}</label>
              <textarea
                name="note"
                id="note"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-green-security text-gray-800"
                rows="3"
                placeholder={contactForm.fields.note.placeholder}
              ></textarea>
            </div>

            <input type="hidden" name="form_source" value="bottom_form">
            <input type="hidden" name="gclid" value="">
            <input type="hidden" name="utm_source" value="">
            <input type="hidden" name="utm_medium" value="">
            <input type="hidden" name="utm_campaign" value="">
            <input type="hidden" name="utm_term" value="">
            <input type="hidden" name="keyword" value="">
            <input type="hidden" name="utm_content" value="">
            <input type="hidden" name="matchtype" value="">
            <input type="hidden" name="redirect_url" value="https://www.sfrattosicuro.it/grazie.html">

            <div class="text-center text-xs text-dark-gray mb-4">
              <p>{contactForm.privacyNote}</p>
            </div>

            <button
              type="submit"
              class="w-full btn-primary py-4 rounded-lg font-bold text-white text-lg btn-mobile-fix"
              aria-label="Invia richiesta di consulenza gratuita"
            >
              {contactForm.submitLabel}
            </button>

            <p class="text-xs text-dark-gray mt-4 text-center">✓ Gratuita, sicura e senza impegno</p>

          </form>

          <div class="mt-6 text-center text-sm text-dark-gray">
            {contactForm.formNote.split('\n').map((line) => (<p>{line}</p>))}
          </div>
        </div>

        <!-- Contact info -->
        <div class="space-y-8">

          <div class="bg-blue-navy text-white p-6 md:p-8 rounded-lg">
            <h3 class="text-xl md:text-2xl font-bold mb-6">
              Contatti Diretti
            </h3>

            <div class="space-y-6">
              <div>
                <h4 class="font-bold text-lg mb-1">{contactForm.contacts.phoneLabel}</h4>
                <p class="text-gray-300 text-lg">
                  <a href="tel:+390280898395" class="hover:text-gold-refined font-bold">{contactForm.contacts.phoneValue}</a>
                </p>
                <p class="text-gray-400 text-sm mt-1">{contactForm.contacts.phoneHours}</p>
              </div>

              <hr class="border-white/10">

              <div>
                <h4 class="font-bold text-lg mb-1">{contactForm.contacts.whatsappLabel}</h4>
                <p class="text-gray-300 text-lg">
                  <a href="https://wa.me/393291175957" target="_blank" rel="noopener noreferrer" class="hover:text-gold-refined font-bold">{contactForm.contacts.whatsappValue}</a>
                </p>
                <p class="text-gray-400 text-sm mt-1">{contactForm.contacts.whatsappNote}</p>
              </div>

              <hr class="border-white/10">

              <div>
                <h4 class="font-bold text-lg mb-1">{contactForm.contacts.emailLabel}</h4>
                <p class="text-gray-300 text-lg">
                  <a href="mailto:consulenza@sfrattosicuro.it" class="hover:text-gold-refined font-bold">{contactForm.contacts.emailValue}</a>
                </p>
                <p class="text-gray-400 text-sm mt-1">{contactForm.contacts.emailNote}</p>
              </div>
            </div>
          </div>

          <div class="bg-yellow-50 border border-gold-refined p-6 rounded-lg">
            <h4 class="font-bold text-blue-navy mb-3">
              {contactForm.urgencyBox.title}
            </h4>
            <p class="text-dark-gray text-base">
              <span set:html={contactForm.urgencyBox.body}></span>
            </p>
          </div>

        </div>

      </div>

    </div>
  </div>
</section>
