---
// LandingOriginalHeaderSection.astro — 1:1 clone of original header
// Source: public/landing/index.html
---
<header
  id="site-header"
  class="bg-white shadow-md fixed w-full top-0 z-50 border-b-2 border-green-security"
>
  <div class="container mx-auto px-4">
    <div class="flex justify-between items-center">
      <a href="/" aria-label="Sfratto Sicuro - Torna alla home" class="logo-container" style="gap: 0.2rem;">
        <picture>
          <source media="(min-width: 768px)" srcset="/assets/img/logo/logo-200.webp" width="88" height="88">
          <source media="(min-width: 640px)" srcset="/assets/img/logo/logo-150.webp" width="70" height="70">
          <img
            src="/assets/img/logo/logo-100.webp"
            alt="Sfratto Sicuro - Avvocati Specializzati in Sfratto per Morosità"
            class="logo-main-image"
            style="height: 80px; width: auto;"
            width="50"
            height="50"
            fetchpriority="high"
            decoding="sync"
            loading="eager"
          >
        </picture>
        <div class="logo-text-container">
          <div class="logo-sub-text" style="font-size: 1rem; font-weight: 700; color: var(--blue-navy);">Avvocati Specializzati</div>
        </div>
      </a>

      <div class="header-contacts">
        <div class="phone-number-desktop">
          <i class="fas fa-phone text-green-security" aria-hidden="true"></i>
          <div>
            <a
              href="tel:+390280898395"
              style="font-weight: 700; font-size: 1.125rem; color: var(--blue-navy);"
              class="hover:text-green-security"
              aria-label="Chiama il numero 02 8089 8395"
            >02 8089 8395</a>
          </div>
        </div>

        <a
          href="tel:+390280898395"
          class="btn-call-header md:hidden"
          style="display:flex !important; align-items:center !important; justify-content:center !important; gap:0 !important; padding:0.6rem 0.75rem !important; background:#3BAE5D !important; color:#FFFFFF !important; border-radius:0.5rem !important; font-weight:700 !important; text-decoration:none !important; min-height:44px !important; font-size:0.875rem !important;"
          aria-label="Chiama ora"
        >
          <span style="color:#FFFFFF !important; -webkit-text-fill-color:#FFFFFF !important;">Chiama</span>
        </a>
      </div>
    </div>
  </div>
</header>
