---
// LandingOriginalLegalCostSection.astro — 1:1 clone of original rimborso spese section
// Source: public/landing/index.html
import { landingOriginal } from '../../data/landing-original';

interface Props {
  legalCost?: typeof landingOriginal.legalCost;
}

const { legalCost = landingOriginal.legalCost } = Astro.props;
---
<section id={legalCost.sectionId} class="py-16 bg-white" aria-labelledby="rimborso-spese-title">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <div class="transparency-box p-6 sm:p-8 rounded-lg card-shadow text-center border-green-security">

        <div class="text-green-security text-3xl sm:text-4xl mb-4" aria-hidden="true">
          💰
        </div>

        <h2 id="rimborso-spese-title" class="text-2xl md:text-3xl font-bold text-blue-navy mb-4">
          {legalCost.title}
        </h2>

        <p class="text-base sm:text-lg text-dark-gray leading-relaxed">
          {legalCost.body}
        </p>

      </div>
    </div>
  </div>
</section>
