---
// LandingOriginalMiniWidgetSection.astro — 1:1 clone of original mini rating widget
// Source: public/landing/index.html
---
<section class="pt-6 sm:pt-8 bg-gray-pearl">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <div class="bg-gradient-to-r from-green-50 to-blue-50 border-3 border-green-security p-5 sm:p-6 md:p-8 rounded-xl shadow-lg">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 sm:gap-6">
          <div class="flex items-center gap-4 sm:gap-6">
            <div id="mini-widget-rating" class="text-5xl sm:text-6xl font-bold text-green-security flex-shrink-0">
              5.0
            </div>
            <div>
              <div id="mini-widget-stars" class="text-2xl sm:text-3xl text-yellow-400 mb-1" aria-label="5 stelle su 5">★★★★★</div>
              <div class="text-xs sm:text-sm text-dark-gray font-semibold">
                <span id="mini-widget-total">8</span> recensioni Google
              </div>
            </div>
          </div>
          <div class="text-center sm:text-right">
            <div class="font-bold text-blue-navy text-base sm:text-lg mb-1">
              Oltre 1.500 proprietari soddisfatti
            </div>
            <div class="text-sm sm:text-base text-dark-gray">
              si sono già affidati a noi con successo
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
