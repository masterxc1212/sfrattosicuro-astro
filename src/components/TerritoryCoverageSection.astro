---
import sedi from '../data/sedi.json';

interface SedeItem { nome: string; slug: string; tribunale?: string; areaServita?: string; }
interface Props { sedeSlug?: string; }

const { sedeSlug = 'nazionale' } = Astro.props;
const normalized = sedeSlug.trim().toLowerCase();
const isNazionale = normalized === 'nazionale';
const sede = (sedi as SedeItem[]).find((item) => item.slug === normalized);

const nome = sede?.nome ?? 'la tua città';
const tribunale = sede?.tribunale ?? `Tribunale di ${nome}`;
const areaServita = sede?.areaServita ?? `${nome} e provincia`;
---

{!isNazionale && sede && (
  <section class="section" id="copertura-territoriale" aria-labelledby="coverage-title">
    <div class="container">
      <h2 id="coverage-title">Assistenza legale per sfratto a {nome} e provincia</h2>
      <article class="card">
        <p>Lo studio assiste proprietari di immobili situati a {areaServita}.</p>
        <p>Le procedure di sfratto relative a questi immobili vengono gestite presso il {tribunale}.</p>
      </article>
    </div>
  </section>
)}

<style>
  .section { padding: 56px 0; }
  h2 { margin: 0 0 22px; color: var(--blue-navy); }
  p { margin: 0 0 14px; line-height: 1.6; color: var(--text-body); }
  .card { background: #fff; border-radius: 10px; padding: 24px; box-shadow: 0 4px 12px rgba(0,0,0,.05); border: 1px solid var(--border-light); }
  .card p:last-child { margin-bottom: 0; }
  @media (max-width: 1024px) { .section { padding: 44px 0; } }
  @media (max-width: 767px) { .section { padding: 32px 0; } }
</style>
