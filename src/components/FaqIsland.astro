---
const faqItems = [
  {
    q: 'Quanto dura una procedura di sfratto per morosità',
    a: 'Mediamente la convalida può arrivare in circa 60 giorni, con variazioni legate al tribunale competente e alle specificità del caso.'
  },
  {
    q: 'Qual è il costo del servizio',
    a: 'Per il servizio standard è previsto un costo fisso chiaro, senza sorprese in corso d’opera.'
  },
  {
    q: 'Operate in tutta Italia',
    a: 'Sì, grazie alla rete di domiciliatari operiamo presso i tribunali su tutto il territorio nazionale.'
  }
];
---

<section id="faq" class="block">
  <h2 id="faq-section-title">Domande frequenti</h2>
  <div class="faq-list" data-faq-root>
    {faqItems.map((item, i) => (
      <article class="faq-item">
        <button class="faq-q" type="button" aria-expanded={i === 0 ? 'true' : 'false'} data-faq-trigger>
          <span>{item.q}</span>
          <span aria-hidden="true">+</span>
        </button>
        <div class={`faq-a ${i === 0 ? 'open' : ''}`} data-faq-panel>
          <p>{item.a}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<script>
(() => {
  const root = document.querySelector('[data-faq-root]');
  if (!root) return;
  const triggers = root.querySelectorAll('[data-faq-trigger]');

  triggers.forEach((btn) => {
    btn.addEventListener('click', () => {
      const panel = btn.parentElement.querySelector('[data-faq-panel]');
      const isOpen = panel.classList.contains('open');
      panel.classList.toggle('open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });
})();
</script>

