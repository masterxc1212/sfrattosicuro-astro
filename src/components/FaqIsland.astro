---

<section id="faq" class="block">
  <h2 id="faq-section-title">Domande frequenti</h2>
  <div class="faq-list" data-faq-root>
    {faqItems.map((item, i) => (
      <article class="faq-item">
        <button class="faq-q" type="button" aria-expanded={i === 0 ? 'true' : 'false'} data-faq-trigger>
          <span>{item.q}</span>
          <span aria-hidden="true">+</span>
        </button>
        <div class={`faq-a ${i === 0 ? 'open' : ''}`} data-faq-panel>
          <p>{item.a}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<script>
(() => {
  const root = document.querySelector('[data-faq-root]');
  if (!root) return;
  const triggers = root.querySelectorAll('[data-faq-trigger]');

  triggers.forEach((btn) => {
    btn.addEventListener('click', () => {
      const panel = btn.parentElement.querySelector('[data-faq-panel]');
      const isOpen = panel.classList.contains('open');
      panel.classList.toggle('open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });
})();
</script>

<style>
  .block { margin: 2.5rem 0; padding: 1.2rem; border: 1px solid #e7edf5; border-radius: 12px; }
  .faq-list { display: grid; gap: .7rem; }
  .faq-item { border: 1px solid #e4ebf5; border-radius: 10px; overflow: hidden; }
  .faq-q { width: 100%; text-align: left; border: none; background:#fff; padding: .85rem; font-weight: 700; color: var(--blue-navy); display:flex; justify-content:space-between; }
  .faq-a { display:none; padding: .8rem; border-top: 1px solid #eef2f7; color:#334155; }
  .faq-a.open { display:block; }
</style>

