---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/chi-siamo/', label: 'Chi siamo' },
  { href: '/servizi/', label: 'Servizi' },
  { href: '/sedi/', label: 'Sedi' },
  { href: '/blog/', label: 'Blog' }
];

const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<header id="site-header" class="site-header">
  <div class="container">
    <div class="header-row">
      <a href="/" aria-label="Sfratto Sicuro - Torna alla home" class="logo-container">
        <img
          src="https://www.sfrattosicuro.it/assets/img/logo/logo-200.webp"
          alt="Sfratto Sicuro - Avvocati Specializzati"
          class="logo-main-image"
          width="88"
          height="88"
          fetchpriority="high"
          decoding="sync"
          loading="eager"
        />
        <div class="logo-text-container">
          <div class="logo-sub-text">Avvocati Specializzati</div>
        </div>
      </a>

      <button
        class="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-nav-toggle
      >
        Menu
      </button>

      <nav class="desktop-nav" aria-label="Navigazione principale">
        <ul>
          {navItems.map((item) => (
            <li>
              <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <nav id="mobile-menu" class="mobile-nav" aria-label="Navigazione mobile" data-mobile-menu>
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const btn = document.querySelector('[data-nav-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    border-bottom: 2px solid var(--green-security);
    box-shadow: 0 2px 8px rgba(27, 41, 81, 0.1);
  }

  .container {
    width: min(1200px, 92%);
    margin: 0 auto;
  }

  .header-row {
    min-height: 84px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo-container {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
  }

  .logo-main-image {
    width: auto;
    height: 64px;
    object-fit: contain;
  }

  .logo-sub-text {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--blue-navy);
    line-height: 1.1;
  }

  .desktop-nav {
    display: none;
  }

  .desktop-nav ul,
  .mobile-nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .desktop-nav a,
  .mobile-nav a {
    text-decoration: none;
    color: var(--blue-navy);
    font-weight: 600;
  }

  .desktop-nav a.active,
  .mobile-nav a.active {
    color: var(--green-security);
  }

  .nav-toggle {
    border: 1px solid #dbe3f0;
    background: #fff;
    color: var(--blue-navy);
    border-radius: 0.5rem;
    padding: 0.55rem 0.9rem;
    font-weight: 700;
    cursor: pointer;
  }

  .mobile-nav {
    display: none;
    padding: 0.5rem 0 1rem;
  }

  .mobile-nav.is-open {
    display: block;
  }

  .mobile-nav a {
    display: block;
    padding: 0.7rem 0;
    border-bottom: 1px solid #edf2f7;
  }

  @media (min-width: 900px) {
    .nav-toggle,
    .mobile-nav {
      display: none !important;
    }

    .desktop-nav {
      display: block;
    }

    .desktop-nav ul {
      display: flex;
      align-items: center;
      gap: 1.2rem;
    }
  }
</style>

