---
const steps = [
  {
    title: 'Analisi preliminare del caso',
    text: 'Valutiamo la documentazione, la situazione locativa e le possibili criticità per impostare correttamente la tutela del proprietario.'
  },
  {
    title: 'Valutazione della procedura',
    text: 'Definiamo il percorso più efficace tra procedura di sfratto, recupero canoni e azioni complementari in materia di locazione.'
  },
  {
    title: 'Assistenza durante il procedimento',
    text: 'Seguiamo il proprietario in tutte le fasi della procedura con aggiornamenti continui e gestione operativa delle attività.'
  },
  {
    title: 'Supporto fino alla liberazione dell’immobile',
    text: 'Proseguiamo l’assistenza fino al rilascio dell’immobile e alla chiusura della pratica nelle sue fasi finali.'
  }
];
---

<section class="section services-method-section" id="metodo-servizi" aria-labelledby="services-method-title">
  <div class="container">
    <p class="kicker">Metodo operativo</p>
    <h2 id="services-method-title">Come lavoriamo</h2>

    <div class="cards-grid" role="list">
      {steps.map((step, index) => (
        <article class="card" role="listitem">
          <p class="step-num">{String(index + 1).padStart(2, '0')}</p>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-method-section {
    background: #f7f9fc;
    border-top: 1px solid #e5edf8;
    border-bottom: 1px solid #e5edf8;
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .kicker {
    margin: 0 0 8px;
    color: #c6902a;
    text-transform: uppercase;
    letter-spacing: .05em;
    font-size: .78rem;
    font-weight: 700;
  }
  h2 { margin: 0 0 18px; color: var(--blue-navy); }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .card {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #fff;
    padding: 22px;
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.05);
    position: relative;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, #1b2951 0%, #3bae5d 100%);
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
  }

  .step-num {
    margin: 0 0 8px;
    color: #1b2951;
    font-weight: 800;
    letter-spacing: .04em;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: #eef3fb;
    border: 1px solid #d8e1ef;
  }

  h3 { margin: 0 0 10px; color: var(--blue-navy); font-size: 1.05rem; }
  p { margin: 0; color: #334155; line-height: 1.65; }

  @media (max-width: 1024px) { .cards-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 767px) {
    .container { padding: 0 16px; }
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>
