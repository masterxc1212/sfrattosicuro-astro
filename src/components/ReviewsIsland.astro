<section id="recensioni-google" class="section">
  <div class="container">
    <h2>Recensioni Google</h2>

    <div class="reviews-layout">
      <aside class="summary-card" aria-label="Valutazione media su Google">
        <p class="google-badge">Google Reviews</p>
        <p class="score"><span id="rating-number">5.0</span></p>
        <p class="stars" id="rating-stars">★★★★★</p>
        <p class="summary-title">Valutazione media 5.0</p>
        <p class="summary-sub">Basato su <strong id="total-reviews">0</strong> recensioni verificate.</p>
        <a href="#contatti" class="btn-primary">Richiedi consulenza</a>
      </aside>

      <div id="google-reviews-grid" class="review-grid" style="min-height: 180px;">
        <div class="review-skeleton"></div>
        <div class="review-skeleton"></div>
        <div class="review-skeleton"></div>
        <div class="review-skeleton"></div>
      </div>
    </div>
  </div>
</section>

<script>
(() => {
  const grid = document.getElementById('google-reviews-grid');
  if (!grid) return;

  const initials = (name) => (name || '').trim().split(/\s+/).map(v => v[0] || '').join('').slice(0,2).toUpperCase() || 'G';
  const starsText = (n) => '★'.repeat(Math.max(1, Math.min(5, Number(n || 5))));

  const updateSummary = (rating, total) => {
    const r = Number(rating || 5).toFixed(1);
    const rn = document.getElementById('rating-number');
    const tr = document.getElementById('total-reviews');
    const rs = document.getElementById('rating-stars');
    if (rn) rn.textContent = r;
    if (tr) tr.textContent = String(Number(total || 0));
    if (rs) rs.textContent = starsText(rating);
  };

  const render = (reviews) => {
    if (!reviews || !reviews.length) {
      grid.innerHTML = '<p>Nessuna recensione disponibile.</p>';
      return;
    }
    grid.innerHTML = reviews.slice(0, 4).map((r) => {
      const author = r.author || r.author_name || 'Utente Google';
      const text = (r.text || r.content || '').toString();
      const clipped = text.length > 180 ? text.slice(0, 180).trim() + '…' : text;
      const stars = starsText(r.rating || 5);
      return `<article class="card">
        <div class="head">
          <div class="avatar">${initials(author)}</div>
          <div>
            <strong>${author}</strong>
            <div class="meta">${r.time || r.relative_time || ''}</div>
          </div>
        </div>
        <div class="stars-row">${stars}</div>
        <p>"${clipped}"</p>
      </article>`;
    }).join('');
  };

  const handle = (data) => {
    updateSummary(data.rating, data.total_reviews ?? data.total);
    render(Array.isArray(data.reviews) ? data.reviews : []);
  };

  fetch('/php/get-reviews.php?refresh=1&t=' + Date.now(), { credentials: 'same-origin' })
    .then(r => (r.ok ? r.json() : Promise.reject()))
    .then(handle)
    .catch(() => fetch('/assets/data/reviews-cache.json?t=' + Date.now(), { credentials: 'same-origin' })
      .then(r => (r.ok ? r.json() : Promise.reject()))
      .then(handle)
      .catch(() => { grid.innerHTML = '<p>Errore caricamento recensioni.</p>'; }));
})();
</script>

<style>
  .section { padding: 56px 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  h2 { margin: 0 0 22px; color: var(--blue-navy); }

  .reviews-layout { display: grid; grid-template-columns: .9fr 1.1fr; gap: 24px; align-items: start; }

  .summary-card {
    background: #fff;
    border-radius: 12px;
    padding: 30px;
    box-shadow: 0 4px 10px rgba(0,0,0,.05);
    border: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }
  .google-badge { margin: 0; font-size: 12px; letter-spacing: .04em; text-transform: uppercase; color: #64748b; font-weight: 700; }
  .score { margin: 0; font-size: 36px; font-weight: 700; color: var(--blue-navy); line-height: 1; }
  .stars { margin: 0; color: #f4b400; font-size: 20px; letter-spacing: .1em; }
  .summary-title { margin: 0; color: var(--blue-navy); font-weight: 700; }
  .summary-sub { margin: 0 0 8px; color: #64748b; line-height: 1.6; }

  .btn-primary { background:#22c55e; color:#fff; border-radius:8px; padding:14px 24px; font-weight:600; text-decoration:none; }
  .btn-primary:hover { background:#16a34a; }

  .review-grid { display:grid; grid-template-columns: repeat(2,1fr); gap: 16px; }
  .review-skeleton { height: 148px; border-radius: 12px; background: #eef2f7; }
  .card { border: 1px solid #e5e7eb; border-radius: 12px; padding: 20px; background: #fff; min-height: 170px; box-shadow: 0 4px 10px rgba(0,0,0,.04); }
  .head { display:flex; gap:10px; align-items:center; }
  .avatar { width:34px; height:34px; border-radius:999px; background:#1b2951; color:#fff; display:grid; place-items:center; font-size:.8rem; }
  .meta { font-size: 12px; color: #6b7280; }
  .stars-row { color:#f4b400; margin: 8px 0; font-size: 14px; }
  .card p { margin: 0; font-size: 14px; line-height: 1.6; color: #374151; }

  @media (max-width: 1024px) { .section { padding: 44px 0; } .reviews-layout { grid-template-columns: 1fr; } }
  @media (max-width: 767px) {
    .section { padding: 36px 0; }
    .review-grid { grid-template-columns: 1fr; }
    .review-grid .card:nth-child(n+3) { display: none; }
    .review-skeleton:nth-child(n+3) { display: none; }
    .summary-card { padding: 22px; }
  }
</style>
