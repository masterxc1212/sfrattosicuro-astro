<section id="recensioni-google" class="section">
  <div class="container">
    <h2>Recensioni Google</h2>

    <div class="reviews-layout">
      <aside class="summary-card" aria-label="Valutazione media su Google">
        <p class="google-badge">Google Reviews</p>
        <p class="score"><span id="rating-number">5.0</span></p>
        <p class="stars" id="rating-stars">★★★★★</p>
        <p class="summary-title">Valutazione media 5.0</p>
        <p class="summary-sub">Basato su <strong id="total-reviews">0</strong> recensioni verificate.</p>
        <a href="#contatti" class="btn-primary">Richiedi consulenza</a>
      </aside>

      <div id="google-reviews-grid" class="review-grid" style="min-height: 180px;">
        <div class="review-skeleton"></div>
        <div class="review-skeleton"></div>
        <div class="review-skeleton"></div>
        <div class="review-skeleton"></div>
      </div>
    </div>
  </div>
</section>

<script>
(() => {
  const grid = document.getElementById('google-reviews-grid');
  if (!grid) return;

  const initials = (name) => (name || '').trim().split(/\s+/).map(v => v[0] || '').join('').slice(0,2).toUpperCase() || 'G';
  const starsText = (n) => '★'.repeat(Math.max(1, Math.min(5, Number(n || 5))));

  const updateSummary = (rating, total) => {
    const r = Number(rating || 5).toFixed(1);
    const rn = document.getElementById('rating-number');
    const tr = document.getElementById('total-reviews');
    const rs = document.getElementById('rating-stars');
    if (rn) rn.textContent = r;
    if (tr) tr.textContent = String(Number(total || 0));
    if (rs) rs.textContent = starsText(rating);
  };

  const render = (reviews) => {
    if (!reviews || !reviews.length) {
      grid.innerHTML = '<p>Nessuna recensione disponibile.</p>';
      return;
    }
    grid.innerHTML = reviews.slice(0, 4).map((r) => {
      const author = r.author || r.author_name || 'Utente Google';
      const text = (r.text || r.content || '').toString();
      const clipped = text.length > 180 ? text.slice(0, 180).trim() + '…' : text;
      const stars = starsText(r.rating || 5);
      return `<article class="card">
        <div class="head">
          <div class="avatar">${initials(author)}</div>
          <div>
            <strong>${author}</strong>
            <div class="meta">${r.time || r.relative_time || ''}</div>
          </div>
        </div>
        <div class="stars-row">${stars}</div>
        <p>"${clipped}"</p>
      </article>`;
    }).join('');
  };

  const handle = (data) => {
    updateSummary(data.rating, data.total_reviews ?? data.total);
    render(Array.isArray(data.reviews) ? data.reviews : []);
  };

  fetch('/php/get-reviews.php?refresh=1&t=' + Date.now(), { credentials: 'same-origin' })
    .then(r => (r.ok ? r.json() : Promise.reject()))
    .then(handle)
    .catch(() => fetch('/assets/data/reviews-cache.json?t=' + Date.now(), { credentials: 'same-origin' })
      .then(r => (r.ok ? r.json() : Promise.reject()))
      .then(handle)
      .catch(() => { grid.innerHTML = '<p>Errore caricamento recensioni.</p>'; }));
})();
</script>

