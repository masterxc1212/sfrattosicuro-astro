<section id="video-recensioni" class="section">
  <div class="container">
    <h2>Video Recensioni</h2>

    <div id="videoGrid" class="video-grid">
      <div class="video-skeleton"></div>
      <div class="video-skeleton"></div>
    </div>
    <p id="videoStatus" class="muted" role="status" aria-live="polite"></p>
  </div>
</section>

<script>
(async () => {
  const API_KEY = 'AIzaSyCHsDTZf-Dmrce1mPnCIqEs3832dIbB25g';
  const PLAYLIST_ID = 'PLwgun_cZLsXop3lhU9hEYwDkK-p3ppcQ7';
  const grid = document.getElementById('videoGrid');
  const status = document.getElementById('videoStatus');
  if (!grid) return;

  const openVideo = (videoId, card) => {
    const player = card?.querySelector('.video-player');
    if (!player) return;
    player.innerHTML = `<iframe class="video-iframe" src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0" allowfullscreen allow="autoplay; encrypted-media" title="Video recensione" loading="lazy"></iframe>`;
  };

  try {
    const res = await fetch(`https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&maxResults=6&playlistId=${PLAYLIST_ID}&key=${API_KEY}`);
    const data = await res.json();
    const videos = Array.isArray(data.items)
      ? data.items
          .map((item) => ({
            videoId: item?.snippet?.resourceId?.videoId,
            title: item?.snippet?.title || 'Video recensione',
            thumb: item?.snippet?.thumbnails?.high?.url || ''
          }))
          .filter((v) => v.videoId)
      : [];

    if (!videos.length) {
      if (status) status.textContent = 'Nessuna video recensione disponibile al momento.';
      return;
    }

    grid.innerHTML = videos
      .slice(0, 6)
      .map(
        (v) => `<article class="video-card" data-video-id="${v.videoId}">
          <button class="video-player" aria-label="Apri video ${v.title}">
            <img src="${v.thumb}" alt="${v.title}" loading="lazy" />
            <span>▶</span>
          </button>
        </article>`
      )
      .join('');

    grid.querySelectorAll('.video-card').forEach((card) => {
      const btn = card.querySelector('.video-player');
      const videoId = card.getAttribute('data-video-id');
      btn?.addEventListener('click', () => openVideo(videoId, card));
    });
  } catch {
    if (status) status.textContent = 'Errore nel caricamento video.';
  }
})();
</script>

<style>
  h2 { margin: 0 0 22px; color: var(--blue-navy); }

  .video-grid { display: grid; gap: 24px; grid-template-columns: repeat(2, 1fr); }
  .video-skeleton { border-radius: 14px; background: #edf2f7; aspect-ratio: 16/9; }
  .video-card { border-radius: 14px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.08); }
  .video-player { position: relative; border: none; width: 100%; cursor: pointer; background: #000; padding: 0; display: block; }
  .video-player img,
  .video-iframe { width: 100%; height: 100%; display: block; aspect-ratio: 16/9; object-fit: cover; }
  .video-player span { position: absolute; inset: auto auto 10px 10px; background: rgba(0,0,0,.62); color:#fff; border-radius: 99px; padding: .2rem .5rem; }
  .muted { margin-top: 16px; color:#64748b; }

  @media (max-width: 767px){ .video-grid{grid-template-columns:1fr;} }
</style>
