---
interface JumpItem {
  href: string;
  label: string;
}

interface Props {
  items: JumpItem[];
  title?: string;
}

const { items = [], title = 'Naviga la pagina' } = Astro.props;
const visibleItems = items.filter((item) => item?.href && item?.label);
if (!visibleItems.length) {
  return null;
}
---

<nav class="jump-nav" aria-label={title}>
  <div class="jump-nav__inner">
    <p class="jump-nav__title">{title}</p>
    <ul>
      {visibleItems.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .jump-nav {
    position: sticky;
    top: 72px;
    z-index: 18;
    background: #fff;
    border-top: 1px solid #edf2f7;
    border-bottom: 1px solid #edf2f7;
  }

  .jump-nav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 8px 24px;
    display: grid;
    gap: 8px;
  }

  .jump-nav__title {
    margin: 0;
    color: #64748b;
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .05em;
    font-weight: 700;
  }

  .jump-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .jump-nav a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    border-radius: 999px;
    border: 1px solid #dbe3f0;
    background: #f8fbff;
    color: #1e3a8a;
    text-decoration: none;
    font-size: .9rem;
    font-weight: 600;
    line-height: 1.1;
    padding: 10px 14px;
  }

  .jump-nav a:hover,
  .jump-nav a:focus-visible {
    background: #eaf2ff;
    border-color: #bfd3f0;
    outline: none;
  }

  @media (max-width: 900px) {
    .jump-nav {
      position: static;
      border-top: 0;
    }

    .jump-nav__inner {
      padding: 10px 16px;
    }

    .jump-nav a {
      min-height: 44px;
      font-size: .92rem;
      padding: 11px 14px;
    }
  }
</style>
