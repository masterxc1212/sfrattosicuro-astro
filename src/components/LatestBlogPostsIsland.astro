---
import BlogCard from './blog/BlogCard.astro';
import { getLatestBlogPosts } from '../data/blog-posts';

const latestPosts = getLatestBlogPosts(3);
---

<section class="blog-latest" aria-labelledby="blog-latest-title">
  <div class="container">
    <div class="topbar">
      <div>
        <p class="eyebrow">Dal blog</p>
        <h2 id="blog-latest-title">Ultimi approfondimenti su sfratti e locazioni</h2>
        <p class="sub">
          Aggiornamenti pratici, casi ricorrenti e guide operative scritte in modo chiaro per proprietari e amministratori.
        </p>
      </div>
      <a class="all-link" href="/blog/">Vedi tutti gli articoli →</a>
    </div>

    <div class="cards">
      {latestPosts.map((post) => <BlogCard post={post} compact />)}
    </div>
  </div>
</section>

