---
import BlogCard from './blog/BlogCard.astro';
import { blogPosts } from '../data/blog-posts';

const latestPosts = blogPosts.slice(0, 3);
---

<section class="blog-latest" aria-labelledby="blog-latest-title">
  <div class="container">
    <div class="topbar">
      <div>
        <p class="eyebrow">Dal blog</p>
        <h2 id="blog-latest-title">Ultimi approfondimenti su sfratti e locazioni</h2>
        <p class="sub">
          Aggiornamenti pratici, casi ricorrenti e guide operative scritte in modo chiaro per proprietari e amministratori.
        </p>
      </div>
      <a class="all-link" href="/blog/">Vedi tutti gli articoli →</a>
    </div>

    <div class="cards">
      {latestPosts.map((post) => <BlogCard post={post} compact />)}
    </div>
  </div>
</section>

<style>
  .blog-latest {
    background: linear-gradient(180deg, #f7fbff 0%, #eef4fb 100%);
    border-top: 1px solid #e2eaf6;
    border-bottom: 1px solid #e2eaf6;
    padding: 44px 0;
  }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .topbar { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; margin-bottom: 20px; }
  .eyebrow { margin: 0 0 6px; font-size: .78rem; letter-spacing: .06em; text-transform: uppercase; color: #c6902a; font-weight: 700; }
  h2 { margin: 0; color: var(--blue-navy); font-size: clamp(1.45rem, 2.2vw, 1.95rem); }
  .sub { margin: 8px 0 0; color: #3d4b65; max-width: 68ch; line-height: 1.65; }
  .all-link { text-decoration: none; color: #1b376b; font-weight: 700; white-space: nowrap; }
  .cards { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; }
  @media (max-width: 980px) {
    .topbar { flex-direction: column; align-items: flex-start; }
    .cards { grid-template-columns: 1fr; }
  }
</style>
