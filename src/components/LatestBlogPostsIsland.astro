---
const FALLBACK_POSTS = [
  {
    id: 1,
    title: 'Guida pratica: sfratto per morosità nel 2026',
    excerpt: 'Panoramica essenziale su tempi, passaggi e documenti utili per avviare correttamente la procedura.',
    link: 'https://sfrattosicuro.it/blog/',
    date: 'Nuovo articolo'
  },
  {
    id: 2,
    title: 'Sfratto per finita locazione: quando e come agire',
    excerpt: 'Checklist operativa per gestire la chiusura del contratto e la restituzione dell’immobile senza errori.',
    link: 'https://sfrattosicuro.it/blog/',
    date: 'Nuovo articolo'
  },
  {
    id: 3,
    title: 'Morosità inquilino: cosa fare nei primi 30 giorni',
    excerpt: 'Le azioni iniziali che possono ridurre tempi e costi prima dell’avvio dell’azione giudiziale.',
    link: 'https://sfrattosicuro.it/blog/',
    date: 'Nuovo articolo'
  }
];
---

<section class="blog-latest" aria-labelledby="blog-latest-title">
  <div class="container">
    <div class="topbar">
      <div>
        <p class="eyebrow">Dal blog</p>
        <h2 id="blog-latest-title">Ultimi approfondimenti su sfratti e locazioni</h2>
        <p class="sub">
          Aggiornamenti pratici, casi ricorrenti e guide operative scritte in modo chiaro per proprietari e amministratori.
        </p>
      </div>
      <a class="all-link" href="https://sfrattosicuro.it/blog/" target="_blank" rel="noopener noreferrer">Vedi tutti gli articoli →</a>
    </div>

    <div class="cards" id="latest-blog-posts">
      {FALLBACK_POSTS.map((post) => (
        <article class="card" data-post-id={post.id}>
          <p class="meta">{post.date}</p>
          <h3>{post.title}</h3>
          <p>{post.excerpt}</p>
          <a href={post.link} target="_blank" rel="noopener noreferrer">Leggi articolo</a>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
(() => {
  const container = document.getElementById('latest-blog-posts');
  if (!container) return;

  const decode = (value = '') => {
    const txt = document.createElement('textarea');
    txt.innerHTML = value || '';
    return txt.value;
  };

  const stripHtml = (html = '') => {
    const div = document.createElement('div');
    div.innerHTML = html || '';
    return (div.textContent || div.innerText || '').trim();
  };

  const escapeHtml = (value = '') =>
    value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

  const formatDate = (date) => {
    try {
      return new Intl.DateTimeFormat('it-IT', {
        day: '2-digit',
        month: 'long',
        year: 'numeric'
      }).format(new Date(date));
    } catch {
      return 'Nuovo articolo';
    }
  };

  const render = (posts) => {
    if (!Array.isArray(posts) || !posts.length) return;

    container.innerHTML = posts.map((post) => {
      const title = escapeHtml(decode(post?.title?.rendered || 'Articolo'));
      const excerpt = stripHtml(post?.excerpt?.rendered || '');
      const summary = escapeHtml(excerpt.length > 150 ? excerpt.slice(0, 150).trim() + '…' : excerpt);
      const link = post?.link || 'https://sfrattosicuro.it/blog/';
      const date = formatDate(post?.date);

      return `<article class="card">
        <p class="meta">${date}</p>
        <h3>${title}</h3>
        <p>${summary}</p>
        <a href="${link}" target="_blank" rel="noopener noreferrer">Leggi articolo</a>
      </article>`;
    }).join('');
  };

  fetch(`https://www.sfrattosicuro.it/blog/wp-json/wp/v2/posts?per_page=3&_fields=id,date,link,title,excerpt&orderby=date&order=desc&nocache=${Date.now()}`, {
    headers: { Accept: 'application/json' },
    cache: 'no-store'
  })
    .then((response) => (response.ok ? response.json() : Promise.reject(new Error('fetch_failed'))))
    .then((posts) => render(posts))
    .catch(() => {
      // keep fallback cards already rendered in HTML
    });
})();
</script>

<style>
  .blog-latest {
    background: linear-gradient(180deg, #f7fbff 0%, #eef4fb 100%);
    border-top: 1px solid #e2eaf6;
    border-bottom: 1px solid #e2eaf6;
    padding: 44px 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .topbar {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
  }

  .eyebrow {
    margin: 0 0 6px;
    font-size: .78rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: #c6902a;
    font-weight: 700;
  }

  h2 {
    margin: 0;
    color: var(--blue-navy);
    font-size: clamp(1.45rem, 2.2vw, 1.95rem);
  }

  .sub {
    margin: 8px 0 0;
    color: #3d4b65;
    max-width: 68ch;
    line-height: 1.65;
  }

  .all-link {
    text-decoration: none;
    color: #1b376b;
    font-weight: 700;
    white-space: nowrap;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .card {
    border: 1px solid #d9e4f3;
    border-radius: 14px;
    background: #fff;
    padding: 16px;
    box-shadow: 0 10px 24px rgba(22, 35, 60, .07);
    display: grid;
    gap: 10px;
  }

  .meta {
    margin: 0;
    font-size: .8rem;
    color: #64748b;
    font-weight: 600;
  }

  h3 {
    margin: 0;
    color: var(--blue-navy);
    font-size: 1.2rem;
    line-height: 1.25;
  }

  .card p {
    margin: 0;
    color: #334155;
    line-height: 1.6;
  }

  .card a {
    margin-top: 4px;
    color: #1e3a8a;
    text-decoration: none;
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .topbar { flex-direction: column; align-items: flex-start; }
    .cards { grid-template-columns: 1fr; }
  }
</style>
