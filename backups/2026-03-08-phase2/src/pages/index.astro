---
import SiteLayout from '../layouts/SiteLayout.astro';
import HeaderIsland from '../components/HeaderIsland.astro';
import ReviewsIsland from '../components/ReviewsIsland.astro';
import LatestBlogPostsIsland from '../components/LatestBlogPostsIsland.astro';
import ContactFormIsland from '../components/ContactFormIsland.astro';
import SmoothScrollIsland from '../components/SmoothScrollIsland.astro';
import Footer from '../components/Footer.astro';
import HeroInstitutionalIsland from '../components/HeroInstitutionalIsland.astro';
import SedeIdentityIsland from '../components/SedeIdentityIsland.astro';
import WhenPossibleSection from '../components/WhenPossibleSection.astro';
import ProcedureSection from '../components/ProcedureSection.astro';
import TypesSection from '../components/TypesSection.astro';
import TimelineSection from '../components/TimelineSection.astro';
import WhyLawyerSection from '../components/WhyLawyerSection.astro';
import TerritoryCoverageSection from '../components/TerritoryCoverageSection.astro';
import DoveOperiamoSection from '../components/DoveOperiamoSection.astro';
import StudioSection from '../components/StudioSection.astro';
import ProvvedimentiIsland from '../components/ProvvedimentiIsland.astro';
import FaqSection from '../components/FaqSection.astro';
import JsonLd from '../components/JsonLd.astro';
import PageJumpNavIsland from '../components/PageJumpNavIsland.astro';
import TerritorialCtaIsland from '../components/TerritorialCtaIsland.astro';
import site from '../data/site.json';

const title = 'Avvocato per sfratto per morosità | Sfratto Sicuro';
const description = 'Avvocato per sfratto per morosità e finita locazione. Guida su come sfrattare un inquilino e assistenza legale fino al rilascio dell’immobile.';
const siteUrl = site.siteUrl.replace(/\/$/, '');

const faqEntities = [
  {
    '@type': 'Question',
    name: 'Quanto tempo serve per sfrattare un inquilino?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'La durata dipende dal tribunale competente e dall’eventuale opposizione dell’inquilino.'
    }
  },
  {
    '@type': 'Question',
    name: 'Quanti mesi di affitto non pagato servono per lo sfratto?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'In genere è possibile avviare la procedura quando l’inquilino non paga il canone nei termini previsti dal contratto.'
    }
  },
  {
    '@type': 'Question',
    name: 'È possibile sfrattare un inquilino con figli minori?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'La presenza di minori non impedisce la procedura di sfratto ma può incidere sui tempi dell’esecuzione.'
    }
  }
];

const org = site.organization;
const mapUrl = org.sameAs?.[0] || '';

const homeGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: `${siteUrl}/`,
      name: org.name,
      publisher: { '@id': `${siteUrl}/#organization` }
    },
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: org.name,
      legalName: org.legalName,
      url: `${siteUrl}/`,
      logo: {
        '@type': 'ImageObject',
        url: org.logoUrl
      },
      email: org.email,
      telephone: org.telephone,
      vatID: org.vatID,
      address: {
        '@type': 'PostalAddress',
        ...org.nationalAddress
      },
      contactPoint: [
        {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          telephone: org.telephone,
          email: org.email,
          availableLanguage: ['it']
        },
        {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          url: org.whatsappUrl,
          availableLanguage: ['it']
        }
      ],
      sameAs: org.sameAs || []
    },
    {
      '@type': 'LegalService',
      '@id': `${siteUrl}/#legalservice`,
      name: org.name,
      url: `${siteUrl}/`,
      areaServed: [
        { '@type': 'Country', name: 'IT' },
        { '@type': 'AdministrativeArea', name: org.nationalAddress.addressRegion },
        { '@type': 'City', name: org.nationalAddress.addressLocality }
      ],
      serviceType: ['Sfratto per morosità', 'Sfratto per finita locazione'],
      provider: { '@id': `${siteUrl}/#organization` },
      ...(mapUrl ? { hasMap: mapUrl } : {})
    },
    {
      '@type': 'WebPage',
      '@id': `${siteUrl}/#webpage`,
      url: `${siteUrl}/`,
      name: title,
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}/#legalservice` }
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteUrl}/#faq`,
      mainEntity: faqEntities
    }
  ]
};
---

<SiteLayout title={title} description={description} canonicalPath="/" image="/og-home.jpg">
  <Fragment slot="head">
    <JsonLd graph={homeGraph} />
  </Fragment>

  <HeaderIsland />
  <PageJumpNavIsland
    title="Percorso rapido"
    items={[
      { href: '#procedura-sfratto', label: 'Procedura' },
      { href: '#faq-sfratto', label: 'FAQ' },
      { href: '#contatti', label: 'Contatti' },
      { href: '/sedi/', label: 'Sedi territoriali' }
    ]}
  />

  <main id="main-content">
    <HeroInstitutionalIsland sedeSlug="nazionale" />
    <SedeIdentityIsland sedeSlug="nazionale" />
    <TerritorialCtaIsland sedeSlug="nazionale" />

    <WhenPossibleSection sedeSlug="nazionale" />
    <ProcedureSection sedeSlug="nazionale" />
    <TypesSection sedeSlug="nazionale" />
    <TimelineSection sedeSlug="nazionale" />
    <WhyLawyerSection sedeSlug="nazionale" />
    <TerritoryCoverageSection sedeSlug="nazionale" />

    <DoveOperiamoSection />
    <StudioSection sedeSlug="nazionale" />
    <ProvvedimentiIsland />
    <ReviewsIsland />
    <LatestBlogPostsIsland />
    <FaqSection />
    <ContactFormIsland />
  </main>

  <Footer sedeSlug="nazionale" />
  <SmoothScrollIsland />
</SiteLayout>
