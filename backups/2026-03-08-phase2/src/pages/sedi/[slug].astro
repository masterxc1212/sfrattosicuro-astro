---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HeaderIsland from '../../components/HeaderIsland.astro';
import HeroInstitutionalIsland from '../../components/HeroInstitutionalIsland.astro';
import SedeIdentityIsland from '../../components/SedeIdentityIsland.astro';
import WhenPossibleSection from '../../components/WhenPossibleSection.astro';
import ProcedureSection from '../../components/ProcedureSection.astro';
import TypesSection from '../../components/TypesSection.astro';
import TimelineSection from '../../components/TimelineSection.astro';
import WhyLawyerSection from '../../components/WhyLawyerSection.astro';
import TerritoryCoverageSection from '../../components/TerritoryCoverageSection.astro';
import StudioSection from '../../components/StudioSection.astro';
import ProvvedimentiIsland from '../../components/ProvvedimentiIsland.astro';
import ReviewsIsland from '../../components/ReviewsIsland.astro';
import VideoReviewsIsland from '../../components/VideoReviewsIsland.astro';
import FaqSection from '../../components/FaqSection.astro';
import ContactFormIsland from '../../components/ContactFormIsland.astro';
import Footer from '../../components/Footer.astro';
import SmoothScrollIsland from '../../components/SmoothScrollIsland.astro';
import JsonLd from '../../components/JsonLd.astro';
import PageJumpNavIsland from '../../components/PageJumpNavIsland.astro';
import TerritorialCtaIsland from '../../components/TerritorialCtaIsland.astro';
import sedi from '../../data/sedi.json';
import site from '../../data/site.json';

type OfficeAddress = {
  streetAddress?: string;
  addressLocality?: string;
  postalCode?: string;
  addressRegion?: string;
  addressCountry?: string;
};

type LocalFaqItem = { q: string; a: string };

type SedeItem = {
  nome: string;
  slug: string;
  tribunale: string;
  areaServita: string;
  regione: string;
  faqLocal?: LocalFaqItem[];
  officeAddress?: OfficeAddress | null;
};

export function getStaticPaths() {
  const allSedi = sedi as SedeItem[];
  return allSedi.map((item) => ({
    params: { slug: item.slug },
    props: { sede: item }
  }));
}

const { sede } = Astro.props as { sede: SedeItem };
const siteUrl = site.siteUrl.replace(/\/$/, '');
const canonicalPath = `/sedi/${sede.slug}/`;
const title = `Avvocato per sfratto a ${sede.nome} | Sfratto Sicuro`;
const description = `Avvocato per sfratto a ${sede.nome}. Assistenza legale per sfratto per morosità e finita locazione presso il ${sede.tribunale}.`;

const fallbackFaq = [
  {
    q: `Quanto tempo richiede uno sfratto a ${sede.nome}?`,
    a: `I tempi dipendono dal calendario del ${sede.tribunale} e dall'eventuale opposizione dell'inquilino.`
  },
  {
    q: `Quando si può avviare lo sfratto per morosità a ${sede.nome}?`,
    a: 'La procedura può essere avviata quando l’inquilino non paga i canoni nei termini previsti dal contratto.'
  },
  {
    q: `Serve un avvocato per sfrattare un inquilino a ${sede.nome}?`,
    a: 'Sì. L’assistenza legale è necessaria per impostare correttamente la procedura e seguire udienza di convalida ed eventuale fase esecutiva.'
  }
];

const faqVisible = (sede.faqLocal && sede.faqLocal.length ? sede.faqLocal : fallbackFaq).slice(0, 3);
const faqEntities = faqVisible.map((item) => ({
  '@type': 'Question',
  name: item.q,
  acceptedAnswer: {
    '@type': 'Answer',
    text: item.a
  }
}));

const hasRealAddress = !!(sede.officeAddress && sede.officeAddress.streetAddress && sede.officeAddress.addressLocality);

const legalServiceNode: Record<string, unknown> = {
  '@type': 'LegalService',
  '@id': `${siteUrl}${canonicalPath}#legalservice`,
  name: `Avvocato per sfratto a ${sede.nome}`,
  url: `${siteUrl}${canonicalPath}`,
  areaServed: [
    { '@type': 'Country', name: 'IT' },
    { '@type': 'AdministrativeArea', name: sede.regione },
    { '@type': 'City', name: sede.nome }
  ],
  serviceType: ['Sfratto per morosità', 'Sfratto per finita locazione'],
  provider: { '@id': `${siteUrl}/#organization` }
};

if (hasRealAddress) {
  legalServiceNode.address = {
    '@type': 'PostalAddress',
    streetAddress: sede.officeAddress?.streetAddress,
    addressLocality: sede.officeAddress?.addressLocality,
    postalCode: sede.officeAddress?.postalCode,
    addressRegion: sede.officeAddress?.addressRegion,
    addressCountry: sede.officeAddress?.addressCountry || 'IT'
  };
}

const sedeGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      '@id': `${siteUrl}${canonicalPath}#breadcrumbs`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Sedi', item: `${siteUrl}/sedi/` },
        { '@type': 'ListItem', position: 3, name: sede.nome, item: `${siteUrl}${canonicalPath}` }
      ]
    },
    legalServiceNode,
    {
      '@type': 'WebPage',
      '@id': `${siteUrl}${canonicalPath}#webpage`,
      url: `${siteUrl}${canonicalPath}`,
      name: title,
      inLanguage: 'it-IT',
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}${canonicalPath}#legalservice` },
      mainEntity: { '@id': `${siteUrl}${canonicalPath}#legalservice` }
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteUrl}${canonicalPath}#faq`,
      mainEntity: faqEntities
    }
  ]
};
---

<SiteLayout title={title} description={description} canonicalPath={canonicalPath} image="/og-sedi.jpg">
  <Fragment slot="head">
    <JsonLd graph={sedeGraph} />
  </Fragment>

  <HeaderIsland />
  <PageJumpNavIsland
    title={`Percorso rapido · ${sede.nome}`}
    items={[
      { href: '#procedura-sfratto', label: 'Procedura' },
      { href: '#faq-sfratto', label: 'FAQ locali' },
      { href: '#contatti', label: 'Contatti' },
      { href: '/sedi/', label: 'Tutte le sedi' }
    ]}
  />

  <main id="main-content">
    <nav class="breadcrumb container" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/sedi/">Sedi</a>
      <span>/</span>
      <span aria-current="page">{sede.nome}</span>
    </nav>

    <HeroInstitutionalIsland sedeSlug={sede.slug} />
    <SedeIdentityIsland sedeSlug={sede.slug} />
    <TerritorialCtaIsland sedeSlug={sede.slug} />

    <section class="section section--compact intro container">
      <p>Se devi sfrattare un inquilino a {sede.nome}, un avvocato per sfratto può assisterti nella procedura di sfratto per morosità o finita locazione presso il {sede.tribunale}.</p>
      <a class="back-link" href="/sedi/">← Torna all'elenco sedi</a>
    </section>

    <WhenPossibleSection sedeSlug={sede.slug} />
    <ProcedureSection sedeSlug={sede.slug} />
    <TypesSection sedeSlug={sede.slug} />
    <TimelineSection sedeSlug={sede.slug} />
    <WhyLawyerSection sedeSlug={sede.slug} />
    <TerritoryCoverageSection sedeSlug={sede.slug} />

    <StudioSection sedeSlug={sede.slug} />
    <ProvvedimentiIsland />
    <ReviewsIsland />
    <VideoReviewsIsland />
    <FaqSection sedeSlug={sede.slug} faqItems={faqVisible} />
    <ContactFormIsland />
  </main>

  <Footer sedeSlug={sede.slug} />
  <SmoothScrollIsland />
</SiteLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-top: 18px;
    font-size: .95rem;
    color: #64748b;
  }

  .breadcrumb a { color: #1e3a8a; text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .intro p { margin: 0 0 12px; line-height: 1.65; color: #334155; }
  .back-link { color: #1e3a8a; text-decoration: none; font-weight: 600; }
</style>
