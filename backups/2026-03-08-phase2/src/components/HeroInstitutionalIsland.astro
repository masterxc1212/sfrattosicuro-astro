---
import sedi from '../data/sedi.json';

interface HeroVars {
  kicker?: string;
  h1Suffix?: string;
  subtitleLocal?: string;
  trustLocal1?: string;
  trustLocal2?: string;
  trustLocal3?: string;
  imageAlt?: string;
}

interface SedeItem {
  nome: string;
  slug: string;
  regione?: string;
  intro?: string;
  heroVars?: HeroVars;
}

interface HeroCarouselItem {
  image: string;
  alt: string;
  title: string;
  description: string;
}

interface Props {
  sedeSlug?: string;
  kicker?: string;
  h1?: string;
  subtitle?: string;
  bullets?: string[];
  trustRow?: string[];
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  heroImage?: string;
  heroImageAlt?: string;
  bulletsLabel?: string;
  useCarousel?: boolean;
  carouselItems?: HeroCarouselItem[];
}

const {
  sedeSlug = 'nazionale',
  kicker: kickerOverride,
  h1: h1Override,
  subtitle: subtitleOverride,
  bullets: bulletsOverride,
  trustRow: trustRowOverride,
  primaryCtaLabel = 'Richiedi consulenza gratuita',
  primaryCtaHref = '#contatti',
  secondaryCtaLabel = 'Scopri il metodo',
  secondaryCtaHref = '#procedura-sfratto',
  heroImage,
  heroImageAlt,
  bulletsLabel = 'Servizi principali',
  useCarousel = false,
  carouselItems = []
} = Astro.props;

const normalized = sedeSlug.trim().toLowerCase();
const isNazionale = normalized === 'nazionale';
const effectiveSlug = isNazionale ? 'salerno' : normalized;

const sediList = sedi as SedeItem[];
const sede = sediList.find((item) => item.slug === effectiveSlug);
const vars = sede?.heroVars ?? {};

const defaultKicker = 'Specialisti in sfratti e diritto delle locazioni';

const defaultH1 = isNazionale
  ? 'Avvocato per Sfratto'
  : `Avvocato per Sfratto ${vars.h1Suffix ?? sede?.nome ?? ''}`.trim();

const normalizeLocalCopy = (text?: string) =>
  (text || '')
    .replace(/operiamo presso il tribunale di/gi, 'assistenza presso il tribunale di')
    .replace(/operatività presso il tribunale di/gi, 'presenza presso il tribunale di')
    .trim();

const defaultSubtitle = isNazionale
  ? 'Ti assistiamo in tutta Italia per sfrattare un inquilino moroso o a fine locazione, con gestione completa della procedura fino al rilascio dell\'immobile.'
  : normalizeLocalCopy(vars.subtitleLocal)
    || `Ti assistiamo per la procedura di sfratto presso il Tribunale di ${sede?.nome ?? 'competenza territoriale'}, fino al rilascio dell'immobile.`;

const defaultBullets = [
  'Sfratto per morosità e recupero dei canoni non pagati',
  'Sfratto per finita locazione e rilascio dell\'immobile',
  'Consulenza specialistica e gestione completa della pratica'
];

const defaultTrustRow = isNazionale
  ? [
      'Specialisti in sfratti',
      'Esperti in diritto delle locazioni',
      'Operativi su tutto il territorio nazionale'
    ]
  : [
      normalizeLocalCopy(vars.trustLocal1) || `Tribunale competente: ${sede?.nome ?? ''}`,
      vars.trustLocal2 ?? (sede?.regione ? `Copertura territoriale in ${sede.regione}` : 'Copertura territoriale dedicata'),
      vars.trustLocal3 ?? 'Assistenza completa fino alla convalida'
    ];

const kicker = kickerOverride ?? defaultKicker;
const h1 = h1Override ?? defaultH1;
const subtitle = subtitleOverride ?? defaultSubtitle;
const bullets = bulletsOverride ?? defaultBullets;
const trustRow = trustRowOverride ?? defaultTrustRow;

const mediaImage = heroImage ?? '/assets/img/ufficio/hero_home.webp';
const mediaAlt = heroImageAlt ?? vars.imageAlt ?? 'Studio legale Sfratto Sicuro';
const enableCarousel = useCarousel && carouselItems.length > 0;
---

<section class="hero-institutional" aria-labelledby="hero-title">
  <div class="hero-grid">
    <div class="hero-copy">
      <p class="kicker">{kicker}</p>
      <h1 id="hero-title">{h1}</h1>
      <p class="subtitle">{subtitle}</p>

      <ul class="bullets" aria-label={bulletsLabel}>
        {bullets.map((item) => (
          <li>{item}</li>
        ))}
      </ul>

      <div class="cta-row">
        <a href={primaryCtaHref} class="btn btn-primary">{primaryCtaLabel}</a>
        <a href={secondaryCtaHref} class="btn btn-secondary">{secondaryCtaLabel}</a>
      </div>

      <div class="trust-row" aria-label="Elementi di affidabilità">
        {trustRow.map((item) => (
          <span>{item}</span>
        ))}
      </div>
    </div>

    {enableCarousel ? (
      <div class="hero-media hero-carousel" data-hero-carousel>
        <div class="carousel-track">
          {carouselItems.map((item, idx) => (
            <article class={`slide ${idx === 0 ? 'is-active' : ''}`} data-slide style={idx === 0 ? 'display:block' : 'display:none'}>
              <img src={item.image} alt={item.alt} loading={idx === 0 ? 'eager' : 'lazy'} fetchpriority={idx === 0 ? 'high' : 'auto'} decoding="async" />
              <div class="slide-overlay"></div>
              <div class="slide-text">
                <p class="slide-title">{item.title}</p>
                <p class="slide-description">{item.description}</p>
              </div>
            </article>
          ))}
        </div>

        <button class="carousel-btn prev" type="button" aria-label="Slide precedente" data-prev>‹</button>
        <button class="carousel-btn next" type="button" aria-label="Slide successiva" data-next>›</button>

        <div class="carousel-dots" aria-label="Indicatori slide">
          {carouselItems.map((_, idx) => (
            <button type="button" class={`dot ${idx === 0 ? 'is-active' : ''}`} data-dot data-index={idx} aria-label={`Vai alla slide ${idx + 1}`}></button>
          ))}
        </div>
      </div>
    ) : (
      <picture class="hero-media">
        <source srcset={mediaImage} type="image/webp" />
        <img src={mediaImage} alt={mediaAlt} loading="eager" fetchpriority="high" decoding="async" />
      </picture>
    )}
  </div>
</section>

{enableCarousel && (
  <script is:inline>
    (() => {
      const carousels = document.querySelectorAll('[data-hero-carousel]');
      carousels.forEach((root) => {
        const slides = Array.from(root.querySelectorAll('[data-slide]'));
        const dots = Array.from(root.querySelectorAll('[data-dot]'));
        const prev = root.querySelector('[data-prev]');
        const next = root.querySelector('[data-next]');
        if (!slides.length) return;

        let current = 0;
        let timer = null;

        const setActive = (index) => {
          current = (index + slides.length) % slides.length;
          slides.forEach((slide, i) => {
            const isActive = i === current;
            slide.classList.toggle('is-active', isActive);
            slide.style.display = isActive ? 'block' : 'none';
          });
          dots.forEach((dot, i) => dot.classList.toggle('is-active', i === current));
        };

        const play = () => {
          stop();
          timer = setInterval(() => setActive(current + 1), 4500);
        };

        const stop = () => {
          if (timer) {
            clearInterval(timer);
            timer = null;
          }
        };

        prev?.addEventListener('click', () => {
          setActive(current - 1);
          play();
        });

        next?.addEventListener('click', () => {
          setActive(current + 1);
          play();
        });

        dots.forEach((dot, idx) => {
          dot.addEventListener('click', () => {
            setActive(idx);
            play();
          });
        });

        root.addEventListener('mouseenter', stop);
        root.addEventListener('mouseleave', play);
        play();
      });
    })();
  </script>
)}

<style>
  .hero-institutional {
    margin: 0 0 24px;
    padding: clamp(20px, 2.8vw, 34px);
    border-radius: 0;
    background: #f7f9fc;
    border: 1px solid #e2e8f0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(16px, 2.5vw, 30px);
    align-items: center;
  }

  .hero-copy { max-width: 74ch; }

  .kicker {
    margin: 0 0 8px;
    color: #c6902a;
    text-transform: uppercase;
    letter-spacing: .05em;
    font-size: .78rem;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    font-size: clamp(1.7rem, 3.4vw, 2.7rem);
    line-height: 1.12;
    color: var(--blue-navy);
    text-wrap: balance;
  }

  .subtitle {
    margin: 14px 0 0;
    color: #334155;
    line-height: 1.65;
    max-width: 66ch;
    font-size: clamp(1rem, 1.15vw, 1.06rem);
  }

  .bullets {
    margin: 16px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 8px;
    max-width: 70ch;
  }

  .bullets li {
    position: relative;
    padding-left: 22px;
    color: #1e293b;
    line-height: 1.5;
  }

  .bullets li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--green-security);
    font-weight: 700;
  }

  .cta-row { margin-top: 18px; display: flex; flex-wrap: wrap; gap: 10px; }
  .btn { display: inline-flex; align-items: center; justify-content: center; text-decoration: none; font-weight: 700; border-radius: 10px; padding: 12px 16px; }
  .btn-primary { background: var(--green-security); color: #fff; }
  .btn-secondary { background: #fff; color: var(--blue-navy); border: 1px solid #d8e1ef; }

  .trust-row { margin-top: 14px; display: flex; flex-wrap: wrap; gap: 8px; }
  .trust-row span {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 6px 10px;
    background: #eef3fb;
    border: 1px solid #d8e1ef;
    color: var(--blue-navy);
    font-size: 12px;
  }

  .hero-media {
    width: 100%;
    border-radius: 0;
    overflow: hidden;
    border: 1px solid #dbe4f2;
    background: #fff;
    aspect-ratio: 16 / 10;
    position: relative;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .hero-carousel .carousel-track { position: relative; width: 100%; height: 100%; }
  .hero-carousel .slide {
    position: absolute;
    inset: 0;
    display: none;
    animation: fadeIn .35s ease;
    background: #f8fafc;
  }
  .hero-carousel .slide.is-active {
    display: block;
  }

  .hero-carousel .slide img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #f8fafc;
  }

  .hero-carousel .slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15, 23, 42, 0.55) 0%, rgba(15, 23, 42, 0.08) 58%, rgba(15, 23, 42, 0.02) 100%);
    pointer-events: none;
  }

  .hero-carousel .slide-text {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 14px;
    color: #fff;
  }

  .hero-carousel .slide-title {
    margin: 0;
    font-weight: 700;
    font-size: .95rem;
    line-height: 1.3;
    color: #fff;
  }

  .hero-carousel .slide-description {
    margin: 4px 0 0;
    font-size: .82rem;
    line-height: 1.4;
    color: #e2e8f0;
  }

  .hero-carousel .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.45);
    background: rgba(15, 23, 42, .45);
    color: #fff;
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
  }

  .hero-carousel .carousel-btn.prev { left: 10px; }
  .hero-carousel .carousel-btn.next { right: 10px; }

  .hero-carousel .carousel-dots {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 8px;
    display: flex;
    justify-content: center;
    gap: 6px;
    z-index: 2;
  }

  .hero-carousel .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: 0;
    background: rgba(255,255,255,.55);
    cursor: pointer;
  }

  .hero-carousel .dot.is-active { background: #fff; }

  @keyframes fadeIn {
    from { opacity: .25; }
    to { opacity: 1; }
  }

  @media (min-width: 980px) {
    .hero-grid { grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr); }
    .hero-copy { max-width: 62ch; }
    .hero-media { justify-self: end; max-width: 560px; aspect-ratio: 4 / 3; }
  }
</style>
