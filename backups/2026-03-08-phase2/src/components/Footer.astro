---
import sedi from '../data/sedi.json';
import site from '../data/site.json';

interface SedeItem {
  nome: string;
  slug: string;
  regione?: string;
  indirizzo?: string;
  tribunale?: string;
}

interface Props {
  sedeSlug?: string;
}

const { sedeSlug = 'nazionale' } = Astro.props;

const sediList = sedi as SedeItem[];
const sede = sedeSlug && sedeSlug !== 'nazionale'
  ? sediList.find((item) => item.slug === sedeSlug)
  : undefined;

const sedeLabel = sede ? `Sede territoriale: ${sede.nome}` : 'Sede centrale: Salerno';
const sedeLocalita = sede
  ? `${sede.nome}${sede.regione ? `, ${sede.regione}` : ''}`
  : 'Salerno';
const org = site.organization;
const orgAddress = org?.nationalAddress;

const sedeAddress = sede?.indirizzo?.trim() || `${orgAddress?.streetAddress ?? 'Via F. P. Volpe 2'}, ${orgAddress?.postalCode ?? '84122'} ${orgAddress?.addressLocality ?? 'Salerno'} (${orgAddress?.addressRegion ?? 'SA'})`;

const tribunale = sede?.tribunale ?? (sede ? `Tribunale di ${sede.nome}` : 'Tribunali competenti in tutta Italia');

const coperturaText = sede
  ? ''
  : 'Operiamo fisicamente presso i Tribunali competenti su tutto il territorio nazionale.';

const legalName = org?.legalName ?? 'D1 S.R.L.S.';
const vatId = (org?.vatID || '').replace(/^IT/i, '') || '06177400659';
const legalEmail = org?.email ?? 'consulenza@sfrattosicuro.it';
const legalPhone = org?.telephone ?? '+39 02 8089 8395';
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="grid">
      <div>
        <a href="/" class="brand" aria-label="Sfratto Sicuro - Torna alla home">
          <img src="https://www.sfrattosicuro.it/assets/img/logo/logo-100.webp" alt="Sfratto Sicuro" width="50" height="50" />
          <div class="brand-text">
            <span>Sfratto Sicuro</span>
            <small>Avvocati Specializzati</small>
          </div>
        </a>
        <p class="muted">Il primo servizio legale in Italia specializzato esclusivamente nel recupero immobili per morosità.</p>
        <p class="muted small legal-links">
          <a href="/privacy-policy/">Privacy Policy</a> ·
          <a href="/termini/">Termini</a> ·
          <a href="/cookie-policy">Cookie Policy</a>
        </p>
      </div>

      <div>
        <h3>Servizi</h3>
        <ul>
          <li><a href="/servizi/">Sfratto Abitativo</a></li>
          <li><a href="/servizi/">Sfratto Commerciale</a></li>
          <li><a href="/servizi/">Recupero Canoni</a></li>
          <li><a href="/servizi/">Esecuzione Forzata</a></li>
        </ul>
      </div>

      <div>
        <h3>Dove Operiamo</h3>
        <div class="where-card">
          <p class="where-title">{sedeLabel}</p>
          <p class="where-line"><strong>Tribunale:</strong> {tribunale}</p>
          <p class="where-line"><strong>Area:</strong> {sedeLocalita}</p>
          <p class="where-line"><strong>Indirizzo:</strong> {sedeAddress}</p>
          {coperturaText && <p class="where-note">{coperturaText}</p>}
        </div>
      </div>

      <div>
        <h3>Dati Societari</h3>
        <p class="strong">© {new Date().getFullYear()} Sfratto Sicuro</p>
        <p>{legalName}</p>
        <p class="muted small">P. IVA {vatId}</p>
        <p class="muted small">E-mail: <a href={`mailto:${legalEmail}`}>{legalEmail}</a></p>
        <p class="muted small">Telefono: <a href={`tel:${legalPhone.replace(/\s+/g, '')}`}>{legalPhone}</a></p>
        <p class="muted small">Capitale Sociale Interamente Versato</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 2rem;
    padding: 2.5rem 0;
    color: #fff;
    background: linear-gradient(180deg, var(--blue-navy) 0%, #152040 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  h3 { margin: 0 0 1rem; font-size: 1.05rem; }
  ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.5rem; }
  a { color: #d2d9e6; text-decoration: none; }
  a:hover { color: var(--green-security); }
  .brand { display: inline-flex; align-items: center; gap: 0.55rem; margin-bottom: 0.75rem; }
  .brand img { filter: brightness(0) invert(1); }
  .brand-text span { display: block; font-size: 1.2rem; font-weight: 700; color: #fff; }
  .brand-text small { color: #c9a961; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; }
  .muted { color: #c7d0df; }
  .strong { color: #fff; font-weight: 700; }
  .small { font-size: 0.85rem; }
  .legal-links { margin-top: .65rem; }
  .legal-links a { color: #d2d9e6; }
  .legal-links a:hover { color: var(--green-security); }
  .where-card {
    border: 1px solid rgba(255,255,255,.16);
    background: rgba(255,255,255,.04);
    border-radius: 12px;
    padding: 14px;
    display: grid;
    gap: 8px;
  }
  .where-title {
    margin: 0;
    color: #c9a961;
    font-weight: 700;
    font-size: .9rem;
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .where-line { margin: 0; color: #e7edf8; }
  .where-line strong { color: #fff; }
  .where-note { margin: 4px 0 0; color: #c7d0df; font-size: .92rem; line-height: 1.5; }
  @media (min-width: 900px) { .grid { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 2.5rem; } }
</style>
